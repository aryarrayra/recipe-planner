<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <% const profileData = profile || {}; %>
  <% const avatarUrl = profileData.avatarUrl || user.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(user.username || 'Pengguna')}`; %>
  <% const hasCustomAvatar = Boolean(user.avatar_url && !String(user.avatar_url).includes('ui-avatars.com')); %>
  <% const progress = profileData.progress || { level: 1, title: 'Koki Pemula', progress: 0, activityPoints: 0, pointsIntoLevel: 0, pointsToNextLevel: 10 }; %>
  <% const skillLabel = profileData.skillLevel || 'Pemula'; %>
  <% const totalCooked = Number(profileData.cookingCount || user.total_recipes_cooked || 0); %>
  <% const totalSaved = Number(user.total_saved_recipes || 0); %>
  <% const totalShared = Number(user.total_recipes_shared || 0); %>
  <% const favoriteCount = Number(profileData.favoriteCount || 0); %>
  <% const communityFeed = profileData.communityFeed || { posts: [], comments: [] }; %>
  <% const profileBio = String(profileData.bio || user.bio || '').trim() || 'Belum ada bio akun. Tambahkan cerita singkat tentang gaya masak atau menu favoritmu di pengaturan profil.'; %>
  <% const birthDateDisplay = String(profileData.birthDate || '').trim(); %>
  <% const birthDateValue = String(profileData.birthDateValue || '').trim(); %>
  <% const regionOrigin = String(profileData.regionOrigin || user.region_origin || '').trim(); %>
  <% const communityPosts = Array.isArray(communityFeed.posts) ? communityFeed.posts : []; %>
  <% const communityComments = Array.isArray(communityFeed.comments) ? communityFeed.comments : []; %>
  <% const communityPostUrl = (recipe) => `/community/posts/${encodeURIComponent(recipe.communityPostId || recipe.postId || recipe.post_id || recipe.id || '')}`; %>
  <% const communityCommentUrl = (comment) => `/community/posts/${encodeURIComponent(comment.postId || comment.post_id || '')}`; %>
  <% const formatRelativeTime = (value) => {
    if (!value) return 'baru saja';
    const created = new Date(value);
    if (Number.isNaN(created.getTime())) return 'baru saja';
    const diff = Date.now() - created.getTime();
    const minutes = Math.max(0, Math.floor(diff / 60000));
    if (minutes < 1) return 'baru saja';
    if (minutes < 60) return `${minutes}m`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}d`;
    return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
  }; %>
  <style>
    body.profile-page {
      background: #ffffff;
    }

    .profile-dashboard .user-dashboard-main {
      display: grid;
      gap: 18px;
      padding: 20px;
      border-radius: 0;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      box-shadow: none;
      min-width: 0;
    }

    .profile-topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      padding: 24px 26px;
      border-radius: 20px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      box-shadow: none;
      backdrop-filter: none;
    }

    .profile-topbar-copy {
      display: grid;
      gap: 10px;
      max-width: 760px;
    }

    .profile-topbar-copy h1 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(1.8rem, 2.7vw, 2.8rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .profile-topbar-note {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      max-width: 78ch;
    }

    .profile-quick-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 4px;
    }

    .profile-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid rgba(15, 20, 25, 0.08);
      background: #f7f9fa;
      color: #0f1419;
      text-decoration: none;
      font: inherit;
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: none;
    }

    .profile-chip:hover {
      background: #eef3f4;
      border-color: rgba(15, 20, 25, 0.12);
    }

    .profile-topbar-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-end;
      align-items: center;
    }

    .profile-settings-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 0;
      appearance: none;
      -webkit-appearance: none;
      background: #0f1419;
      color: #fff;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      box-shadow: none;
    }

    .profile-settings-button:hover {
      background: #1d1d1d;
    }

    .profile-settings-button:focus-visible {
      outline: none;
      box-shadow: 0 0 0 4px rgba(15, 20, 25, 0.14);
    }

    .profile-dashboard .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      text-decoration: none;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      border: 0;
      appearance: none;
      -webkit-appearance: none;
    }

    .profile-dashboard .button-secondary {
      background: #f7f9fa;
      color: #0f1419;
      border: 1px solid rgba(15, 20, 25, 0.08);
      box-shadow: none;
    }

    .profile-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 20px;
      align-items: start;
    }

    .profile-main,
    .profile-sidebar {
      display: grid;
      gap: 18px;
    }

    .profile-sidebar {
      display: none;
    }

    .profile-card {
      padding: 22px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      box-shadow: none;
    }

    .profile-card.is-accent {
      background: #ffffff;
    }

    .profile-settings-overlay {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: grid;
      place-items: center;
      padding: 24px;
      background: rgba(15, 20, 25, 0.64);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
    }

    .profile-settings-overlay[hidden] {
      display: none !important;
    }

    body.profile-settings-open {
      overflow: hidden;
    }

    .profile-settings-modal {
      width: min(100%, 1120px);
      max-height: calc(100vh - 48px);
      overflow: auto;
      border-radius: 24px;
      border: 1px solid rgba(15, 20, 25, 0.08);
      background: #ffffff;
      box-shadow: 0 28px 60px rgba(15, 20, 25, 0.18);
      padding: 24px;
      animation: profileSettingsIn 0.22s ease;
    }

    .profile-settings-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .profile-settings-head h2 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.04em;
    }

    .profile-settings-close {
      appearance: none;
      border: 0;
      width: 46px;
      height: 46px;
      border-radius: 999px;
      display: inline-grid;
      place-items: center;
      background: #f7f9fa;
      color: #0f1419;
      cursor: pointer;
      transition:
        transform 0.2s ease,
        background 0.2s ease;
    }

    .profile-settings-close:hover {
      transform: rotate(8deg);
      background: #eef3f4;
    }

    .profile-settings-close:focus-visible {
      outline: none;
      box-shadow: 0 0 0 4px rgba(53, 164, 176, 0.16);
    }

    .profile-settings-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
      gap: 18px;
      align-items: start;
    }

    .profile-settings-column {
      display: grid;
      gap: 18px;
    }

    .profile-settings-section {
      padding: 22px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      box-shadow: none;
    }

    .profile-settings-section-wide {
      grid-column: 1 / -1;
    }

    .profile-settings-section .profile-section-head {
      margin-bottom: 14px;
    }

    .profile-settings-section .profile-section-actions {
      margin-top: 16px;
    }

    .profile-settings-section .profile-form-grid {
      margin-top: 0;
    }

    .profile-settings-section .profile-preference-grid {
      max-height: 360px;
      overflow: auto;
      padding-right: 4px;
    }

    .profile-settings-section .profile-field input[type="file"] {
      padding: 12px 14px;
      background: #fff;
    }

    @keyframes profileSettingsIn {
      from {
        transform: translateY(18px) scale(0.98);
        opacity: 0;
      }

      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    .profile-hero {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: 18px;
      align-items: start;
    }

    .profile-avatar-wrap {
      display: grid;
      gap: 10px;
      justify-items: start;
      align-content: start;
    }

    .profile-avatar-form {
      margin: 0;
    }

    .profile-avatar-button {
      position: relative;
      appearance: none;
      border: 0;
      padding: 0;
      background: transparent;
      cursor: pointer;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: none;
    }

    .profile-avatar-button img {
      width: 120px;
      height: 120px;
      object-fit: cover;
      display: block;
    }

    .profile-avatar-overlay {
      position: absolute;
      right: 10px;
      bottom: 10px;
      width: 32px;
      height: 32px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      background: #0f1419;
      color: #fff;
      font-size: 0.82rem;
      box-shadow: 0 10px 18px rgba(29, 29, 29, 0.18);
    }

    .profile-avatar-caption {
      margin: 0;
      color: var(--muted);
      font-size: 0.82rem;
      text-align: center;
    }

    .profile-avatar {
      width: 120px;
      height: 120px;
      border-radius: 24px;
      overflow: hidden;
      background: #eef2ee;
      box-shadow: none;
    }

    .profile-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .profile-name-row {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .profile-name-row h2 {
      margin: 6px 0 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(1.5rem, 2.2vw, 2.4rem);
      letter-spacing: -0.04em;
      line-height: 1.05;
    }

    .profile-muted {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
    }

    .profile-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 12px;
    }

    .profile-bio-box {
      margin-top: 16px;
      padding: 14px 16px;
      border-radius: 18px;
      background: #f7f9fa;
      border: 1px solid rgba(15, 20, 25, 0.08);
      color: #536471;
      line-height: 1.7;
    }

    .profile-bio-box strong {
      display: block;
      margin-bottom: 6px;
      color: #0f1419;
      font-size: 0.92rem;
    }

    .profile-account-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .profile-account-meta span {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #f7f9fa;
      color: #536471;
      font-size: 0.84rem;
      font-weight: 700;
    }

    .profile-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: #f7f9fa;
      color: #0f1419;
      font-weight: 700;
    }

    .profile-badge-label {
      white-space: nowrap;
    }

    .profile-level-pill {
      display: inline-grid;
      gap: 4px;
      align-content: center;
      padding: 10px 14px;
      border-radius: 18px;
      background: #f7f9fa;
      border: 1px solid rgba(15, 20, 25, 0.08);
      color: #0f1419;
      font-weight: 800;
      min-width: 120px;
    }

    .profile-level-pill span {
      font-size: 0.82rem;
      font-weight: 700;
      color: #536471;
    }

    .profile-stats-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .profile-stat {
      padding: 14px 16px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      display: grid;
      gap: 5px;
    }

    .profile-stat strong {
      font-family: "Space Grotesk", sans-serif;
      font-size: 1.35rem;
      letter-spacing: -0.04em;
    }

    .profile-section-head {
      display: grid;
      gap: 4px;
      margin-bottom: 16px;
    }

    .profile-section-head h3 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: 1.35rem;
      letter-spacing: -0.03em;
    }

    .profile-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .profile-field {
      display: grid;
      gap: 8px;
    }

    .profile-field.full {
      grid-column: 1 / -1;
    }

    .profile-field label {
      font-weight: 800;
      color: var(--text);
    }

    .profile-field input,
    .profile-field textarea,
    .profile-field select {
      width: 100%;
      padding: 13px 14px;
      border-radius: 16px;
      border: 1px solid rgba(29, 29, 29, 0.1);
      background: #fff;
      color: var(--text);
      font: inherit;
      box-sizing: border-box;
      appearance: none;
      -webkit-appearance: none;
      box-shadow: 0 8px 20px rgba(29, 29, 29, 0.04);
    }

    .profile-field input[type="date"] {
      appearance: auto;
      -webkit-appearance: auto;
      min-height: 52px;
    }

    .profile-field input[type="file"] {
      padding: 11px 14px;
      background: #fff;
      appearance: auto;
      -webkit-appearance: auto;
      box-shadow: none;
    }

    .profile-field textarea {
      min-height: 108px;
      resize: vertical;
    }

    .profile-section-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 16px;
    }

    .profile-primary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 0;
      background: #0f1419;
      color: #fff;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      box-shadow: none;
    }

    .profile-secondary-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid rgba(15, 20, 25, 0.08);
      background: #f7f9fa;
      color: #0f1419;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
    }

    .profile-progress {
      display: grid;
      gap: 12px;
    }

    .profile-progress-meter {
      height: 14px;
      border-radius: 999px;
      background: rgba(15, 20, 25, 0.08);
      overflow: hidden;
    }

    .profile-progress-meter span {
      display: block;
      height: 100%;
      border-radius: inherit;
      background: #1d9bf0;
      width: <%= Math.max(0, Math.min(100, progress.progress || 0)) %>%;
    }

    .profile-progress-meta {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      color: var(--muted);
      font-size: 0.92rem;
    }

    .profile-side-list {
      display: grid;
      gap: 12px;
    }

    .profile-side-item {
      display: grid;
      gap: 5px;
      padding: 14px 16px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
    }

    .profile-side-item strong {
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.02em;
    }

    .profile-preference-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .profile-preference-chip {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 14px;
      border-radius: 16px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      cursor: pointer;
      overflow: hidden;
    }

    .profile-preference-chip input {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
    }

    .profile-preference-chip span {
      font-size: 0.86rem;
      font-weight: 700;
      color: var(--text);
    }

    .profile-preference-chip:has(input:checked) {
      border-color: rgba(29, 155, 240, 0.36);
      background: rgba(29, 155, 240, 0.08);
    }

    .profile-empty-state {
      padding: 16px;
      border-radius: 18px;
      background: #f7f9fa;
      color: var(--muted);
      line-height: 1.6;
    }

    .profile-password-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .profile-note-box {
      padding: 16px;
      border-radius: 18px;
      background: #f7f9fa;
      color: #0f1419;
      line-height: 1.6;
    }

    .profile-flash-message {
      transition:
        opacity 220ms ease,
        transform 220ms ease,
        max-height 220ms ease,
        margin 220ms ease,
        padding 220ms ease;
      opacity: 1;
      transform: translateY(0);
      max-height: 160px;
      overflow: hidden;
    }

    .profile-flash-message.is-hiding {
      opacity: 0;
      transform: translateY(-8px);
      max-height: 0;
      margin: 0;
      padding-top: 0;
      padding-bottom: 0;
    }

    .profile-community-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .profile-community-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .profile-community-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .profile-community-stream {
      display: grid;
      gap: 0;
    }

    .profile-community-card-link {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    .profile-community-card-link:hover .profile-community-text {
      color: #0f1419;
    }

    .profile-community-tweet,
    .profile-community-reply {
      display: grid;
      grid-template-columns: 48px minmax(0, 1fr);
      gap: 12px;
      padding: 18px 0;
      border: 0;
      border-bottom: 1px solid rgba(15, 20, 25, 0.08);
      background: transparent;
      box-shadow: none;
    }

    .profile-community-reply {
      padding: 14px 0;
    }

    .profile-community-avatar {
      width: 48px;
      height: 48px;
      border-radius: 999px;
      overflow: hidden;
      background: #f7f9fa;
    }

    .profile-community-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-community-body {
      display: grid;
      gap: 10px;
      min-width: 0;
    }

    .profile-community-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .profile-community-user {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px;
      min-width: 0;
      color: #536471;
      font-size: 0.92rem;
    }

    .profile-community-user strong {
      color: #0f1419;
      font-size: 0.98rem;
    }

    .profile-community-user span {
      white-space: nowrap;
    }

    .profile-community-text {
      margin: 0;
      color: #0f1419;
      font-size: 1.02rem;
      line-height: 1.55;
      word-break: break-word;
    }

    .profile-community-subtext {
      margin: 0;
      color: #536471;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .profile-community-media {
      width: 100%;
      border-radius: 20px;
      overflow: hidden;
      background: #f7f9fa;
      border: 1px solid rgba(15, 20, 25, 0.08);
    }

    .profile-community-media img {
      width: 100%;
      display: block;
      max-height: 420px;
      object-fit: cover;
    }

    .profile-community-card {
      display: grid;
      gap: 10px;
      padding: 16px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
    }

    .profile-community-card h4,
    .profile-community-card p {
      margin: 0;
    }

    .profile-community-card h4 {
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.03em;
    }

    .profile-community-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      color: var(--muted);
      font-size: 0.88rem;
    }

    .profile-community-meta span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .profile-community-comments {
      display: grid;
      gap: 10px;
      margin-top: 4px;
    }

    .profile-community-comment {
      padding: 14px 16px;
      border-radius: 16px;
      background: #ffffff;
      border: 1px solid rgba(15, 20, 25, 0.08);
      display: grid;
      gap: 6px;
    }

    .profile-community-reply .profile-community-meta,
    .profile-community-tweet .profile-community-meta {
      color: #536471;
      font-size: 0.88rem;
    }

    .profile-community-comment strong {
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.02em;
    }

    .profile-community-empty {
      padding: 16px;
      border-radius: 18px;
      background: #f7f9fa;
      color: var(--muted);
      line-height: 1.6;
    }

    @media (max-width: 1100px) {
      .profile-layout {
        display: flex;
        flex-direction: column;
      }

      .profile-main,
      .profile-sidebar {
        width: 100%;
      }

      .profile-sidebar {
        order: 1;
      }

      .profile-main {
        order: 2;
      }

      .profile-stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .profile-password-grid {
        grid-template-columns: 1fr;
      }

      .profile-community-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 700px) {
      .profile-dashboard .user-dashboard-main {
        padding: 16px 16px calc(132px + env(safe-area-inset-bottom));
      }

      .profile-topbar {
        padding: 18px;
        flex-direction: column;
      }

      .profile-hero {
        grid-template-columns: 1fr;
      }

      .profile-avatar-button img {
        width: 92px;
        height: 92px;
      }

      .profile-badges {
        gap: 8px;
      }

      .profile-badge {
        min-width: 0;
        justify-content: center;
        padding: 8px 10px;
      }

      .profile-badge-label {
        display: none;
      }

      .profile-stats-grid,
      .profile-form-grid,
      .profile-preference-grid {
        grid-template-columns: 1fr;
      }

      .profile-layout {
        gap: 16px;
      }

      .profile-settings-overlay {
        padding: 10px;
      }

      .profile-settings-modal {
        width: 100%;
        max-height: calc(100vh - 20px);
        padding: 16px;
        border-radius: 20px;
      }

      .profile-settings-head {
        flex-direction: column;
        align-items: stretch;
        margin-bottom: 14px;
      }

      .profile-settings-close {
        align-self: flex-end;
      }

      .profile-settings-grid {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .profile-settings-column {
        gap: 14px;
      }

      .profile-settings-section {
        padding: 16px;
      }

      .profile-settings-section .profile-preference-grid {
        max-height: none;
        overflow: visible;
        padding-right: 0;
      }

      .profile-community-grid,
      .profile-community-stream {
        width: 100%;
        min-width: 0;
      }

      .profile-layout,
      .profile-main,
      .profile-sidebar {
        padding-bottom: calc(8px + env(safe-area-inset-bottom));
      }

      .profile-community-card-link {
        width: 100%;
      }

      .profile-community-tweet,
      .profile-community-reply {
        width: 100%;
        min-width: 0;
      }
    }

    @media (max-width: 640px) {
      .profile-dashboard .user-dashboard-main {
        padding-bottom: calc(136px + env(safe-area-inset-bottom));
      }

      .profile-community-grid {
        gap: 10px;
      }

      .profile-settings-section {
        padding: 14px;
      }

      .profile-community-tweet,
      .profile-community-reply {
        grid-template-columns: 40px minmax(0, 1fr);
        gap: 10px;
        padding: 14px 0;
      }

      .profile-community-avatar {
        width: 40px;
        height: 40px;
      }

      .profile-community-head {
        flex-direction: column;
        align-items: start;
        gap: 8px;
      }

      .profile-community-user {
        width: 100%;
      }

      .profile-community-media {
        border-radius: 16px;
      }

      .profile-community-media img {
        max-height: 220px;
      }
    }
  </style>
  <style>
    body.profile-page {
      background: #ffffff;
    }

    .profile-dashboard .user-dashboard-main {
      border-radius: 0;
      background: #ffffff;
      border-color: rgba(15, 20, 25, 0.08);
      box-shadow: none;
    }

    .profile-topbar,
    .profile-card,
    .profile-settings-section,
    .profile-community-card,
    .profile-community-comment,
    .profile-side-item,
    .profile-empty-state,
    .profile-note-box {
      border-radius: 18px;
      background: #ffffff;
      border-color: rgba(15, 20, 25, 0.08);
      box-shadow: none;
    }

    .profile-topbar {
      backdrop-filter: none;
      padding: 18px 20px;
    }

    .profile-topbar-copy h1,
    .profile-section-head h3,
    .profile-name-row h2,
    .profile-community-card h4 {
      letter-spacing: -0.04em;
    }

    .profile-settings-button {
      background: #0f1419;
      box-shadow: none;
    }

    .profile-settings-button:hover {
      background: #1d1d1d;
    }

    .profile-chip,
    .profile-secondary-button {
      background: #f7f9fa;
      border-color: rgba(15, 20, 25, 0.08);
      color: #0f1419;
      box-shadow: none;
    }

    .profile-primary-button {
      background: #0f1419;
      box-shadow: none;
    }

    .profile-progress-meter {
      background: rgba(15, 20, 25, 0.08);
    }

    .profile-progress-meter span {
      background: #1d9bf0;
    }

    .profile-avatar-button {
      border-radius: 18px;
      box-shadow: none;
    }

    .profile-avatar-overlay {
      background: #0f1419;
    }

    .profile-settings-overlay {
      background: rgba(15, 20, 25, 0.64);
    }

    .profile-settings-modal {
      border-radius: 24px;
      box-shadow: 0 28px 60px rgba(15, 20, 25, 0.18);
    }

    .profile-settings-close {
      background: #f7f9fa;
    }

    .profile-community-grid {
      gap: 12px;
    }

    .profile-community-actions .profile-primary-button,
    .profile-community-actions .profile-secondary-button {
      min-height: 42px;
    }
  </style>
</head>
<body class="profile-page">
  <div class="page-bg"></div>

  <main class="user-dashboard profile-dashboard">
    <div class="user-dashboard-shell profile-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'profile', user }) %>

      <section class="user-dashboard-main">
        <header class="profile-topbar">
          <div class="profile-topbar-copy">
            <p class="user-panel-kicker">Profil</p>
            <h1>Akun dan progres memasak</h1>
            <p class="profile-topbar-note">
              Klik foto profil untuk ganti avatar. Pengaturan bio dan preferensi dibuka lewat tombol Pengaturan.
            </p>
          </div>

          <div class="profile-topbar-actions">
            <button type="button" class="profile-settings-button" id="openProfileSettings">
              <i class="fa-solid fa-gear"></i>
              <span>Pengaturan</span>
            </button>
          </div>
        </header>

        <% if (notice) { %>
          <article class="profile-card is-accent profile-flash-message" data-profile-flash>
            <div class="profile-note-box"><%= notice %></div>
          </article>
        <% } %>

        <% if (error) { %>
          <article class="profile-card is-accent profile-flash-message" data-profile-flash>
            <div class="profile-note-box"><%= error %></div>
          </article>
        <% } %>

        <div class="profile-layout">
          <section class="profile-main">
            <article class="profile-card is-accent">
              <div class="profile-hero">
                <form class="profile-avatar-form" action="/profile/details" method="post" enctype="multipart/form-data">
                  <input
                    class="sr-only"
                    type="file"
                    id="profileAvatarInput"
                    name="avatar_image"
                    accept="image/*"
                    aria-label="Upload foto profil"
                  />
                  <button type="button" class="profile-avatar-button" id="profileAvatarButton" aria-label="Klik untuk ganti foto profil">
                    <img src="<%= avatarUrl %>" alt="<%= user.username %>" />
                    <span class="profile-avatar-overlay" aria-hidden="true">
                      <i class="fa-solid <%= hasCustomAvatar ? 'fa-pen' : 'fa-plus' %>"></i>
                    </span>
                  </button>
                </form>

                <div>
                  <div class="profile-name-row">
                    <div>
                      <p class="user-panel-kicker">Akun aktif</p>
                      <h2><%= user.username %></h2>
                      <p class="profile-muted"><%= user.email %></p>
                    </div>
                    <div class="profile-level-pill">
                      <strong><%= progress.title %></strong>
                      <span>Level <%= progress.level %></span>
                    </div>
                  </div>

                  <% if (birthDateDisplay || regionOrigin) { %>
                    <div class="profile-account-meta">
                      <% if (birthDateDisplay) { %>
                        <span><i class="fa-regular fa-calendar"></i> <%= birthDateDisplay %></span>
                      <% } %>
                      <% if (regionOrigin) { %>
                        <span><i class="fa-solid fa-location-dot"></i> <%= regionOrigin %></span>
                      <% } %>
                    </div>
                  <% } %>

                  <div class="profile-bio-box">
                    <strong>Bio akun</strong>
                    <span><%= profileBio %></span>
                  </div>

                  <div class="profile-badges">
                    <span class="profile-badge"><i class="fa-solid fa-fire-burner"></i> <%= totalCooked %> <span class="profile-badge-label">masak ulang</span></span>
                    <span class="profile-badge"><i class="fa-solid fa-bookmark"></i> <%= totalSaved %> <span class="profile-badge-label">tersimpan</span></span>
                    <span class="profile-badge"><i class="fa-solid fa-share-nodes"></i> <%= totalShared %> <span class="profile-badge-label">dibagikan</span></span>
                    <span class="profile-badge"><i class="fa-solid fa-heart"></i> <%= favoriteCount %> <span class="profile-badge-label">favorit</span></span>
                  </div>
                </div>
              </div>
            </article>

            <article class="profile-card">
              <div class="profile-section-head">
                <p class="user-panel-kicker">Progres level</p>
                <h3><%= progress.title %></h3>
                <p class="profile-muted">Semakin sering recook, simpan, dan bagikan, level akun akan naik.</p>
              </div>

              <div class="profile-progress">
                <div class="profile-progress-meter"><span></span></div>
                <div class="profile-progress-meta">
                  <span><%= progress.activityPoints %> poin aktivitas</span>
                  <span><%= progress.pointsIntoLevel %>/10 menuju level berikutnya</span>
                  <span><%= progress.pointsToNextLevel %> poin lagi</span>
                </div>
              </div>

              <div class="profile-stats-grid" style="margin-top: 16px;">
                <div class="profile-stat">
                  <span>Total masak ulang</span>
                  <strong><%= totalCooked %></strong>
                </div>
                <div class="profile-stat">
                  <span>Favorit tersimpan</span>
                  <strong><%= totalSaved %></strong>
                </div>
                <div class="profile-stat">
                  <span>Resep dibagikan</span>
                  <strong><%= totalShared %></strong>
                </div>
              </div>
            </article>

            <article class="profile-card">
              <div class="profile-section-head profile-community-header">
                <div>
                  <p class="user-panel-kicker">Feed komunitas</p>
                  <h3>Postingan dan komentar kamu</h3>
                  <p class="profile-muted">Semua posting komunitas kamu tampil di sini. Komentar yang kamu kirim ke postingan orang lain juga muncul di bawahnya.</p>
                </div>
              </div>

              <div class="profile-community-grid" style="margin-top: 16px;">
                <div class="profile-settings-section" style="padding: 18px;">
                  <div class="profile-section-head">
                    <p class="user-panel-kicker">Posting kamu</p>
                    <h3>Unggahan terbaru</h3>
                  </div>

                  <% if (communityPosts.length) { %>
                    <div class="profile-community-stream">
                      <% communityPosts.forEach((recipe) => { %>
                        <a class="profile-community-card-link" href="<%= communityPostUrl(recipe) %>">
                        <article class="profile-community-tweet">
                          <div class="profile-community-avatar">
                            <img
                              src="<%= recipe.creatorAvatarUrl || user.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(recipe.creatorName || user.username || 'Pengguna komunitas')}&background=0f1419&color=ffffff&bold=true` %>"
                              alt="<%= recipe.creatorName || user.username %>"
                            />
                          </div>
                          <div class="profile-community-body">
                            <div class="profile-community-head">
                              <div class="profile-community-user">
                                <strong><%= recipe.creatorName || user.username %></strong>
                                <span><%= formatRelativeTime(recipe.createdAt) %></span>
                              </div>
                              <span class="community-status is-approved">Diterbitkan</span>
                            </div>
                            <p class="profile-community-text"><%= recipe.title %></p>
                            <p class="profile-community-subtext"><%= recipe.category %> &bull; <%= recipe.cuisine %></p>
                            <div class="profile-community-media">
                              <img src="<%= recipe.imageUrl || '/images/1.png' %>" alt="<%= recipe.title %>" />
                            </div>
                            <div class="profile-community-meta">
                              <span><i class="fa-regular fa-clock"></i> <%= recipe.cookingTime || 0 %> menit</span>
                              <span><i class="fa-solid fa-wallet"></i> Rp <%= Number(recipe.estimatedPrice || 0).toLocaleString('id-ID') %></span>
                            </div>
                          </div>
                        </article>
                        </a>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <div class="profile-community-empty">
                      Belum ada posting komunitas. Klik <strong>Posting ke komunitas</strong> untuk mulai membagikan resep kamu.
                    </div>
                  <% } %>
                </div>

                <div class="profile-settings-section" style="padding: 18px;">
                  <div class="profile-section-head">
                    <p class="user-panel-kicker">Komentar kamu</p>
                    <h3>Aktivitas balasan</h3>
                  </div>

                  <% if (communityComments.length) { %>
                    <div class="profile-community-stream">
                      <% communityComments.forEach((comment) => { %>
                        <a class="profile-community-card-link" href="<%= communityCommentUrl(comment) %>">
                        <article class="profile-community-reply">
                          <div class="profile-community-avatar">
                            <img
                              src="<%= user.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(comment.creatorName || user.username || 'Pengguna komunitas')}&background=0f1419&color=ffffff&bold=true` %>"
                              alt="<%= comment.creatorName || user.username %>"
                            />
                          </div>
                          <div class="profile-community-body">
                            <div class="profile-community-head">
                              <div class="profile-community-user">
                                <strong><%= comment.creatorName || user.username %></strong>
                                <span><%= formatRelativeTime(comment.createdAt) %></span>
                              </div>
                            </div>
                            <p class="profile-community-text"><%= comment.content %></p>
                            <p class="profile-community-subtext">Balasan ke <%= comment.title %></p>
                          </div>
                        </article>
                        </a>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <div class="profile-community-empty">
                      Belum ada komentar yang kamu kirim ke postingan orang lain.
                    </div>
                  <% } %>
                </div>
              </div>
            </article>

          </section>

          <aside class="profile-sidebar">
            <article class="profile-card">
              <div class="profile-section-head">
                <p class="user-panel-kicker">Preferensi</p>
                <h3>Yang sedang dihindari</h3>
              </div>

              <% if (preferences.length) { %>
                <div class="profile-side-list">
                  <% preferences.forEach((item) => { %>
                    <div class="profile-side-item">
                      <strong><%= (allergyOptions.find((option) => option.key === item) || {}).label || item %></strong>
                      <span>Tidak akan diprioritaskan saat rekomendasi resep.</span>
                    </div>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="profile-empty-state">
                  Belum ada preferensi khusus. Semua resep akan tampil normal sampai kamu memilih yang ingin dihindari.
                </div>
              <% } %>
            </article>
          </aside>
        </div>

        <div class="profile-settings-overlay" id="profileSettingsOverlay" hidden>
          <div class="profile-settings-modal" role="dialog" aria-modal="true" aria-labelledby="profileSettingsTitle">
            <div class="profile-settings-head">
              <div>
                <p class="user-panel-kicker">Pengaturan</p>
                <h2 id="profileSettingsTitle">Edit profil dan preferensi</h2>
              </div>
              <button type="button" class="profile-settings-close" id="closeProfileSettings" aria-label="Tutup pengaturan">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>

            <div class="profile-settings-grid">
              <div class="profile-settings-column">
                <article class="profile-settings-section">
                  <div class="profile-section-head">
                    <p class="user-panel-kicker">Profil dan info akun</p>
                    <h3>Edit profil</h3>
                    <p class="profile-muted">Edit bio akun, tanggal lahir, dan asal daerah kamu di sini.</p>
                  </div>

                  <form action="/profile/details" method="post">
                    <div class="profile-form-grid">
                      <label class="profile-field full">
                        <span>Bio singkat</span>
                        <textarea
                          name="bio"
                          placeholder="Ceritakan gaya masak kamu dalam satu atau dua kalimat."
                        ><%= user.bio || '' %></textarea>
                      </label>

                      <label class="profile-field">
                        <span>Tanggal lahir</span>
                        <input
                          type="date"
                          name="birth_date"
                          value="<%= birthDateValue %>"
                        />
                      </label>

                      <label class="profile-field">
                        <span>Asal daerah</span>
                        <input
                          type="text"
                          name="region_origin"
                          value="<%= regionOrigin %>"
                          placeholder="Contoh: Bandung, Jawa Barat"
                        />
                      </label>
                    </div>

                    <div class="profile-section-actions">
                      <button type="submit" class="profile-primary-button">Simpan profil</button>
                    </div>
                  </form>
                </article>
              </div>

              <div class="profile-settings-column">
                <article class="profile-settings-section">
                  <div class="profile-section-head">
                    <p class="user-panel-kicker">Preferensi makanan</p>
                    <h3>Alergi dan makanan yang dihindari</h3>
                    <p class="profile-muted">Preferensi ini akan dipakai untuk menyaring resep dan rekomendasi.</p>
                  </div>

                  <form action="/profile/preferences" method="post">
                    <div class="profile-preference-grid">
                      <% allergyOptions.forEach((option) => { %>
                        <label class="profile-preference-chip">
                          <input
                            type="checkbox"
                            name="preferences"
                            value="<%= option.key %>"
                            <%= preferences.includes(option.key) ? 'checked' : '' %>
                          />
                          <span><%= option.label %></span>
                        </label>
                      <% }) %>
                    </div>

                    <div class="profile-section-actions">
                      <button type="submit" class="profile-primary-button">Simpan preferensi</button>
                    </div>
                  </form>
                </article>
              </div>

              <article class="profile-settings-section profile-settings-section-wide">
                <div class="profile-section-head">
                  <p class="user-panel-kicker">Keamanan</p>
                  <h3>Ganti password</h3>
                  <p class="profile-muted">Masukkan password lama lalu tentukan password baru yang kuat.</p>
                </div>

                <form action="/profile/password" method="post">
                  <div class="profile-password-grid">
                    <label class="profile-field">
                      <span>Password lama</span>
                      <div class="password-field">
                        <input type="password" id="currentPassword" name="current_password" placeholder="Password saat ini" required />
                        <button type="button" class="password-toggle" data-password-toggle data-target="currentPassword" aria-label="Tampilkan password lama">
                          <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                            <path class="eye-slash" d="M4 4l16 16"></path>
                          </svg>
                        </button>
                      </div>
                    </label>

                    <label class="profile-field">
                      <span>Password baru</span>
                      <div class="password-field">
                        <input type="password" id="newPassword" name="new_password" placeholder="Password baru" required />
                        <button type="button" class="password-toggle" data-password-toggle data-target="newPassword" aria-label="Tampilkan password baru">
                          <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                            <path class="eye-slash" d="M4 4l16 16"></path>
                          </svg>
                        </button>
                      </div>
                    </label>

                    <label class="profile-field">
                      <span>Konfirmasi password</span>
                      <div class="password-field">
                        <input type="password" id="confirmPassword" name="confirm_password" placeholder="Ulangi password baru" required />
                        <button type="button" class="password-toggle" data-password-toggle data-target="confirmPassword" aria-label="Tampilkan konfirmasi password">
                          <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                            <circle cx="12" cy="12" r="3"></circle>
                            <path class="eye-slash" d="M4 4l16 16"></path>
                          </svg>
                        </button>
                      </div>
                    </label>
                  </div>

                  <div class="profile-section-actions">
                    <button type="submit" class="profile-primary-button">Ubah password</button>
                  </div>
                </form>
              </article>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    (() => {
      const settingsOverlay = document.getElementById('profileSettingsOverlay');
      const openSettingsButton = document.getElementById('openProfileSettings');
      const closeSettingsButton = document.getElementById('closeProfileSettings');
      const settingsModal = settingsOverlay ? settingsOverlay.querySelector('.profile-settings-modal') : null;
      const avatarButton = document.getElementById('profileAvatarButton');
      const avatarInput = document.getElementById('profileAvatarInput');
      const avatarForm = avatarInput?.closest('form');

      const openSettings = () => {
        if (!settingsOverlay) return;
        settingsOverlay.hidden = false;
        document.body.classList.add('profile-settings-open');
        const firstField = settingsOverlay.querySelector('textarea, input, select, button');
        firstField?.focus?.();
      };

      const closeSettings = () => {
        if (!settingsOverlay) return;
        settingsOverlay.hidden = true;
        document.body.classList.remove('profile-settings-open');
      };

      openSettingsButton?.addEventListener('click', openSettings);
      closeSettingsButton?.addEventListener('click', closeSettings);

      settingsOverlay?.addEventListener('click', (event) => {
        if (event.target === settingsOverlay) {
          closeSettings();
        }
      });

      settingsModal?.addEventListener('click', (event) => {
        event.stopPropagation();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !settingsOverlay?.hidden) {
          closeSettings();
        }
      });

      avatarButton?.addEventListener('click', () => {
        avatarInput?.click();
      });

      avatarInput?.addEventListener('change', () => {
        if (avatarInput.files && avatarInput.files.length > 0) {
          avatarForm?.submit();
        }
      });

      settingsOverlay?.querySelectorAll('input[type="date"]').forEach((input) => {
        const openDatePicker = () => {
          if (typeof input.showPicker === 'function') {
            try {
              input.showPicker();
            } catch (error) {
              input.focus();
            }
            return;
          }

          input.focus();
        };

        input.addEventListener('click', openDatePicker);
        input.addEventListener('touchend', openDatePicker, { passive: true });
      });

      document.querySelectorAll('[data-profile-flash]').forEach((flash) => {
        window.setTimeout(() => {
          flash.classList.add('is-hiding');
          window.setTimeout(() => {
            flash.remove();
          }, 240);
        }, 2000);
      });

      document.querySelectorAll('[data-password-toggle]').forEach((button) => {
        const target = document.getElementById(button.dataset.target || '');
        if (!target) {
          return;
        }

        button.addEventListener('click', () => {
          const showPassword = target.type === 'password';
          target.type = showPassword ? 'text' : 'password';
          button.classList.toggle('is-visible', showPassword);
          button.setAttribute('aria-label', showPassword ? 'Sembunyikan password' : 'Tampilkan password');
        });
      });
    })();
  </script>
</body>
</html>
