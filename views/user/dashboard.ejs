<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="user-dashboard">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'dashboard', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar">
          <div class="user-search">
            <i class="fa-solid fa-magnifying-glass user-search-icon" aria-hidden="true"></i>
            <input type="text" placeholder="<%= dashboardData.searchPlaceholder %>" />
            <span>Search</span>
          </div>

          <div class="user-topbar-actions">
            <a class="user-icon-button" href="/chat-ai" aria-label="Buka AI Chat">
              <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
            </a>
          </div>
        </header>

        <div class="user-dashboard-content user-dashboard-content-modern">
          <section class="user-dashboard-left">
            <article class="user-panel user-panel-banner">
              <div class="user-banner-copy">
                <p class="user-panel-kicker">Dashboard User</p>
                <h1><%= dashboardData.greeting %>, <%= dashboardData.firstName %></h1>
                <p class="user-banner-description">
                  Temukan resep favorit, menu hemat, comfort food, sampai ide masak cepat
                  tanpa harus scroll terlalu jauh.
                </p>

                <div class="user-mood-row">
                  <% dashboardData.moods.forEach((mood) => { %>
                    <span><%= mood %></span>
                  <% }) %>
                </div>
              </div>

              <div class="user-banner-card">
                <p class="user-banner-label">Daily challenge / menu hari ini</p>
                <h2>Hari ini coba masak <%= dashboardData.dailyChallenge.title %></h2>
                <div class="user-recipe-tags">
                  <span><i class="fa-regular fa-clock"></i> <%= dashboardData.dailyChallenge.cookingTime %> menit</span>
                  <span><i class="fa-solid fa-fire"></i> <%= dashboardData.dailyChallenge.calories %> kkal</span>
                  <span><i class="fa-solid fa-signal"></i> <%= dashboardData.dailyChallenge.difficulty %></span>
                </div>
                <a class="auth-button" href="/recipe-detail?recipeId=<%= encodeURIComponent(dashboardData.dailyChallenge.id) %>">Lihat resep</a>
              </div>
            </article>

            <article class="user-panel user-panel-hero">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Kategori resep</p>
                  <h2>Pilih sesuai mood dan kebutuhan</h2>
                </div>
              </div>

              <div class="user-category-row user-category-grid-modern">
                <% dashboardData.categories.forEach((category) => { %>
                  <a class="user-category-chip" href="/recipes?feed=<%= encodeURIComponent(category.feedKey || 'random') %>">
                    <img src="<%= category.image %>" alt="<%= category.label %>" />
                    <span><%= category.label %></span>
                  </a>
                <% }) %>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Resep trending / populer</p>
                  <h2>Paling sering dilihat atau disukai</h2>
                </div>
                <a class="user-panel-link" href="/recipes">Lihat semua</a>
              </div>

              <div class="user-recipe-list user-recipe-list-compact">
                <% dashboardData.trendingRecipes.forEach((recipe) => { %>
                  <a class="user-recipe-card user-recipe-card-modern user-recipe-card-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                    <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                    <div class="user-recipe-copy">
                      <h3><%= recipe.title %></h3>
                      <p><%= recipe.description %></p>
                      <div class="user-recipe-tags">
                        <span><i class="fa-regular fa-eye"></i> <%= recipe.viewsCount %></span>
                        <span><i class="fa-regular fa-heart"></i> <%= recipe.likesCount %></span>
                        <span><i class="fa-regular fa-clock"></i> <%= recipe.cookingTime %> menit</span>
                        <span><i class="fa-solid fa-fire"></i> <%= recipe.calories %> kkal</span>
                        <span><i class="fa-solid fa-signal"></i> <%= recipe.difficulty %></span>
                      </div>
                    </div>
                  </a>
                <% }) %>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Rekomendasi untuk user</p>
                  <h2>Berdasarkan resep yang pernah dilihat atau disimpan</h2>
                </div>
              </div>

              <div class="user-card-grid">
                <% dashboardData.recommendedRecipes.forEach((recipe) => { %>
                  <a class="user-mini-recipe-card user-mini-recipe-card-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                    <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                    <div class="user-mini-recipe-copy">
                      <h3><%= recipe.title %></h3>
                      <p><%= recipe.category %></p>
                      <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                    </div>
                  </a>
                <% }) %>
              </div>
            </article>

            <div class="user-section-grid">
              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Favorite recipes</p>
                    <h2>Resep yang disimpan user</h2>
                  </div>
                </div>

                <% if (dashboardData.favoriteRecipes.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.favoriteRecipes.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.calories %> kkal - Perkiraan Rp<%= Number(recipe.estimatedPrice).toLocaleString('id-ID') %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-heart"></i>
                    <p>Belum ada resep favorit. Simpan resep yang kamu suka supaya muncul di sini.</p>
                  </div>
                <% } %>
              </article>

              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Recently viewed</p>
                    <h2>Resep terakhir yang dibuka</h2>
                  </div>
                </div>

                <% if (dashboardData.recentlyViewed.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.recentlyViewed.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-clock"></i>
                    <p>Belum ada riwayat resep. Setelah user memasak atau membuka resep, list ini akan terisi.</p>
                  </div>
                <% } %>
              </article>
            </div>
          </section>

          <aside class="user-dashboard-right">
            <article class="user-panel user-ai-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Tips memasak</p>
                  <h2>Biar dashboard tidak kosong</h2>
                </div>
              </div>

              <p class="user-ai-copy"><%= dashboardData.tip %></p>

              <div class="user-ai-prompts">
                <div class="user-prompt-card">
                  <strong>Kalori makanan</strong>
                  <span>Cek resep yang lebih ringan langsung dari badge kalori di setiap kartu resep.</span>
                </div>
                <div class="user-prompt-card">
                  <strong>Waktu & kesulitan</strong>
                  <span>Gunakan info waktu memasak dan difficulty buat milih menu yang paling realistis hari ini.</span>
                </div>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Mood masakan</p>
                  <h2>Butuh ide cepat?</h2>
                </div>
              </div>

              <div class="user-stat-list">
                <div class="user-stat-card">
                  <i class="fa-solid fa-pepper-hot" aria-hidden="true"></i>
                  <strong>Lagi pengen pedes?</strong>
                  <span>Coba buka menu Indonesia/Nusantara atau sambal-based dish.</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-solid fa-cloud" aria-hidden="true"></i>
                  <strong>Comfort food</strong>
                  <span>Pilih yang creamy, manis, atau berkuah hangat.</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-solid fa-wallet" aria-hidden="true"></i>
                  <strong>Budget food</strong>
                  <span>Fokus ke menu murah dengan bahan sederhana dan cepat.</span>
                </div>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Upload resep</p>
                  <h2>Kalau app kamu ada fitur community</h2>
                </div>
              </div>

              <p class="user-ai-copy">
                Bagikan resep andalan kamu, upload foto masakan, lalu biarkan user lain kasih like
                atau simpan ke favorit mereka.
              </p>

              <div class="user-ai-actions">
                <a class="auth-button" href="/recipes">Lihat resep</a>
                <a class="auth-button auth-button-secondary" href="/chat-ai">Minta ide AI</a>
              </div>
            </article>

            <article class="user-panel user-event-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Status akun</p>
                  <h2>Profile ringkas user</h2>
                </div>
              </div>

              <div class="user-stat-list">
                <div class="user-stat-card">
                  <i class="fa-regular fa-id-badge" aria-hidden="true"></i>
                  <strong><%= user.username %></strong>
                  <span>Nama akun aktif</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-regular fa-envelope" aria-hidden="true"></i>
                  <strong><%= user.email %></strong>
                  <span>Email terdaftar</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-solid fa-user-shield" aria-hidden="true"></i>
                  <strong><%= user.role %></strong>
                  <span>Tipe akses saat ini</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-solid fa-shield-heart" aria-hidden="true"></i>
                  <strong><%= dashboardData.preferences && dashboardData.preferences.length ? dashboardData.preferences.map((item) => {
                    const labels = {
                      nuts: 'Kacang',
                      seafood: 'Seafood',
                      milk: 'Susu',
                      egg: 'Telur',
                      gluten: 'Gluten',
                      spicy: 'Pedas',
                      shrimp: 'Udang'
                    };
                    return labels[item] || item;
                  }).join(', ') : 'Belum ada' %></strong>
                  <span>Food preference aktif</span>
                </div>
              </div>

              <div class="user-ai-actions">
                <a class="auth-button auth-button-secondary" href="/profile">Atur preference</a>
              </div>
            </article>
          </aside>
        </div>
      </section>
    </div>
  </main>
</body>
</html>
