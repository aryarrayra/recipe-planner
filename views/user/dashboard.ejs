<% const cookingTips = Array.isArray(dashboardData.dailyTips) && dashboardData.dailyTips.length ? dashboardData.dailyTips : [dashboardData.tip].filter(Boolean); %>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <%- include('../partials/favicon') %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="user-dashboard">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'dashboard', user }) %>

      <section class="user-dashboard-main">
        <div class="user-dashboard-content user-dashboard-content-modern dashboard-home-content">
          <section class="user-dashboard-left">
            <article class="user-panel user-panel-banner">
              <div class="user-banner-copy">
                <p class="user-panel-kicker">Beranda</p>
                <h1><%= dashboardData.greeting %>, <%= dashboardData.firstName %></h1>
                <p class="user-banner-description">
                  Temukan resep favorit, menu hemat, makanan rumahan favorit, sampai ide masak cepat
                  tanpa harus scroll terlalu jauh.
                </p>
              </div>

              <div class="user-banner-card">
                <p class="user-banner-label">Tantangan harian / menu hari ini</p>
                <h2>Hari ini coba masak <%= dashboardData.dailyChallenge.title %></h2>
                <div class="user-recipe-tags">
                  <span><i class="fa-regular fa-clock"></i> <%= dashboardData.dailyChallenge.cookingTime %> menit</span>
                  <span><i class="fa-solid fa-fire"></i> <%= dashboardData.dailyChallenge.calories %> kkal</span>
                  <span><i class="fa-solid fa-signal"></i> <%= dashboardData.dailyChallenge.difficulty %></span>
                </div>
                <a class="auth-button" href="/recipe-detail?recipeId=<%= encodeURIComponent(dashboardData.dailyChallenge.id) %>">Lihat resep</a>
              </div>
            </article>

            <article class="user-panel user-panel-hero">
              <div class="dashboard-category-top">
                <div class="dashboard-category-main">
                  <div class="user-panel-head">
                    <div>
                      <p class="user-panel-kicker">Kategori resep</p>
                      <h2>Pilih sesuai mood dan kebutuhan</h2>
                    </div>
                  </div>

                  <div class="user-category-carousel" data-category-carousel>
                    <div class="user-category-carousel-viewport" data-category-carousel-viewport>
                      <div class="user-category-carousel-track">
                        <% dashboardData.categories.forEach((category) => { %>
                          <a class="user-category-chip" href="/recipe-menu?category=<%= encodeURIComponent(category.feedKey || 'random') %>">
                            <img src="<%= category.image %>" alt="<%= category.label %>" />
                            <span><%= category.label %></span>
                          </a>
                        <% }) %>
                      </div>
                    </div>
                  </div>
                </div>

                <aside class="dashboard-inline-tip-card" data-tip-slider>
                  <div class="dashboard-inline-tip-card-head">
                    <p class="dashboard-inline-tip-card-label">Tips memasak</p>
                    <div class="dashboard-inline-tip-card-nav">
                      <button class="dashboard-inline-tip-card-button" type="button" data-tip-prev aria-label="Tips sebelumnya">
                        <i class="fa-solid fa-chevron-left"></i>
                      </button>
                      <button class="dashboard-inline-tip-card-button" type="button" data-tip-next aria-label="Tips berikutnya">
                        <i class="fa-solid fa-chevron-right"></i>
                      </button>
                    </div>
                  </div>

                  <div class="dashboard-inline-tip-slider" data-tip-viewport>
                    <div class="dashboard-inline-tip-track">
                      <% cookingTips.forEach((tip, index) => { %>
                        <article class="dashboard-inline-tip-slide" data-tip-slide>
                          <p class="dashboard-inline-tip-card-index">Tips <%= index + 1 %></p>
                          <p class="user-dashboard-inline-tip user-dashboard-inline-tip-top"><%= tip %></p>
                        </article>
                      <% }) %>
                    </div>
                  </div>

                  <div class="dashboard-inline-tip-dots" aria-hidden="true">
                    <% cookingTips.forEach((_, index) => { %>
                      <span class="dashboard-inline-tip-dot <%= index === 0 ? 'is-active' : '' %>" data-tip-dot="<%= index %>"></span>
                    <% }) %>
                  </div>
                </aside>
              </div>

            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Resep trending / populer</p>
                  <h2>Paling sering dilihat atau disukai</h2>
                </div>
                <a class="user-panel-link" href="/recipe-menu">Lihat semua</a>
              </div>

              <% if (dashboardData.trendingRecipes.length) { %>
                <div class="user-recipe-list user-recipe-list-compact">
                  <% dashboardData.trendingRecipes.forEach((recipe) => { %>
                    <a class="user-recipe-card user-recipe-card-modern user-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                      <% if (recipe.hasImage) { %>
                        <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                      <% } %>
                      <div class="user-recipe-copy">
                        <h3><%= recipe.title %></h3>
                        <p><%= recipe.description %></p>
                        <div class="user-recipe-tags">
                          <% if (recipe.showViewsCount) { %>
                            <span><i class="fa-regular fa-eye"></i> <%= recipe.viewsCount %></span>
                          <% } %>
                          <% if (recipe.showLikesCount) { %>
                            <span><i class="fa-regular fa-heart"></i> <%= recipe.likesCount %></span>
                          <% } %>
                          <span><i class="fa-regular fa-clock"></i> <%= recipe.cookingTime %> menit</span>
                          <% if (recipe.showCalories) { %>
                            <span><i class="fa-solid fa-fire"></i> <%= recipe.calories %> kkal</span>
                          <% } %>
                          <span><i class="fa-solid fa-signal"></i> <%= recipe.difficulty %></span>
                        </div>
                      </div>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="user-empty-state">
                  <i class="fa-regular fa-compass"></i>
                  <p>Belum ada resep populer global yang bisa ditampilkan sekarang.</p>
                </div>
              <% } %>
            </article>

            <div class="user-section-grid">
              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Resep favorit</p>
                    <h2>Resep yang disimpan user</h2>
                  </div>
                </div>

                <% if (dashboardData.favoriteRecipes.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.favoriteRecipes.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <% if (recipe.hasImage) { %>
                          <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <% } %>
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-heart"></i>
                    <p>Belum ada resep favorit. Simpan resep yang kamu suka supaya muncul di sini.</p>
                  </div>
                <% } %>
              </article>

              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Baru dilihat</p>
                    <h2>Resep terakhir yang dibuka</h2>
                  </div>
                </div>

                <% if (dashboardData.recentlyViewed.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.recentlyViewed.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <% if (recipe.hasImage) { %>
                          <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <% } %>
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-clock"></i>
                    <p>Belum ada riwayat resep. Setelah user memasak atau membuka resep, list ini akan terisi.</p>
                  </div>
                <% } %>
              </article>
            </div>
          </section>

        </div>
      </section>
    </div>
  </main>
  <script>
    (function () {
      const carousel = document.querySelector('[data-category-carousel]');
      if (!carousel) {
        return;
      }

      const viewport = carousel.querySelector('[data-category-carousel-viewport]');
      if (!viewport) {
        return;
      }

      function updateState() {
        const maxScrollLeft = Math.max(0, viewport.scrollWidth - viewport.clientWidth - 1);
        carousel.classList.toggle('is-scrollable', maxScrollLeft > 0);
      }

      viewport.addEventListener('scroll', updateState, { passive: true });
      window.addEventListener('resize', updateState);
      window.addEventListener('load', updateState, { once: true });

      if (window.ResizeObserver) {
        const observer = new ResizeObserver(updateState);
        observer.observe(viewport);
      }

      requestAnimationFrame(updateState);
    })();

    (function () {
      const slider = document.querySelector('[data-tip-slider]');
      if (!slider) {
        return;
      }

      const viewport = slider.querySelector('[data-tip-viewport]');
      const track = slider.querySelector('.dashboard-inline-tip-track');
      const slides = Array.from(slider.querySelectorAll('[data-tip-slide]'));
      const dots = Array.from(slider.querySelectorAll('[data-tip-dot]'));
      const prevButton = slider.querySelector('[data-tip-prev]');
      const nextButton = slider.querySelector('[data-tip-next]');

      if (!viewport || !track || !slides.length) {
        return;
      }

      const storageKey = 'dashboardCookingTipIndex';
      let activeIndex = 0;
      let dragStartX = 0;
      let dragCurrentX = 0;
      let isDragging = false;

      function renderPosition(index, animate) {
        track.style.transition = animate ? 'transform 280ms ease' : 'none';
        track.style.transform = 'translateX(' + (index * -100) + '%)';
      }

      function syncDots(index) {
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle('is-active', dotIndex === index);
        });
      }

      function goTo(index) {
        const clampedIndex = Math.max(0, Math.min(index, slides.length - 1));
        const target = slides[clampedIndex];
        if (!target) {
          return;
        }

        activeIndex = clampedIndex;
        renderPosition(activeIndex, true);
        syncDots(activeIndex);
        try {
          localStorage.setItem(storageKey, String(activeIndex));
        } catch (error) {
          /* noop */
        }
      }

      function onPointerDown(clientX) {
        dragStartX = clientX;
        dragCurrentX = clientX;
        isDragging = true;
        track.style.transition = 'none';
      }

      function onPointerMove(clientX) {
        if (!isDragging) {
          return;
        }

        dragCurrentX = clientX;
        const deltaX = dragCurrentX - dragStartX;
        const viewportWidth = viewport.offsetWidth || 1;
        const baseOffset = activeIndex * -100;
        const dragOffset = (deltaX / viewportWidth) * 100;
        track.style.transform = 'translateX(' + (baseOffset + dragOffset) + '%)';
      }

      function onPointerUp() {
        if (!isDragging) {
          return;
        }

        const deltaX = dragCurrentX - dragStartX;
        const threshold = Math.max(48, viewport.offsetWidth * 0.16);
        isDragging = false;

        if (deltaX <= -threshold) {
          goTo(activeIndex + 1);
          return;
        }

        if (deltaX >= threshold) {
          goTo(activeIndex - 1);
          return;
        }

        renderPosition(activeIndex, true);
      }

      prevButton?.addEventListener('click', function () {
        goTo(activeIndex - 1);
      });

      nextButton?.addEventListener('click', function () {
        goTo(activeIndex + 1);
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', function () {
          goTo(index);
        });
      });

      window.addEventListener('resize', function () {
        renderPosition(activeIndex, false);
      });

      viewport.addEventListener('mousedown', function (event) {
        onPointerDown(event.clientX);
      });

      window.addEventListener('mousemove', function (event) {
        onPointerMove(event.clientX);
      });

      window.addEventListener('mouseup', onPointerUp);

      viewport.addEventListener('touchstart', function (event) {
        if (!event.touches.length) {
          return;
        }

        onPointerDown(event.touches[0].clientX);
      }, { passive: true });

      viewport.addEventListener('touchmove', function (event) {
        if (!event.touches.length) {
          return;
        }

        onPointerMove(event.touches[0].clientX);
      }, { passive: true });

      viewport.addEventListener('touchend', onPointerUp, { passive: true });
      viewport.addEventListener('mouseleave', onPointerUp);

      let initialIndex = 0;
      try {
        const storedIndex = Number(localStorage.getItem(storageKey));
        initialIndex = Number.isFinite(storedIndex) ? (storedIndex + 1) % slides.length : 0;
      } catch (error) {
        initialIndex = 0;
      }

      requestAnimationFrame(function () {
        goTo(initialIndex);
      });
    })();
  </script>
</body>
</html>
