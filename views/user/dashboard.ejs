<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="user-dashboard">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'dashboard', user }) %>

      <section class="user-dashboard-main">
        <div class="user-dashboard-content user-dashboard-content-modern">
          <section class="user-dashboard-left">
            <article class="user-panel user-panel-banner">
              <div class="user-banner-copy">
                <p class="user-panel-kicker">Dashboard</p>
                <h1><%= dashboardData.greeting %>, <%= dashboardData.firstName %></h1>
                <p class="user-banner-description">
                  Temukan resep favorit, menu hemat, comfort food, sampai ide masak cepat
                  tanpa harus scroll terlalu jauh.
                </p>

                <div class="user-banner-actions">
                  <a class="auth-button" href="/recipe-menu">Mulai pilih resep</a>
                  <a class="auth-button auth-button-secondary" href="/shopping-list">Siapkan belanja</a>
                  <a class="auth-button auth-button-secondary" href="/community">Share ke community</a>
                </div>

                <div class="user-mood-row">
                  <% dashboardData.moods.forEach((mood) => { %>
                    <span><%= mood %></span>
                  <% }) %>
                </div>
              </div>

              <div class="user-banner-card">
                <p class="user-banner-label">Daily challenge / menu hari ini</p>
                <h2>Hari ini coba masak <%= dashboardData.dailyChallenge.title %></h2>
                <div class="user-recipe-tags">
                  <span><i class="fa-regular fa-clock"></i> <%= dashboardData.dailyChallenge.cookingTime %> menit</span>
                  <span><i class="fa-solid fa-fire"></i> <%= dashboardData.dailyChallenge.calories %> kkal</span>
                  <span><i class="fa-solid fa-signal"></i> <%= dashboardData.dailyChallenge.difficulty %></span>
                </div>
                <a class="auth-button" href="/recipe-detail?recipeId=<%= encodeURIComponent(dashboardData.dailyChallenge.id) %>">Lihat resep</a>
              </div>
            </article>

            <article class="user-panel user-panel-hero">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Kategori resep</p>
                  <h2>Pilih sesuai mood dan kebutuhan</h2>
                </div>
              </div>

              <p class="user-dashboard-inline-tip">
                Tips memasak: cek kalori makanan, waktu memasak, dan tingkat kesulitan
                sebelum pilih resep supaya lebih gampang menyesuaikan menu dengan waktu
                dan kebutuhan hari ini.
              </p>

              <div class="user-flow-strip" aria-label="Alur utama aplikasi">
                <span class="user-flow-step is-active">1. Pilih resep</span>
                <span class="user-flow-step">2. Cek detail</span>
                <span class="user-flow-step">3. Mulai masak</span>
                <span class="user-flow-step">4. Sajikan / share</span>
              </div>

              <div class="user-category-carousel" data-category-carousel>
                <div class="user-category-carousel-viewport" data-category-carousel-viewport>
                  <div class="user-category-carousel-track">
                    <% dashboardData.categories.forEach((category) => { %>
                      <a class="user-category-chip" href="/recipe-menu?category=<%= encodeURIComponent(category.feedKey || 'random') %>">
                        <img src="<%= category.image %>" alt="<%= category.label %>" />
                        <span><%= category.label %></span>
                      </a>
                    <% }) %>
                  </div>
                </div>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Resep trending / populer</p>
                  <h2>Paling sering dilihat atau disukai</h2>
                </div>
                <a class="user-panel-link" href="/recipe-menu">Lihat semua</a>
              </div>

              <% if (dashboardData.trendingRecipes.length) { %>
                <div class="user-recipe-list user-recipe-list-compact">
                  <% dashboardData.trendingRecipes.forEach((recipe) => { %>
                    <a class="user-recipe-card user-recipe-card-modern user-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                      <% if (recipe.hasImage) { %>
                        <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                      <% } %>
                      <div class="user-recipe-copy">
                        <h3><%= recipe.title %></h3>
                        <p><%= recipe.description %></p>
                        <div class="user-recipe-tags">
                          <% if (recipe.showViewsCount) { %>
                            <span><i class="fa-regular fa-eye"></i> <%= recipe.viewsCount %></span>
                          <% } %>
                          <% if (recipe.showLikesCount) { %>
                            <span><i class="fa-regular fa-heart"></i> <%= recipe.likesCount %></span>
                          <% } %>
                          <span><i class="fa-regular fa-clock"></i> <%= recipe.cookingTime %> menit</span>
                          <% if (recipe.showCalories) { %>
                            <span><i class="fa-solid fa-fire"></i> <%= recipe.calories %> kkal</span>
                          <% } %>
                          <span><i class="fa-solid fa-signal"></i> <%= recipe.difficulty %></span>
                        </div>
                      </div>
                    </a>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="user-empty-state">
                  <i class="fa-regular fa-compass"></i>
                  <p>Belum ada resep populer global yang bisa ditampilkan sekarang.</p>
                </div>
              <% } %>
            </article>

            <div class="user-section-grid">
              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Favorite recipes</p>
                    <h2>Resep yang disimpan user</h2>
                  </div>
                </div>

                <% if (dashboardData.favoriteRecipes.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.favoriteRecipes.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <% if (recipe.hasImage) { %>
                          <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <% } %>
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-heart"></i>
                    <p>Belum ada resep favorit. Simpan resep yang kamu suka supaya muncul di sini.</p>
                  </div>
                <% } %>
              </article>

              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Recently viewed</p>
                    <h2>Resep terakhir yang dibuka</h2>
                  </div>
                </div>

                <% if (dashboardData.recentlyViewed.length) { %>
                  <div class="user-card-grid">
                    <% dashboardData.recentlyViewed.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <% if (recipe.hasImage) { %>
                          <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <% } %>
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit - <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-clock"></i>
                    <p>Belum ada riwayat resep. Setelah user memasak atau membuka resep, list ini akan terisi.</p>
                  </div>
                <% } %>
              </article>
            </div>
          </section>

          <aside class="user-dashboard-right">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Community</p>
                  <h2>Bagikan resep buatanmu</h2>
                </div>
              </div>

              <p class="user-ai-copy">
                Kirim resep original atau hasil recook kamu ke community. Resep akan menunggu approval
                sebelum tampil di feed publik.
              </p>

              <div class="user-ai-actions">
                <a class="auth-button" href="/community">Buka community</a>
                <a class="auth-button auth-button-secondary" href="/chat-ai">Minta ide AI</a>
              </div>
            </article>

          </aside>
        </div>
      </section>
    </div>
  </main>
  <script>
    (function () {
      const carousel = document.querySelector('[data-category-carousel]');
      if (!carousel) {
        return;
      }

      const viewport = carousel.querySelector('[data-category-carousel-viewport]');
      if (!viewport) {
        return;
      }

      function updateState() {
        const maxScrollLeft = Math.max(0, viewport.scrollWidth - viewport.clientWidth - 1);
        carousel.classList.toggle('is-scrollable', maxScrollLeft > 0);
      }

      viewport.addEventListener('scroll', updateState, { passive: true });
      window.addEventListener('resize', updateState);
      window.addEventListener('load', updateState, { once: true });

      if (window.ResizeObserver) {
        const observer = new ResizeObserver(updateState);
        observer.observe(viewport);
      }

      requestAnimationFrame(updateState);
    })();
  </script>
</body>
</html>
