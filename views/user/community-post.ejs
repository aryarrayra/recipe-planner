<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const recipeIngredients = Array.isArray(post.ingredients) ? post.ingredients : []; %>
  <% const recipeSteps = Array.isArray(post.steps) ? post.steps : []; %>
  <% const recipeTags = Array.isArray(post.tags) ? post.tags : []; %>
  <% const postIsDeleted = Boolean(post.isDeleted || post.is_deleted); %>
  <% const formatRelativeTime = (value) => {
    if (!value) return 'baru saja';
    const created = new Date(value);
    if (Number.isNaN(created.getTime())) return 'baru saja';
    const diff = Date.now() - created.getTime();
    const minutes = Math.max(0, Math.floor(diff / 60000));
    if (minutes < 1) return 'baru saja';
    if (minutes < 60) return `${minutes}m`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}d`;
    return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
  }; %>

  <main class="user-dashboard community-page community-post-page">
    <div class="user-dashboard-shell community-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'community', user }) %>

      <section class="user-dashboard-main community-main">
        <header class="community-post-topbar">
          <div class="community-post-topbar-copy">
            <h1><%= post.title %></h1>
            <p class="community-post-topbar-subcopy">Resep komunitas, bahan, lalu langkah masak per step.</p>
          </div>
          <a class="community-back-link community-post-back-button" href="/community">
            <i class="fa-solid fa-arrow-left"></i>
            <span>Kembali</span>
          </a>
        </header>

        <article class="community-post-layout <%= postIsDeleted ? 'is-deleted' : '' %>">
          <section class="community-post-main">
            <article class="community-book-cover-panel <%= postIsDeleted ? 'is-deleted' : '' %>">
              <div class="community-book-cover">
                <img src="<%= post.imageUrl || '/images/1.png' %>" alt="<%= post.title %>" />
              </div>

              <div class="community-book-cover-copy">
                <div class="community-book-author">
                  <img
                    src="<%= post.creatorAvatarUrl || `https://ui-avatars.com/api/?name=${encodeURIComponent(post.creatorName || 'Pengguna komunitas')}&background=0f1419&color=ffffff&bold=true` %>"
                    alt="<%= post.creatorName %>"
                  />
                  <div>
                    <strong><%= post.creatorName %></strong>
                    <span><%= formatRelativeTime(post.createdAt) %></span>
                  </div>
                </div>

                <% if (postIsDeleted) { %>
                  <div class="community-post-status-pill is-deleted">
                    <i class="fa-solid fa-trash"></i>
                    <span>DIHAPUS</span>
                  </div>
                <% } %>

                <p class="community-book-kicker"><%= post.cuisine || post.originPlace || 'Komunitas' %> &bull; <%= post.category || 'resep' %></p>
                <h2 class="community-book-title"><%= post.title %></h2>
                <p class="community-book-description"><%= post.content || post.title %></p>

                <div class="community-book-chip-row">
                  <span><i class="fa-regular fa-clock"></i> <%= post.cookingTime || 0 %> menit</span>
                  <span><i class="fa-solid fa-users"></i> <%= post.servings || 1 %> porsi</span>
                  <span><i class="fa-solid fa-wallet"></i> Rp <%= formatPrice(post.estimatedPrice) %></span>
                  <span><i class="fa-solid fa-signal"></i> <%= post.difficulty || 'easy' %></span>
                  <span><i class="fa-solid fa-star"></i> <span id="detailLikeCount"><%= post.likesCount || 0 %></span> suka</span>
                  <span><i class="fa-regular fa-comment"></i> <%= post.commentsCount || comments.length || 0 %> komentar</span>
                </div>

                <div class="community-detail-actions">
                  <button type="button" class="community-tweet-action-button <%= post.likedByMe ? 'is-liked' : '' %>" id="detailLikeButton" <%= postIsDeleted || post.likedByMe ? 'disabled' : '' %>>
                    <span class="community-action-icon"><i class="fa-regular fa-heart"></i></span>
                    <span><%= post.likedByMe ? 'Sudah disukai' : 'Suka resep' %></span>
                  </button>
                  <a class="community-tweet-action-button <%= postIsDeleted ? 'is-disabled' : '' %>" href="#comments" <%= postIsDeleted ? 'aria-disabled="true" tabindex="-1"' : '' %>>
                    <span class="community-action-icon"><i class="fa-regular fa-comment"></i></span>
                    <span><%= post.commentsCount || comments.length || 0 %> komentar</span>
                  </a>
                  <a class="community-tweet-action-button <%= postIsDeleted ? 'is-disabled' : '' %>" href="#bahan" <%= postIsDeleted ? 'aria-disabled="true" tabindex="-1"' : '' %>>
                    <span class="community-action-icon"><i class="fa-solid fa-list-check"></i></span>
                    <span>Lihat bahan</span>
                  </a>
                  <button type="button" class="community-tweet-action-button community-tweet-action-button-icon" id="reportContentButton" aria-label="Laporkan konten" title="Laporkan konten" <%= postIsDeleted ? 'disabled' : '' %>>
                    <span class="community-action-icon"><i class="fa-regular fa-flag"></i></span>
                  </button>
                  <button type="button" class="community-tweet-action-button community-tweet-action-button-icon" id="reportUserButton" aria-label="Laporkan pengguna" title="Laporkan pengguna" <%= postIsDeleted ? 'disabled' : '' %>>
                    <span class="community-action-icon"><i class="fa-solid fa-user-slash"></i></span>
                  </button>
                  <% if (!postIsDeleted && String(post.creatorUserId || '') === String(user && user.id ? user.id : '')) { %>
                    <button type="button" class="community-tweet-action-button community-tweet-action-button-danger" id="deletePostButton" aria-label="Hapus postingan" title="Hapus postingan">
                      <span class="community-action-icon"><i class="fa-regular fa-trash-can"></i></span>
                      <span>Hapus</span>
                    </button>
                  <% } %>
                </div>
              </div>
            </article>

            <div class="community-book-columns">
              <article class="community-book-section" id="bahan">
                <div class="community-book-section-head">
                  <div>
                    <p class="community-detail-thread-kicker">Bahan-bahan</p>
                    <h3>Bahan</h3>
                  </div>
                </div>

                <% if (recipeIngredients.length) { %>
                  <ul class="community-book-ingredient-list">
                    <% recipeIngredients.forEach((ingredient) => { %>
                      <li>
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= ingredient.display || ingredient.label || ingredient.name %></span>
                      </li>
                    <% }) %>
                  </ul>
                <% } else { %>
                  <div class="community-detail-empty">
                    <p>Belum ada daftar bahan yang tersimpan untuk resep ini.</p>
                  </div>
                <% } %>
              </article>

              <article class="community-book-section">
                <div class="community-book-section-head">
                  <div>
                    <p class="community-detail-thread-kicker">Cara membuat</p>
                    <h3>Langkah memasak</h3>
                  </div>
                </div>

                <% if (recipeSteps.length) { %>
                  <ol class="community-book-step-list">
                    <% recipeSteps.forEach((step) => { %>
                      <li>
                        <strong>Langkah <%= step.step %></strong>
                        <p><%= step.instruction %></p>
                        <% if (step.sectionImageUrl) { %>
                          <div class="community-book-step-media">
                            <img src="<%= step.sectionImageUrl %>" alt="Foto langkah <%= step.step %>" />
                          </div>
                        <% } %>
                      </li>
                    <% }) %>
                  </ol>
                <% } else { %>
                  <div class="community-detail-empty">
                    <p>Belum ada langkah memasak yang tersimpan untuk resep ini.</p>
                  </div>
                <% } %>
              </article>
            </div>

            <section class="community-detail-comments <%= postIsDeleted ? 'is-deleted' : '' %>" id="comments">
              <div class="community-detail-comments-head">
                <div>
                  <p class="community-detail-thread-kicker">Balasan</p>
                  <h3>Komentar pembaca</h3>
                </div>
                <span id="communityDetailCommentState"><%= comments.length ? `${comments.length} balasan` : 'Belum ada komentar' %></span>
              </div>

              <div class="community-detail-comments-list" id="commentsList">
                <% if (comments.length) { %>
                  <% comments.forEach((comment) => { %>
                    <article class="community-thread-item">
                      <div class="community-thread-avatar">
                        <img
                          src="<%= comment.creatorAvatarUrl || `https://ui-avatars.com/api/?name=${encodeURIComponent(comment.creatorName || 'Pengguna komunitas')}&background=0f1419&color=ffffff&bold=true` %>"
                          alt="<%= comment.creatorName %>"
                        />
                      </div>
                      <div class="community-thread-body">
                        <div class="community-thread-head">
                          <strong><%= comment.creatorName %></strong>
                          <span>&bull; <%= formatRelativeTime(comment.createdAt) %></span>
                        </div>
                        <p><%= comment.content %></p>
                      </div>
                    </article>
                  <% }) %>
                <% } else { %>
                  <div class="community-detail-empty">
                    <p>Belum ada komentar untuk postingan ini.</p>
                  </div>
                <% } %>
              </div>

              <form class="community-detail-reply-form <%= postIsDeleted ? 'is-disabled' : '' %>" id="replyForm">
                <textarea id="replyInput" rows="3" placeholder="<%= postIsDeleted ? 'Postingan sudah dihapus' : 'Tulis komentar...' %>" required <%= postIsDeleted ? 'disabled' : '' %>></textarea>
                <div class="community-detail-reply-actions">
                  <span class="community-detail-reply-hint">Tulis komentar untuk membalas postingan ini.</span>
                  <button type="submit" class="auth-button" id="replySubmit" <%= postIsDeleted ? 'disabled' : '' %>>Kirim balasan</button>
                </div>
              </form>
            </section>
          </section>

          <aside class="community-book-sidebar">
            <article class="user-panel community-book-sidecard">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Ringkasan resep</p>
                  <h2>Detail cepat</h2>
                </div>
              </div>

              <div class="community-book-summary-list">
                <span><strong>Kategori</strong><%= post.category || 'community' %></span>
                <span><strong>Asal masakan</strong><%= post.cuisine || post.originPlace || 'Komunitas' %></span>
                <span><strong>Waktu</strong><%= post.cookingTime || 0 %> menit</span>
                <span><strong>Porsi</strong><%= post.servings || 1 %> porsi</span>
                <span><strong>Tingkat kesulitan</strong><%= post.difficulty || 'easy' %></span>
                <span><strong>Harga</strong>Rp <%= formatPrice(post.estimatedPrice) %></span>
              </div>
            </article>

            <article class="user-panel community-book-sidecard">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Tags</p>
                  <h2>Catatan resep</h2>
                </div>
              </div>

              <% if (recipeTags.length) { %>
                <div class="community-book-tag-list">
                  <% recipeTags.forEach((tag) => { %>
                    <span><%= tag %></span>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="community-detail-empty">
                  <p>Resep ini belum punya tag tambahan.</p>
                </div>
              <% } %>
            </article>
          </aside>
        </article>

        <div class="community-report-overlay" id="communityReportOverlay" hidden>
          <div class="community-report-modal" role="dialog" aria-modal="true" aria-labelledby="communityReportTitle">
            <div class="community-composer-head">
              <div>
                <p class="user-panel-kicker">Laporan</p>
                <h2 id="communityReportTitle">Laporkan konten atau pengguna</h2>
              </div>
              <button type="button" class="community-composer-close" id="closeCommunityReport" aria-label="Tutup">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>

            <form class="community-report-form" id="communityReportForm">
              <input type="hidden" name="postId" value="<%= post.id %>" />
              <input type="hidden" name="targetId" id="communityReportTargetId" />
              <input type="hidden" name="targetType" id="communityReportTargetType" value="post" />
              <input type="hidden" name="targetUserId" id="communityReportTargetUserId" value="<%= post.creatorUserId || '' %>" />
              <label class="community-form-field">
                <span>Alasan</span>
                <select name="reason" id="communityReportReason" required>
                  <option value="">Pilih alasan</option>
                  <option value="spam">Spam / promosi</option>
                  <option value="harassment">Hate / harassment</option>
                  <option value="misleading">Konten menyesatkan</option>
                  <option value="copyright">Pelanggaran hak cipta</option>
                  <option value="abuse">Konten tidak pantas</option>
                  <option value="other">Lainnya</option>
                </select>
              </label>
              <label class="community-form-field community-form-field-wide">
                <span>Detail tambahan</span>
                <textarea name="details" id="communityReportDetails" rows="4" placeholder="Jelaskan singkat kenapa kamu melaporkan ini"></textarea>
              </label>
              <div class="community-form-actions">
                <button type="submit" class="auth-button">Kirim laporan</button>
                <p>Laporan akan masuk ke panel admin untuk ditinjau.</p>
              </div>
            </form>
          </div>
        </div>

        <div class="community-toast" id="communityReportToast" hidden role="status" aria-live="polite"></div>
      </section>
    </div>
  </main>

  <script>
    (() => {
      const postId = <%- JSON.stringify(post.id) %>;
      const postCreatorUserId = <%- JSON.stringify(post.creatorUserId || '') %>;
      const postIsDeleted = <%- JSON.stringify(Boolean(postIsDeleted)) %>;
      const likeButton = document.getElementById('detailLikeButton');
      const likeCount = document.getElementById('detailLikeCount');
      const replyForm = document.getElementById('replyForm');
      const replyInput = document.getElementById('replyInput');
      const commentsList = document.getElementById('commentsList');
      const commentState = document.getElementById('communityDetailCommentState');
      const reportOverlay = document.getElementById('communityReportOverlay');
      const reportClose = document.getElementById('closeCommunityReport');
      const reportForm = document.getElementById('communityReportForm');
      const reportTargetId = document.getElementById('communityReportTargetId');
      const reportTargetType = document.getElementById('communityReportTargetType');
      const reportTargetUserId = document.getElementById('communityReportTargetUserId');
      const reportReason = document.getElementById('communityReportReason');
      const reportDetails = document.getElementById('communityReportDetails');
      const reportToast = document.getElementById('communityReportToast');
      const reportContentButton = document.getElementById('reportContentButton');
      const reportUserButton = document.getElementById('reportUserButton');
      const deletePostButton = document.getElementById('deletePostButton');

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function formatRelativeTime(value) {
        if (!value) return 'baru saja';
        const created = new Date(value);
        if (Number.isNaN(created.getTime())) return 'baru saja';
        const diff = Date.now() - created.getTime();
        const minutes = Math.max(0, Math.floor(diff / 60000));
        if (minutes < 1) return 'baru saja';
        if (minutes < 60) return `${minutes}m`;
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return `${hours}h`;
        const days = Math.floor(hours / 24);
        if (days < 7) return `${days}d`;
        return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
      }

      function renderComment(comment) {
        const commentTitle = String(comment.content || 'Komentar').slice(0, 48);
        return `
          <article class="community-thread-item" data-comment-id="${escapeHtml(comment.id || '')}" data-comment-user-id="${escapeHtml(comment.creatorUserId || '')}">
            <div class="community-thread-avatar">
              <img src="https://ui-avatars.com/api/?name=${encodeURIComponent(comment.creatorName || 'Pengguna komunitas')}&background=0f1419&color=ffffff&bold=true" alt="${escapeHtml(comment.creatorName || 'Pengguna komunitas')}" />
            </div>
            <div class="community-thread-body">
              <div class="community-thread-head">
                <strong>${escapeHtml(comment.creatorName || 'Pengguna komunitas')}</strong>
                <span>&bull; ${escapeHtml(formatRelativeTime(comment.createdAt))}</span>
              </div>
              <p>${escapeHtml(comment.content || '')}</p>
              <div class="community-detail-comment-actions">
                <button
                  type="button"
                  class="community-comment-report-button"
                  data-action="report-comment"
                  data-report-target-type="comment"
                  data-report-target-id="${escapeHtml(comment.id || '')}"
                  data-report-target-user-id="${escapeHtml(comment.creatorUserId || '')}"
                  data-report-title="${escapeHtml(commentTitle)}"
                  aria-label="Laporkan komentar"
                  title="Laporkan komentar"
                >
                  <i class="fa-regular fa-flag"></i>
                </button>
              </div>
            </div>
          </article>
        `;
      }

      function setReportVisible(visible) {
        if (!reportOverlay) return;
        reportOverlay.hidden = !visible;
        document.body.classList.toggle('community-report-open', visible);
      }

      let reportToastTimer = null;

      function showReportToast(message, variant = 'success') {
        if (!reportToast) return;
        reportToast.textContent = String(message || '');
        reportToast.dataset.variant = variant;
        reportToast.hidden = false;
        if (reportToastTimer) {
          window.clearTimeout(reportToastTimer);
        }
        reportToastTimer = window.setTimeout(() => {
          reportToast.hidden = true;
        }, 3200);
      }

      function openReportModal({ targetType = 'post', targetId = '', targetUserId = '', title = '' } = {}) {
        if (reportTargetType) {
          reportTargetType.value = ['post', 'user', 'comment'].includes(targetType) ? targetType : 'post';
        }
        if (reportTargetId) {
          reportTargetId.value = String(targetId || '');
        }
        if (reportTargetUserId) {
          reportTargetUserId.value = String(targetUserId || postCreatorUserId || '');
        }
        if (reportReason) {
          reportReason.value = '';
        }
        if (reportDetails) {
          reportDetails.value = '';
        }
        const titleNode = document.getElementById('communityReportTitle');
        if (titleNode) {
          titleNode.textContent = title || (targetType === 'user' ? 'Laporkan pengguna' : targetType === 'comment' ? 'Laporkan komentar' : 'Laporkan konten');
        }
        setReportVisible(true);
      }

      async function sendReport() {
        const formData = new FormData(reportForm);
        const payload = new URLSearchParams();
        formData.forEach((value, key) => {
          payload.set(key, String(value || ''));
        });
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/report`, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          },
          body: payload
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal mengirim laporan');
        }
        return data;
      }

      async function deletePost() {
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/delete`, {
          method: 'POST',
          headers: { Accept: 'application/json' }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal menghapus postingan');
        }
        return data;
      }

      likeButton?.addEventListener('click', async () => {
        if (!postId || postIsDeleted) return;
        try {
          likeButton.classList.remove('is-pop');
          void likeButton.offsetWidth;
          likeButton.classList.add('is-pop');
          const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/like`, {
            method: 'POST',
            headers: { Accept: 'application/json' }
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.success) {
            throw new Error(data.error || 'Gagal menyukai postingan');
          }

          likeCount.textContent = String(data.likesCount || 0);
          likeButton.classList.add('is-liked');
          likeButton.disabled = true;
          window.setTimeout(() => likeButton.classList.remove('is-pop'), 260);
          if (data.likedAlready) {
            window.alert('Kamu sudah menyukai postingan ini.');
          }
        } catch (error) {
          likeButton.classList.remove('is-pop');
          window.alert(error.message || 'Gagal menyukai postingan');
        }
      });

      replyForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (postIsDeleted) {
          return;
        }
        const content = String(replyInput.value || '').trim();
        if (!content) return;

        try {
          const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/comments`, {
            method: 'POST',
            headers: {
              Accept: 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: new URLSearchParams({ content })
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || !data.success) {
            throw new Error(data.error || 'Gagal mengirim komentar');
          }

          const emptyState = commentsList.querySelector('.community-detail-empty');
          if (emptyState) {
            emptyState.remove();
          }
          commentsList.insertAdjacentHTML('beforeend', renderComment(data.comment));
          replyInput.value = '';
          const currentCount = Number(commentState.textContent.match(/\d+/)?.[0] || '0') + 1;
          commentState.textContent = `${currentCount} balasan`;
        } catch (error) {
          window.alert(error.message || 'Gagal mengirim komentar');
        }
      });

      reportClose?.addEventListener('click', () => setReportVisible(false));
      reportOverlay?.addEventListener('click', (event) => {
        if (event.target === reportOverlay) {
          setReportVisible(false);
        }
      });
      reportContentButton?.addEventListener('click', () => {
        if (postIsDeleted) return;
        openReportModal({
          targetType: 'post',
          targetId: postId,
          targetUserId: postCreatorUserId,
          title: 'Laporkan konten'
        });
      });
      reportUserButton?.addEventListener('click', () => {
        if (postIsDeleted) return;
        openReportModal({
          targetType: 'user',
          targetId: postCreatorUserId,
          targetUserId: postCreatorUserId,
          title: 'Laporkan pengguna'
        });
      });

      deletePostButton?.addEventListener('click', async () => {
        if (postIsDeleted) {
          return;
        }
        const confirmed = window.confirm('Hapus postingan ini? Aksi ini tidak bisa dibatalkan.');
        if (!confirmed) {
          return;
        }

        deletePostButton.disabled = true;
        try {
          await deletePost();
          window.location.href = '/community?notice=Postingan+berhasil+dihapus';
        } catch (error) {
          deletePostButton.disabled = false;
          window.alert(error.message || 'Gagal menghapus postingan');
        }
      });

      commentsList?.addEventListener('click', (event) => {
        const reportCommentButton = event.target.closest('[data-action="report-comment"]');
        if (!reportCommentButton) {
          return;
        }

        event.preventDefault();
        event.stopPropagation();

        openReportModal({
          targetType: 'comment',
          targetId: reportCommentButton.getAttribute('data-report-target-id') || '',
          targetUserId: reportCommentButton.getAttribute('data-report-target-user-id') || '',
          title: reportCommentButton.getAttribute('data-report-title') || 'Laporkan komentar'
        });
      });
      reportForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        try {
          if (reportTargetType?.value === 'user') {
            if (reportTargetId && !reportTargetId.value) {
              reportTargetId.value = postCreatorUserId || '';
            }
          }
          await sendReport();
          setReportVisible(false);
          showReportToast('Laporan berhasil dikirim. Tim admin akan meninjaunya.');
        } catch (error) {
          showReportToast(error.message || 'Gagal mengirim laporan', 'error');
        }
      });
    })();
  </script>
</body>
</html>
