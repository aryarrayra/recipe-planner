<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>

  <main class="user-dashboard user-recipe-menu-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'recipes', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar user-recipe-topbar">
          <div class="user-topbar-actions"></div>
        </header>

        <div class="user-recipe-menu-layout user-recipe-menu-layout-single">
          <section class="user-recipe-menu-main">
            <article class="user-panel user-recipe-menu-hero">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Recipe collection</p>
                  <h1>Pilih resep yang mau dimasak</h1>
                </div>
              </div>

              <p class="user-ai-copy">
                Halaman ini khusus katalog resep. Pilih filter region dan bahan untuk mempersempit hasil, lalu tombol
                `Cook` untuk masuk ke detail resep dan mulai ikuti step memasaknya.
              </p>

              <form class="user-recipe-filter-form" action="/recipe-menu" method="get">
                <label class="user-recipe-filter-field">
                  <span>Region</span>
                  <select name="region">
                    <% regionOptions.forEach((option) => { %>
                      <option value="<%= option.value %>" <%= String(selectedRegion || '') === String(option.value || '') ? 'selected' : '' %>>
                        <%= option.label %>
                      </option>
                    <% }) %>
                  </select>
                </label>

                <label class="user-recipe-filter-field">
                  <span>Bahan</span>
                  <select name="ingredient">
                    <% ingredientOptions.forEach((option) => { %>
                      <option value="<%= option.value %>" <%= String(selectedIngredient || '') === String(option.value || '') ? 'selected' : '' %>>
                        <%= option.label %>
                      </option>
                    <% }) %>
                  </select>
                </label>

                <label class="user-recipe-filter-field">
                  <span>Alphabet</span>
                  <select name="alphabet">
                    <% alphabetOptions.forEach((option) => { %>
                      <option value="<%= option.value %>" <%= String(selectedAlphabet || '') === String(option.value || '') ? 'selected' : '' %>>
                        <%= option.label %>
                      </option>
                    <% }) %>
                  </select>
                </label>

                <label class="user-recipe-filter-field user-recipe-filter-field-text">
                  <span>Cari resep</span>
                  <input
                    type="text"
                    name="q"
                    value="<%= search || '' %>"
                    placeholder="Nama resep, atau kata kunci"
                  />
                </label>

                <div class="user-recipe-filter-actions">
                  <button type="submit" class="auth-button">Terapkan filter</button>
                  <a class="auth-button auth-button-secondary" href="/recipe-menu">Reset</a>
                </div>
              </form>
            </article>

            <div class="user-recipe-menu-grid" id="recipe-results">
              <% recipes.forEach((recipe) => { %>
                <article class="user-panel user-recipe-menu-card">
                  <a class="user-recipe-menu-media" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>" aria-label="Buka resep <%= recipe.title %>">
                    <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                  </a>
                  <div class="user-recipe-menu-copy">
                    <div class="user-recipe-menu-copy-top">
                      <p class="user-panel-kicker"><%= recipe.originPlace || recipe.cuisine || recipe.category %></p>
                      <span class="user-recipe-menu-price">Rp <%= formatPrice(recipe.estimatedPrice || 0) %></span>
                    </div>
                    <h2><%= recipe.title %></h2>
                    <div class="user-recipe-menu-meta">
                      <span><i class="fa-solid fa-star"></i> 4.9</span>
                      <span><i class="fa-regular fa-clock"></i> <%= recipe.cookingTime %> min</span>
                      <span><i class="fa-solid fa-signal"></i> <%= recipe.difficulty %></span>
                    </div>

                    <div class="user-recipe-menu-actions">
                      <% if (recipe.warning) { %>
                        <div class="recipe-warning-badge user-recipe-menu-warning">
                          <i class="fa-solid fa-triangle-exclamation"></i>
                          <span><%= recipe.warning %></span>
                        </div>
                      <% } else { %>
                        <span class="user-recipe-menu-origin"><%= recipe.creatorName %></span>
                      <% } %>
                      <a class="user-recipe-menu-cta" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.id) %>">Cook</a>
                    </div>
                  </div>
                </article>
              <% }) %>

              <% if (!recipes.length) { %>
                <article class="user-panel user-feed-empty">
                  <h3>Belum ada resep yang cocok.</h3>
                  <p>Coba cari keyword lain atau ganti kategori resep.</p>
                </article>
              <% } %>
            </div>

            <% if (totalPages > 1) { %>
              <nav class="user-recipe-pagination" aria-label="Pagination resep">
                <% if (currentPage <= 1) { %>
                  <span class="user-recipe-pagination-link is-disabled" aria-disabled="true" tabindex="-1">
                    <i class="fa-solid fa-chevron-left"></i>
                    Prev
                  </span>
                <% } else { %>
                  <a class="user-recipe-pagination-link" href="<%= prevPageUrl %>">
                    <i class="fa-solid fa-chevron-left"></i>
                    Prev
                  </a>
                <% } %>

                <div class="user-recipe-pagination-pages">
                  <% paginationItems.forEach((item) => { %>
                    <% if (item === 'ellipsis') { %>
                      <span class="user-recipe-pagination-ellipsis">...</span>
                    <% } else if (item === currentPage) { %>
                      <span class="user-recipe-pagination-page is-active"><%= item %></span>
                    <% } else { %>
                      <a class="user-recipe-pagination-page" href="<%= buildPageUrl(item) %>"><%= item %></a>
                    <% } %>
                  <% }) %>
                </div>

                <% if (currentPage >= totalPages) { %>
                  <span class="user-recipe-pagination-link is-disabled" aria-disabled="true" tabindex="-1">
                    Next
                    <i class="fa-solid fa-chevron-right"></i>
                  </span>
                <% } else { %>
                  <a class="user-recipe-pagination-link" href="<%= nextPageUrl %>">
                    Next
                    <i class="fa-solid fa-chevron-right"></i>
                  </a>
                <% } %>
              </nav>
              <p class="user-recipe-load-more-note">
                Menampilkan <%= visibleRecipeCount %> resep dari <%= totalRecipeCount %> hasil.
              </p>
            <% } %>
          </section>

        </div>
      </section>
    </div>
  </main>
</body>
</html>
