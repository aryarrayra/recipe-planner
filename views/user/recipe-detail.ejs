<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .recipe-share-sheet[hidden] { display: none !important; }
    .recipe-share-sheet {
      position: fixed;
      inset: 0;
      z-index: 80;
      display: grid;
      place-items: center;
      padding: 24px;
      background: rgba(15, 23, 42, 0.24);
      backdrop-filter: blur(8px);
    }
    .recipe-share-sheet-panel {
      width: min(100%, 420px);
      border-radius: 28px;
      padding: 24px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
      display: grid;
      gap: 14px;
    }
    .recipe-share-sheet-head {
      display: grid;
      gap: 6px;
    }
    .recipe-share-sheet-head h3,
    .recipe-share-sheet-head p {
      margin: 0;
    }
    .recipe-share-sheet-head p {
      color: #5f6f79;
    }
    .recipe-share-sheet-actions {
      display: grid;
      gap: 10px;
    }
    .recipe-share-option {
      width: 100%;
      justify-content: flex-start;
      gap: 12px;
      text-align: left;
    }
    .recipe-share-sheet-close {
      justify-self: end;
      border: 0;
      background: transparent;
      color: #54737a;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 700;
    }
  </style>
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const serializedRecipes = JSON.stringify(recipes || []).replace(/</g, '\\u003c'); %>
  <% const activeRecipeId = activeRecipe ? String(activeRecipe.favoriteKey || activeRecipe.id) : ''; %>
  <% const activeRecipeSource = activeRecipe ? String(activeRecipe.source || 'themealdb') : ''; %>
  <% const activeRecipeSourceId = activeRecipe ? String(activeRecipe.sourceId || activeRecipe.id || '') : ''; %>

  <main class="user-dashboard user-feed-page user-recipe-detail-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'recipes', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar user-recipe-topbar">
          <div class="user-topbar-actions">
            <a class="user-recipe-back-link" href="/recipe-menu" aria-label="Kembali ke daftar resep">
              <span class="user-recipe-back-icon" aria-hidden="true"><i class="fa-solid fa-arrow-left"></i></span>
              <span>Kembali</span>
            </a>
          </div>
        </header>

        <% if (activeRecipe) { %>
          <div class="user-recipe-detail-layout user-recipe-detail-layout-no-rail">
            <section class="user-recipe-detail-main">
              <article class="user-panel user-recipe-detail-panel">
                <div class="user-recipe-visual user-recipe-hero-media">
                  <% if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'youtube') { %>
                    <iframe
                      src="<%= activeRecipe.videoSource.src %>"
                      title="<%= activeRecipe.title %>"
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  <% } else if (activeRecipe.videoSource && activeRecipe.videoSource.src && activeRecipe.videoSource.kind === 'direct') { %>
                    <video controls poster="<%= activeRecipe.imageUrl %>">
                      <source src="<%= activeRecipe.videoSource.src %>" />
                    </video>
                  <% } else if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'tiktok' && activeRecipe.videoSource.postUrl) { %>
                    <blockquote
                      class="tiktok-embed"
                      cite="<%= activeRecipe.videoSource.postUrl %>"
                      data-video-id="<%= activeRecipe.videoSource.videoId %>"
                      style="max-width: 100%; min-width: 100%;"
                    >
                      <section>
                        <a target="_blank" rel="noreferrer" href="<%= activeRecipe.videoSource.postUrl %>">
                          Lihat di TikTok
                        </a>
                      </section>
                    </blockquote>
                  <% } else if (activeRecipe.hasImage) { %>
                    <img src="<%= activeRecipe.imageUrl %>" alt="<%= activeRecipe.title %>" />
                  <% } else { %>
                    <div class="user-recipe-visual-placeholder">
                      <i class="fa-regular fa-image"></i>
                      <strong>Resep ini belum punya gambar</strong>
                      <span>Fokus ke ringkasan, bahan, dan langkah memasaknya.</span>
                    </div>
                  <% } %>
                </div>

                <div class="user-panel-head user-recipe-detail-head">
                  <div class="user-recipe-detail-head-main">
                    <p class="user-panel-kicker"><%= activeRecipe.originPlace || activeRecipe.cuisine %> &bull; <%= activeRecipe.category %></p>
                    <h1><%= activeRecipe.title %></h1>
                  </div>
                  <div class="user-recipe-author">
                    <span>Dibuat oleh <strong><%= activeRecipe.creatorName %></strong></span>
                  </div>
                </div>

                <div class="user-recipe-detail-tags">
                  <span><i class="fa-regular fa-clock"></i> <%= activeRecipe.cookingTime %> menit</span>
                  <span><i class="fa-solid fa-signal"></i> <%= activeRecipe.difficulty %></span>
                  <span><i class="fa-solid fa-fire"></i> <%= activeRecipe.calories %> kkal</span>
                  <span><i class="fa-solid fa-rotate-right"></i> <%= Number(activeRecipe.recookCount || 0) %> kali recook</span>
                </div>

                <% if (activeRecipe.warning) { %>
                  <div class="recipe-warning-badge recipe-warning-panel">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span><%= activeRecipe.warning %></span>
                  </div>
                <% } %>

                <div class="user-recipe-detail-grid">
                  <div class="user-recipe-sidecards">
                    <article class="user-recipe-mini-panel">
                      <div class="recipe-serving-head">
                        <div>
                          <h3>Bahan</h3>
                          <p class="recipe-serving-copy">Ubah porsi, quantity bahan ikut menyesuaikan otomatis.</p>
                        </div>
                        <div class="recipe-serving-scaler" id="recipeServingScaler">
                          <button type="button" class="recipe-serving-btn" data-serving-action="decrease" aria-label="Kurangi porsi">
                            <i class="fa-solid fa-minus"></i>
                          </button>
                          <label class="recipe-serving-input-wrap">
                            <span>Porsi</span>
                            <input type="number" min="1" step="1" value="<%= activeRecipe.servings %>" id="recipeServingInput" />
                          </label>
                          <button type="button" class="recipe-serving-btn" data-serving-action="increase" aria-label="Tambah porsi">
                            <i class="fa-solid fa-plus"></i>
                          </button>
                        </div>
                      </div>
                      <div class="user-recipe-ingredient-list" id="recipeIngredientList">
                        <% activeRecipe.ingredients.forEach((ingredient) => { %>
                          <label class="user-recipe-ingredient-item">
                            <span><%= ingredient.display || ingredient.label || ingredient.name %></span>
                          </label>
                        <% }) %>
                      </div>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Ringkasan resep</h3>
                      <div class="user-recipe-summary-list">
                        <span><strong>Perkiraan harga</strong> Rp <span id="recipeEstimatedPrice"><%= formatPrice(activeRecipe.estimatedPrice) %></span></span>
                        <span><strong>Waktu</strong> <%= activeRecipe.cookingTime %> menit</span>
                        <span><strong>Tingkat</strong> <%= activeRecipe.difficulty %></span>
                        <span><strong>Porsi</strong> <span id="recipeServingLabel"><%= activeRecipe.servings %></span> porsi</span>
                      </div>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Info makanan</h3>
                      <div class="recipe-food-info-list">
                        <% activeRecipe.foodInfo.badges.forEach((badge) => { %>
                          <span class="recipe-food-info-badge is-<%= badge.tone %>"><%- badge.tone === 'safe' ? '&#10003;' : badge.tone === 'warn' ? '&#9888;' : '&#10060;' %> <%= badge.text %></span>
                        <% }) %>
                      </div>
                    </article>
                  </div>
                </div>

                <p class="user-recipe-detail-description"><%= activeRecipe.description %></p>

                <div class="user-recipe-action-row">
                  <a class="user-recipe-action-btn is-primary" href="#recipeSteps">
                    <i class="fa-solid fa-play"></i>
                    <span>Mulai masak</span>
                  </a>
                  <button
                    type="button"
                    class="user-recipe-action-btn"
                    id="recipeDetailFavorite"
                    data-action="favorite"
                    data-recipe-id="<%= activeRecipe.favoriteKey || activeRecipe.id %>"
                  >
                    <i class="fa-<%= activeRecipe.isFavorite ? 'solid' : 'regular' %> fa-heart"></i>
                    <span><%= activeRecipe.isFavorite ? 'Hapus dari favorit' : 'Simpan ke favorit' %></span>
                  </button>
                  <button
                    type="button"
                    class="user-recipe-action-btn"
                    id="recipeAddToShoppingList"
                    data-recipe-id="<%= activeRecipe.favoriteKey || activeRecipe.id %>"
                  >
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Tambah ke daftar belanja</span>
                  </button>
                  <a class="user-recipe-action-btn" href="/shopping-list">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Lihat daftar belanja</span>
                  </a>
                  <a class="user-recipe-action-btn" href="/recipe-menu">
                    <i class="fa-solid fa-compass"></i>
                    <span>Kembali ke katalog</span>
                  </a>
                  <button type="button" class="user-recipe-action-btn" id="recipeDetailShare" data-action="share">
                    <i class="fa-solid fa-share-nodes"></i>
                    <span>Bagikan</span>
                  </button>
                </div>
              </article>

              <article class="user-panel user-recipe-steps-panel" id="recipeSteps">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Langkah demi langkah</p>
                    <h2>Masak pelan-pelan, lanjut per step</h2>
                  </div>
                  <span class="user-panel-meta" id="stepProgressLabel">1 / <%= activeRecipe.steps.length %></span>
                </div>

                <div class="user-recipe-step-list" id="recipeStepList">
                  <% activeRecipe.steps.forEach((step, index) => { %>
                    <article class="user-recipe-step-card <%= index === 0 ? 'is-visible' : '' %>" data-step-card data-step-index="<%= index %>">
                      <strong>Langkah <%= step.step %></strong>
                      <p><%= step.instruction %></p>
                    </article>
                  <% }) %>
                </div>

                <div class="user-ai-actions">
                  <button
                    type="button"
                    class="auth-button"
                    id="nextStepButton"
                    data-finished-label="Selesai"
                    data-finish-url="/recipes/serve?recipeId=<%= encodeURIComponent(activeRecipe.id) %>"
                  >
                    <%= activeRecipe.steps.length <= 1 ? 'Selesai' : 'Lanjut' %>
                  </button>
                </div>
              </article>
            </section>

            <aside class="user-recipe-detail-sidebar">
              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Resep terkait</p>
                    <h2>Cocok dibuka berikutnya</h2>
                  </div>
                </div>

                <% if (relatedRecipes.length) { %>
                  <div class="user-recipe-related-list">
                    <% relatedRecipes.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link <%= recipe.hasImage ? '' : 'is-text-only' %>" href="/recipe-detail?feed=<%= encodeURIComponent(feed) %>&recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <% if (recipe.hasImage) { %>
                          <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <% } %>
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.originPlace || recipe.cuisine || recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit &bull; <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-folder-open"></i>
                    <p>Belum ada resep terkait untuk asal masakan ini.</p>
                  </div>
                <% } %>
              </article>
            </aside>
          </div>
        <% } else { %>
          <article class="user-panel user-feed-empty">
            <h3>Belum ada resep yang bisa ditampilkan.</h3>
            <p>Coba ganti filter atau tambahkan resep approved dulu dari halaman admin.</p>
          </article>
        <% } %>
      </section>
    </div>
  </main>

  <div class="recipe-share-sheet" id="recipeShareSheet" hidden>
    <div class="recipe-share-sheet-panel" role="dialog" aria-modal="true" aria-labelledby="recipeShareTitle">
      <button type="button" class="recipe-share-sheet-close" id="recipeShareClose">Tutup</button>
      <div class="recipe-share-sheet-head">
        <h3 id="recipeShareTitle">Bagikan resep</h3>
        <p>Pilih cara bagikan resep ini.</p>
      </div>
      <div class="recipe-share-sheet-actions">
        <button type="button" class="user-recipe-action-btn recipe-share-option" id="recipeShareCopyLink">
          <i class="fa-solid fa-link"></i>
          <span>Copy link</span>
        </button>
        <button type="button" class="user-recipe-action-btn recipe-share-option" id="recipeShareWhatsapp">
          <i class="fa-brands fa-whatsapp"></i>
          <span>Kirim ke WhatsApp</span>
        </button>
        <button type="button" class="user-recipe-action-btn recipe-share-option" id="recipeShareCommunity">
          <i class="fa-solid fa-retweet"></i>
          <span>Reshared ke community</span>
        </button>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const cards = Array.from(document.querySelectorAll('[data-step-card]'));
      const nextButton = document.getElementById('nextStepButton');
      const progressLabel = document.getElementById('stepProgressLabel');
      const recipes = <%- serializedRecipes %>;
      const recipeMap = new Map(recipes.map((recipe) => [String(recipe.id), recipe]));
      const selectedRecipeSnapshot = <%- JSON.stringify(activeRecipe || null).replace(/</g, '\\u003c') %>;
      const selectedFavoriteButton = document.getElementById('recipeDetailFavorite');
      const selectedShareButton = document.getElementById('recipeDetailShare');
      const shoppingListButton = document.getElementById('recipeAddToShoppingList');
      const ingredientList = document.getElementById('recipeIngredientList');
      const servingInput = document.getElementById('recipeServingInput');
      const servingLabel = document.getElementById('recipeServingLabel');
      const estimatedPriceNode = document.getElementById('recipeEstimatedPrice');
      const shareSheet = document.getElementById('recipeShareSheet');
      const shareSheetClose = document.getElementById('recipeShareClose');
      const shareCopyLinkButton = document.getElementById('recipeShareCopyLink');
      const shareWhatsappButton = document.getElementById('recipeShareWhatsapp');
      const shareCommunityButton = document.getElementById('recipeShareCommunity');
      let activeShareRecipe = selectedRecipeSnapshot;
      const selectedRecipeId = String(<%- JSON.stringify(activeRecipe ? (activeRecipe.favoriteKey || activeRecipe.id) : '') %>);
      const recipeScalerState = {
        originalServings: Math.max(1, Number(selectedRecipeSnapshot?.servings || 1)),
        desiredServings: Math.max(1, Number(selectedRecipeSnapshot?.servings || 1)),
        estimatedPrice: Number(selectedRecipeSnapshot?.estimatedPrice || 0),
        ingredients: Array.isArray(selectedRecipeSnapshot?.ingredients) ? selectedRecipeSnapshot.ingredients : []
      };
      const COMMUNITY_PREFILL_KEY = 'communityRecipePrefill';
      const recookIdentity = {
        source: <%- JSON.stringify(activeRecipeSource) %>,
        sourceId: <%- JSON.stringify(activeRecipeSourceId) %>,
        recipeId: <%- JSON.stringify(activeRecipe && activeRecipe.recipeId ? String(activeRecipe.recipeId) : '') %>,
        title: <%- JSON.stringify(activeRecipe ? activeRecipe.title : '') %>,
        imageUrl: <%- JSON.stringify(activeRecipe ? activeRecipe.imageUrl : '') %>,
        category: <%- JSON.stringify(activeRecipe ? activeRecipe.category : '') %>,
        cuisine: <%- JSON.stringify(activeRecipe ? activeRecipe.cuisine : '') %>
      };
      const escapeSelector = (value) => {
        if (window.CSS && typeof window.CSS.escape === 'function') {
          return window.CSS.escape(String(value || ''));
        }

        return String(value || '').replace(/"/g, '\\"');
      };

      const buildCommunityPrefill = (recipe) => {
        if (!recipe) {
          return null;
        }

        return {
          title: recipe.title || '',
          description: recipe.description || '',
          image_url: recipe.imageUrl || '',
          video_url: recipe.videoSource?.src || recipe.videoUrl || '',
          cuisine: recipe.originPlace || recipe.cuisine || '',
          category: String(recipe.category || '').toLowerCase(),
          cooking_time: Number(recipe.cookingTime || 0) || '',
          servings: Number(recipe.servings || 0) || '',
          difficulty: String(recipe.difficulty || '').toLowerCase(),
          estimated_price: Number(recipe.estimatedPrice || 0) || '',
          tags: Array.isArray(recipe.tags) ? recipe.tags : [],
          ingredients: Array.isArray(recipe.ingredients)
            ? recipe.ingredients.map((ingredient) => ingredient?.display || ingredient?.label || ingredient?.name || '').filter(Boolean)
            : [],
          steps: Array.isArray(recipe.steps)
            ? recipe.steps.map((step) => ({
                instruction: step?.instruction || step?.text || '',
                image_url: step?.imageUrl || step?.image_url || ''
              }))
            : [],
          share_type: 'reshared'
        };
      };

      const buildRecipeLink = (recipe) => {
        const recipeId = encodeURIComponent(String(recipe?.id || ''));
        return `${window.location.origin}/recipe-detail?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${recipeId}`;
      };

      const setShareSheetVisible = (visible) => {
        if (!shareSheet) {
          return;
        }

        shareSheet.hidden = !visible;
      };

      const openCommunityShare = (recipe) => {
        const payload = buildCommunityPrefill(recipe);
        if (!payload) {
          window.location.href = '/community/new';
          return;
        }

        try {
          window.sessionStorage.setItem(COMMUNITY_PREFILL_KEY, JSON.stringify(payload));
        } catch (error) {
          console.error('Failed to store community prefill:', error);
        }

        window.location.href = '/community/new';
      };

      const openShareMenu = (recipe) => {
        activeShareRecipe = recipe || selectedRecipeSnapshot || null;
        setShareSheetVisible(true);
      };

      const closeShareMenu = () => {
        setShareSheetVisible(false);
      };

      const copyRecipeLink = async (recipe) => {
        const link = buildRecipeLink(recipe);
        try {
          await navigator.clipboard.writeText(link);
          window.alert('Link resep berhasil disalin.');
        } catch (error) {
          window.prompt('Salin link resep ini:', link);
        }
      };

      const shareToWhatsapp = (recipe) => {
        const link = buildRecipeLink(recipe);
        const message = `${recipe?.title || 'Resep favorit'}\n${link}`;
        window.open(`https://wa.me/?text=${encodeURIComponent(message)}`, '_blank', 'noopener');
      };

      const parseFractionToken = (value) => {
        const text = String(value || '').trim();
        if (!text) return null;
        if (/^\d+\s+\d+\/\d+$/.test(text)) {
          const [whole, fraction] = text.split(/\s+/);
          const [numerator, denominator] = fraction.split('/').map(Number);
          return denominator ? Number(whole) + (numerator / denominator) : null;
        }
        if (/^\d+\/\d+$/.test(text)) {
          const [numerator, denominator] = text.split('/').map(Number);
          return denominator ? numerator / denominator : null;
        }
        const parsed = Number.parseFloat(text.replace(',', '.'));
        return Number.isFinite(parsed) ? parsed : null;
      };

      const extractQuantity = (ingredient = {}) => {
        const name = String(ingredient.name || '').trim();
        const amountText = String(ingredient.amount || '').trim();
        const unitText = String(ingredient.unit || '').trim();
        const labelText = String(ingredient.display || ingredient.label || '').trim();
        let quantitySource = [amountText, unitText].filter(Boolean).join(' ').trim();

        if (!quantitySource && labelText) {
          quantitySource = name ? labelText.replace(new RegExp(`\\s*${name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')}$`, 'i'), '').trim() : labelText;
        }

        const match = quantitySource.match(/^(\d+\s+\d+\/\d+|\d+\/\d+|\d+(?:[.,]\d+)?)\s*(.*)$/);
        if (!match) {
          return {
            quantity: null,
            unit: unitText,
            fallbackText: quantitySource
          };
        }

        return {
          quantity: parseFractionToken(match[1]),
          unit: unitText || String(match[2] || '').trim(),
          fallbackText: match[1]
        };
      };

      const formatQuantityValue = (value) => {
        const rounded = Math.round(Number(value || 0) * 100) / 100;
        if (Number.isInteger(rounded)) return String(rounded);
        return rounded.toFixed(2).replace(/\.00$/, '').replace(/(\.\d*[1-9])0+$/, '$1');
      };

      const scaleIngredientDisplay = (ingredient) => {
        const parsed = extractQuantity(ingredient);
        const ratio = recipeScalerState.desiredServings / recipeScalerState.originalServings;
        const scaled = parsed.quantity === null ? null : (parsed.quantity * ratio);
        const prefix = scaled !== null
          ? [formatQuantityValue(scaled), parsed.unit].filter(Boolean).join(' ').trim()
          : parsed.fallbackText || '';
        return [prefix, ingredient.name].filter(Boolean).join(' ').trim() || ingredient.display || ingredient.label || ingredient.name;
      };

      const renderScaledIngredients = () => {
        if (servingInput) {
          servingInput.value = String(recipeScalerState.desiredServings);
        }

        if (servingLabel) {
          servingLabel.textContent = String(recipeScalerState.desiredServings);
        }

        if (estimatedPriceNode) {
          const scaledPrice = recipeScalerState.estimatedPrice * (recipeScalerState.desiredServings / recipeScalerState.originalServings);
          estimatedPriceNode.textContent = new Intl.NumberFormat('id-ID').format(Math.round(scaledPrice));
        }

        if (!ingredientList) {
          return;
        }

        ingredientList.innerHTML = '';
        recipeScalerState.ingredients.forEach((ingredient) => {
          const item = document.createElement('label');
          item.className = 'user-recipe-ingredient-item';
          const text = document.createElement('span');
          text.textContent = scaleIngredientDisplay(ingredient);
          item.appendChild(text);
          ingredientList.appendChild(item);
        });
      };

      const recordRecook = async () => {
        if (!recookIdentity.sourceId && !recookIdentity.recipeId) {
          return { recookCount: Number(<%- JSON.stringify(activeRecipe ? Number(activeRecipe.recookCount || 0) : 0) %>) };
        }

        const requestBody = {
          source: recookIdentity.source,
          sourceId: recookIdentity.sourceId,
          recipeId: recookIdentity.recipeId,
          title: recookIdentity.title,
          imageUrl: recookIdentity.imageUrl,
          category: recookIdentity.category,
          cuisine: recookIdentity.cuisine
        };

        const response = await fetch(`/api/recipes/${encodeURIComponent(recookIdentity.recipeId || recookIdentity.sourceId)}/recook`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(requestBody)
        });

        const result = await response.json().catch(() => ({}));

        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Gagal menyimpan recook.');
        }

        return result.data || {};
      };

      if (!cards.length || !nextButton) {
        // Still keep the page interactive for favorites/sharing below.
      } else {
        let visibleCount = Math.max(1, cards.filter((card) => card.classList.contains('is-visible')).length);

        const syncState = () => {
          cards.forEach((card, index) => {
            card.classList.toggle('is-visible', index < visibleCount);
          });

          if (progressLabel) {
            progressLabel.textContent = `${Math.min(visibleCount, cards.length)} / ${cards.length}`;
          }

          nextButton.textContent = visibleCount >= cards.length
            ? (nextButton.dataset.finishedLabel || 'Selesai')
            : 'Lanjut';
        };

        nextButton.addEventListener('click', () => {
          if (visibleCount < cards.length) {
            visibleCount += 1;
            syncState();
            return;
          }

          const finishUrl = nextButton.dataset.finishUrl;
          if (!finishUrl) {
            return;
          }

          nextButton.disabled = true;
          recordRecook()
            .then((result) => {
              const nextUrl = new URL(finishUrl, window.location.origin);
              if (Number.isFinite(Number(result?.recookCount))) {
                nextUrl.searchParams.set('recookCount', String(Number(result.recookCount)));
              }
              window.location.href = nextUrl.toString();
            })
            .catch((error) => {
              window.alert(error.message || 'Gagal menyimpan recook.');
              nextButton.disabled = false;
            });
        });

        syncState();
      }

      const updateFavoriteState = (recipe) => {
        const recipeKey = String(recipe.favoriteKey || recipe.id);
        const card = document.querySelector(`.user-fyp-menu-card[data-recipe-id="${escapeSelector(recipeKey)}"]`);
        const button = selectedFavoriteButton && String(selectedFavoriteButton.dataset.recipeId) === String(recipeKey)
          ? selectedFavoriteButton
          : null;

        if (card) {
          card.classList.toggle('is-favorite', Boolean(recipe.isFavorite));
          const heartButton = card.querySelector('.js-favorite-btn');
          if (heartButton) {
            heartButton.classList.toggle('is-active', Boolean(recipe.isFavorite));
            heartButton.setAttribute('aria-pressed', recipe.isFavorite ? 'true' : 'false');
            heartButton.setAttribute('aria-label', recipe.isFavorite ? 'Hapus dari favorit' : 'Simpan ke favorit');
            const icon = heartButton.querySelector('i');
            if (icon) {
              icon.className = recipe.isFavorite ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
            }
          }
        }

        if (button) {
          button.innerHTML = recipe.isFavorite
            ? '<i class="fa-solid fa-heart"></i><span>Hapus dari favorit</span>'
            : '<i class="fa-regular fa-heart"></i><span>Simpan ke favorit</span>';
        }
      };

      const toggleFavorite = async (recipeId) => {
        const response = await fetch(`/api/recipes/${encodeURIComponent(recipeId)}/favorite`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Gagal mengubah favorit.');
        }

        const recipe = recipeMap.get(String(recipeId));
        if (recipe) {
          recipe.isFavorite = Boolean(result.favorited);
          recipe.savesCount = Number(result.savesCount || 0);
          updateFavoriteState(recipe);
        }
      };

      document.querySelectorAll('.user-fyp-menu-card[data-recipe-id]').forEach((card) => {
        const recipeId = card.getAttribute('data-recipe-id');

        card.addEventListener('click', (event) => {
          const actionButton = event.target.closest('[data-action]');
          if (actionButton && actionButton.dataset.action === 'favorite') {
            return;
          }

          if (actionButton && actionButton.dataset.action === 'share') {
            const recipe = recipeMap.get(String(recipeId));
            openShareMenu(recipe);
            return;
          }

          if (actionButton && actionButton.dataset.action === 'detail') {
            window.location.href = `/recipe-detail?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
            return;
          }

          window.location.href = `/recipes?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
        });

        card.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            window.location.href = `/recipes?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
          }
        });
      });

      document.querySelectorAll('.js-favorite-btn').forEach((button) => {
        button.addEventListener('click', async (event) => {
          event.stopPropagation();
          const recipeId = button.dataset.recipeId;
          if (!recipeId) {
            return;
          }

          try {
            button.disabled = true;
            await toggleFavorite(recipeId);
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal mengubah favorit.');
          } finally {
            button.disabled = false;
          }
        });
      });

      if (selectedFavoriteButton) {
        selectedFavoriteButton.addEventListener('click', async (event) => {
          event.stopPropagation();
          const recipeId = selectedFavoriteButton.dataset.recipeId;
          if (!recipeId) {
            return;
          }

          try {
            selectedFavoriteButton.disabled = true;
            await toggleFavorite(recipeId);
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal mengubah favorit.');
          } finally {
            selectedFavoriteButton.disabled = false;
          }
        });
      }

      if (selectedShareButton) {
        selectedShareButton.addEventListener('click', openShareMenu);
      }

      shareSheetClose?.addEventListener('click', closeShareMenu);
      shareSheet?.addEventListener('click', (event) => {
        if (event.target === shareSheet) {
          closeShareMenu();
        }
      });
      shareCopyLinkButton?.addEventListener('click', async () => {
        await copyRecipeLink(activeShareRecipe);
        closeShareMenu();
      });
      shareWhatsappButton?.addEventListener('click', () => {
        shareToWhatsapp(activeShareRecipe);
        closeShareMenu();
      });
      shareCommunityButton?.addEventListener('click', () => {
        closeShareMenu();
        openCommunityShare(activeShareRecipe);
      });

      document.querySelectorAll('[data-serving-action]').forEach((button) => {
        button.addEventListener('click', () => {
          const action = button.dataset.servingAction;
          recipeScalerState.desiredServings = Math.max(
            1,
            recipeScalerState.desiredServings + (action === 'increase' ? 1 : -1)
          );
          renderScaledIngredients();
        });
      });

      if (servingInput) {
        servingInput.addEventListener('input', () => {
          const nextValue = Math.max(1, Number(servingInput.value || 1));
          recipeScalerState.desiredServings = nextValue;
          renderScaledIngredients();
        });
      }

      if (shoppingListButton) {
        shoppingListButton.addEventListener('click', async () => {
          const recipeId = shoppingListButton.dataset.recipeId;
          if (!recipeId) {
            return;
          }

          try {
            shoppingListButton.disabled = true;
            const response = await fetch(`/api/recipes/${encodeURIComponent(recipeId)}/shopping-list`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                desiredServings: recipeScalerState.desiredServings
              })
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal menambahkan ke shopping list.');
            }

            shoppingListButton.innerHTML = '<i class="fa-solid fa-check"></i><span>Tersimpan di shopping list</span>';
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal menambahkan ke shopping list.');
          } finally {
            shoppingListButton.disabled = false;
          }
        });
      }

      if (selectedRecipeSnapshot && selectedRecipeSnapshot.id) {
        recipeMap.set(String(selectedRecipeSnapshot.id), selectedRecipeSnapshot);
        if (selectedRecipeSnapshot.favoriteKey) {
          recipeMap.set(String(selectedRecipeSnapshot.favoriteKey), selectedRecipeSnapshot);
        }
      }

      renderScaledIngredients();
    })();
  </script>
</body>
</html>
