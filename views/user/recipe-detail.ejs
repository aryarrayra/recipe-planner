<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>

  <main class="user-dashboard user-feed-page user-recipe-detail-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'recipes', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar user-recipe-topbar">
          <form class="user-search user-recipe-search" action="/recipe-detail" method="get">
            <input type="hidden" name="feed" value="<%= feed %>" />
            <i class="fa-solid fa-magnifying-glass user-search-icon" aria-hidden="true"></i>
            <input type="text" name="q" placeholder="Cari resep, bahan, atau kategori" value="<%= search || '' %>" />
            <button type="submit" class="user-search-submit">Search</button>
          </form>

          <div class="user-topbar-actions">
            <a class="user-icon-button" href="/dashboard" aria-label="Kembali ke dashboard">
              <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
            </a>
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <% if (activeRecipe) { %>
          <div class="user-recipe-detail-layout">
            <aside class="user-recipe-rail">
              <article class="user-panel user-recipe-rail-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Recipe menu</p>
                    <h2><%= feedPreset.title %></h2>
                  </div>
                </div>

                <div class="user-feed-filters user-feed-filters-compact">
                  <% feedOptions.forEach((item) => { %>
                    <form class="user-feed-filter-form" action="/recipe-detail" method="get">
                      <button
                        type="submit"
                        name="feed"
                        value="<%= item.value %>"
                        class="user-feed-filter <%= feed === item.value ? 'is-active' : '' %>"
                      >
                        <strong><%= item.label %></strong>
                        <span><%= item.hint %></span>
                      </button>
                    </form>
                  <% }) %>
                </div>

                <div class="user-recipe-rail-list">
                  <% recipes.forEach((recipe) => { %>
                    <a
                      class="user-recipe-rail-item <%= String(recipe.id) === String(activeRecipe.id) ? 'is-active' : '' %>"
                      href="/recipe-detail?feed=<%= encodeURIComponent(feed) %>&recipeId=<%= encodeURIComponent(recipe.id) %><%= search ? `&q=${encodeURIComponent(search)}` : '' %>"
                    >
                      <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                      <div class="user-recipe-rail-copy">
                        <strong><%= recipe.title %></strong>
                        <span><%= recipe.cookingTime %> menit • <%= recipe.difficulty %></span>
                      </div>
                    </a>
                  <% }) %>
                </div>
              </article>
            </aside>

            <section class="user-recipe-detail-main">
              <article class="user-panel user-recipe-detail-panel">
                <div class="user-panel-head user-recipe-detail-head">
                  <div>
                    <p class="user-panel-kicker"><%= activeRecipe.category %> • <%= activeRecipe.cuisine %></p>
                    <h1><%= activeRecipe.title %></h1>
                  </div>
                  <div class="user-recipe-author">
                    <span>Uploaded by <strong><%= activeRecipe.creatorName %></strong></span>
                  </div>
                </div>

                <div class="user-recipe-detail-tags">
                  <span><i class="fa-solid fa-star"></i> <%= activeRecipe.likesCount %> likes</span>
                  <span><i class="fa-regular fa-eye"></i> <%= activeRecipe.viewsCount %> views</span>
                  <span><i class="fa-regular fa-clock"></i> <%= activeRecipe.cookingTime %> menit</span>
                  <span><i class="fa-solid fa-wallet"></i> Rp <%= formatPrice(activeRecipe.estimatedPrice) %></span>
                  <span><i class="fa-solid fa-signal"></i> <%= activeRecipe.difficulty %></span>
                  <span><i class="fa-solid fa-fire"></i> <%= activeRecipe.calories %> kkal</span>
                </div>

                <% if (activeRecipe.warning) { %>
                  <div class="recipe-warning-badge recipe-warning-panel">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span><%= activeRecipe.warning %></span>
                  </div>
                <% } %>

                <div class="user-recipe-detail-grid">
                  <div class="user-recipe-visual">
                    <% if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'youtube') { %>
                      <iframe
                        src="<%= activeRecipe.videoSource.src %>"
                        title="<%= activeRecipe.title %>"
                        allow="autoplay; encrypted-media; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    <% } else if (activeRecipe.videoSource && activeRecipe.videoSource.src && activeRecipe.videoSource.kind === 'direct') { %>
                      <video controls poster="<%= activeRecipe.imageUrl %>">
                        <source src="<%= activeRecipe.videoSource.src %>" />
                      </video>
                    <% } else { %>
                      <img src="<%= activeRecipe.imageUrl %>" alt="<%= activeRecipe.title %>" />
                    <% } %>
                  </div>

                  <div class="user-recipe-sidecards">
                    <article class="user-recipe-mini-panel">
                      <h3>Ingredients</h3>
                      <div class="user-recipe-ingredient-list">
                        <% activeRecipe.ingredients.forEach((ingredient) => { %>
                          <label class="user-recipe-ingredient-item">
                            <input type="checkbox" />
                            <span><%= ingredient.label %></span>
                          </label>
                        <% }) %>
                      </div>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Recipe summary</h3>
                      <div class="user-recipe-summary-list">
                        <span><strong>Biaya</strong> Rp <%= formatPrice(activeRecipe.estimatedPrice) %></span>
                        <span><strong>Waktu</strong> <%= activeRecipe.cookingTime %> menit</span>
                        <span><strong>Difficulty</strong> <%= activeRecipe.difficulty %></span>
                        <span><strong>Servings</strong> <%= activeRecipe.servings %> porsi</span>
                      </div>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Food info</h3>
                      <div class="recipe-food-info-list">
                        <% activeRecipe.foodInfo.badges.forEach((badge) => { %>
                          <span class="recipe-food-info-badge is-<%= badge.tone %>"><%= badge.tone === 'safe' ? '✅' : badge.tone === 'warn' ? '⚠' : '❌' %> <%= badge.text %></span>
                        <% }) %>
                      </div>
                    </article>
                  </div>
                </div>

                <p class="user-recipe-detail-description"><%= activeRecipe.description %></p>

                <div class="user-recipe-action-row">
                  <button type="button" class="user-recipe-action-btn"><i class="fa-regular fa-bookmark"></i> Save Recipe</button>
                  <button type="button" class="user-recipe-action-btn"><i class="fa-regular fa-file-pdf"></i> Export PDF</button>
                  <button type="button" class="user-recipe-action-btn"><i class="fa-regular fa-heart"></i> Favorite</button>
                  <button type="button" class="user-recipe-action-btn"><i class="fa-solid fa-share-nodes"></i> Share</button>
                  <button type="button" class="user-recipe-action-btn is-primary"><i class="fa-solid fa-fire-burner"></i> Cook Mode</button>
                </div>
              </article>

              <article class="user-panel user-recipe-steps-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Step by step</p>
                    <h2>Masak pelan-pelan, lanjut per step</h2>
                  </div>
                  <span class="user-panel-meta" id="stepProgressLabel">1 / <%= activeRecipe.steps.length %></span>
                </div>

                <div class="user-recipe-step-list" id="recipeStepList">
                  <% activeRecipe.steps.forEach((step, index) => { %>
                    <article class="user-recipe-step-card <%= index === 0 ? 'is-visible' : '' %>" data-step-card data-step-index="<%= index %>">
                      <strong>Step <%= step.step %></strong>
                      <p><%= step.instruction %></p>
                    </article>
                  <% }) %>
                </div>

                <div class="user-ai-actions">
                  <button
                    type="button"
                    class="auth-button"
                    id="nextStepButton"
                    data-finished-label="Done"
                    data-finish-url="/recipes/serve?recipeId=<%= encodeURIComponent(activeRecipe.id) %>"
                  >
                    <%= activeRecipe.steps.length <= 1 ? 'Done' : 'Lanjut' %>
                  </button>
                </div>
              </article>
            </section>

            <aside class="user-recipe-detail-sidebar">
              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Active events</p>
                    <h2>Activity di resep ini</h2>
                  </div>
                  <span class="user-panel-link">View all</span>
                </div>

                <div class="user-stat-list">
                  <div class="user-stat-card">
                    <i class="fa-solid fa-users"></i>
                    <strong><%= activeRecipe.viewsCount %> pembaca</strong>
                    <span>Resep ini sedang ramai dibuka user lain.</span>
                  </div>
                  <div class="user-stat-card">
                    <i class="fa-solid fa-bookmark"></i>
                    <strong><%= activeRecipe.savesCount %> simpan</strong>
                    <span>Bisa dijadikan menu andalan minggu ini.</span>
                  </div>
                </div>
              </article>

              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Reviews & ratings</p>
                    <h2>Feedback user</h2>
                  </div>
                </div>

                <div class="user-recipe-review-list">
                  <% reviews.forEach((review) => { %>
                    <article class="user-recipe-review-item">
                      <div class="user-recipe-review-head">
                        <strong><%= review.name %></strong>
                        <span><%= '★'.repeat(review.rating) %></span>
                      </div>
                      <p><%= review.note %></p>
                    </article>
                  <% }) %>
                </div>
              </article>

              <article class="user-panel">
                <div class="user-panel-head">
                  <div>
                    <p class="user-panel-kicker">Related recipes</p>
                    <h2>Cocok dibuka berikutnya</h2>
                  </div>
                </div>

                <% if (relatedRecipes.length) { %>
                  <div class="user-recipe-related-list">
                    <% relatedRecipes.forEach((recipe) => { %>
                      <a class="user-mini-recipe-card user-mini-recipe-card-link" href="/recipe-detail?feed=<%= encodeURIComponent(feed) %>&recipeId=<%= encodeURIComponent(recipe.id) %>">
                        <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                        <div class="user-mini-recipe-copy">
                          <h3><%= recipe.title %></h3>
                          <p><%= recipe.category %></p>
                          <small><%= recipe.cookingTime %> menit • <%= recipe.difficulty %></small>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } else { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-folder-open"></i>
                    <p>Belum ada resep terkait untuk kategori ini.</p>
                  </div>
                <% } %>
              </article>
            </aside>
          </div>
        <% } else { %>
          <article class="user-panel user-feed-empty">
            <h3>Belum ada resep yang bisa ditampilkan.</h3>
            <p>Coba ganti filter atau tambahkan resep approved dulu dari halaman admin.</p>
          </article>
        <% } %>
      </section>
    </div>
  </main>

  <script>
    (() => {
      const cards = Array.from(document.querySelectorAll('[data-step-card]'));
      const nextButton = document.getElementById('nextStepButton');
      const progressLabel = document.getElementById('stepProgressLabel');

      if (!cards.length || !nextButton) {
        return;
      }

      let visibleCount = Math.max(1, cards.filter((card) => card.classList.contains('is-visible')).length);

      const syncState = () => {
        cards.forEach((card, index) => {
          card.classList.toggle('is-visible', index < visibleCount);
        });

        if (progressLabel) {
          progressLabel.textContent = `${Math.min(visibleCount, cards.length)} / ${cards.length}`;
        }

        nextButton.textContent = visibleCount >= cards.length
          ? (nextButton.dataset.finishedLabel || 'Done')
          : 'Lanjut';
      };

      nextButton.addEventListener('click', () => {
        if (visibleCount < cards.length) {
          visibleCount += 1;
          syncState();
          return;
        }

        if (nextButton.dataset.finishUrl) {
          window.location.href = nextButton.dataset.finishUrl;
        }
      });

      syncState();
    })();
  </script>
</body>
</html>
