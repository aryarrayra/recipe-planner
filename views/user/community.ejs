<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const communitySearch = String(search || '').trim(); %>
  <% const currentUserId = String(user && user.id ? user.id : ''); %>
  <% const statsData = stats || { pending: 0, approved: 0, total: 0 }; %>
  <% const shouldOpenComposer = String(openComposer || '').trim() === '1' || String(openComposer || '').trim().toLowerCase() === 'true'; %>
  <% const communityComments = []; %>
  <% const communityPostsData = (Array.isArray(approvedRecipes) ? approvedRecipes : []).map((recipe) => ({
    id: recipe.id,
    communityPostId: recipe.communityPostId || recipe.postId || '',
    creatorUserId: recipe.creatorUserId || recipe.createdBy || recipe.created_by || '',
    title: recipe.title,
    description: recipe.description || recipe.title || '',
    imageUrl: recipe.imageUrl || '/images/1.png',
    cookingTime: recipe.cookingTime || 0,
    likesCount: Number(recipe.likesCount || 0),
    commentsCount: Number(recipe.commentsCount || 0),
    sharesCount: Number(recipe.sharesCount || 0),
    likedByMe: Boolean(recipe.likedByMe),
    category: recipe.category || 'recipe',
    cuisine: recipe.originPlace || recipe.cuisine || 'Community',
    creatorName: recipe.creatorName || 'Community user',
    createdAt: recipe.createdAt || null,
    commentCount: Array.isArray(recipe.comments) ? recipe.comments.length : 0,
    comments: Array.isArray(recipe.comments)
      ? recipe.comments.map((comment) => ({
          id: comment.id,
          content: comment.content,
          creatorName: comment.creatorName,
          createdAt: comment.createdAt,
          title: comment.title
        }))
      : []
  })); %>
  <% const formatRelativeTime = (value) => {
    if (!value) return 'baru saja';
    const created = new Date(value);
    if (Number.isNaN(created.getTime())) return 'baru saja';
    const diff = Date.now() - created.getTime();
    const minutes = Math.max(0, Math.floor(diff / 60000));
    if (minutes < 1) return 'baru saja';
    if (minutes < 60) return `${minutes}m`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}d`;
    return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
  }; %>
  <script type="application/json" id="communityPostsData"><%- JSON.stringify(communityPostsData).replace(/</g, '\\u003c') %></script>

  <main class="user-dashboard community-page">
    <div class="user-dashboard-shell community-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'community', user }) %>

      <section class="user-dashboard-main community-main">
        <header class="user-dashboard-topbar">
          <div class="user-topbar-copy">
            <p class="user-panel-kicker">Community kitchen</p>
            <h1>Bagikan resep seperti halaman buku masak</h1>
            <p class="user-dashboard-subcopy">
              Tampilan dibuat lebih mirip buku resep: cover besar, ringkasan bahan, dan langkah masak yang mudah dibaca. Daily dan weekly challenge tetap berjalan otomatis dari API.
            </p>
          </div>
          <div class="community-compose-shell">
            <button type="button" class="community-compose-launch" id="openCommunityComposerInlinePost">
              Post resep kamu
            </button>
          </div>
        </header>

        <% if (notice || error) { %>
          <div class="admin-banner <%= error ? 'is-error' : 'is-success' %>">
            <i class="fa-solid <%= error ? 'fa-triangle-exclamation' : 'fa-circle-check' %>" aria-hidden="true"></i>
            <span><%= error || notice %></span>
          </div>
        <% } %>

        <div class="community-layout">
          <section class="community-main-column">
            <% if (approvedRecipes.length) { %>
              <div class="community-feed-grid" id="community-feed">
                <% approvedRecipes.forEach((recipe) => { %>
                  <% const canDeletePost = String(recipe.creatorUserId || '') === currentUserId && String(recipe.communityPostId || recipe.id || '').trim(); %>
                  <article
                    class="community-tweet-card community-recipe-card"
                    data-post-id="<%= recipe.communityPostId || recipe.id %>"
                    data-post-url="/community/posts/<%= encodeURIComponent(recipe.communityPostId || recipe.id) %>"
                    data-creator-user-id="<%= recipe.creatorUserId || '' %>"
                  >
                    <div class="community-recipe-card-hero">
                      <img src="<%= recipe.imageUrl || '/images/1.png' %>" alt="<%= recipe.title %>" />
                    </div>
                    <div class="community-recipe-card-body">
                      <div class="community-recipe-card-author">
                        <img
                          src="<%= recipe.creatorAvatarUrl || `https://ui-avatars.com/api/?name=${encodeURIComponent(recipe.creatorName || 'Community user')}&background=0f1419&color=ffffff&bold=true` %>"
                          alt="<%= recipe.creatorName %>"
                        />
                        <div>
                          <strong><%= recipe.creatorName %></strong>
                        </div>
                      </div>
                      <h3 class="community-recipe-card-title"><%= recipe.title %></h3>
                      <% if (canDeletePost) { %>
                        <div class="community-recipe-card-actions">
                          <button
                            type="button"
                            class="community-recipe-card-report community-recipe-card-delete"
                            data-action="delete-post"
                            data-post-id="<%= recipe.communityPostId || recipe.id %>"
                          >
                            <i class="fa-regular fa-trash-can" aria-hidden="true"></i>
                            <span>Hapus</span>
                          </button>
                        </div>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              </div>
            <% } else { %>
              <div class="community-feed-empty">
                <strong>Belum ada postingan community</strong>
                <p>Kalau belum ada resep yang disetujui, area ini akan tampil kosong. Coba posting resep baru atau cek lagi setelah ada approval.</p>
              </div>
            <% } %>
          </section>
        </div>

        <div class="community-composer-overlay" id="communityComposerOverlay" hidden>
          <div class="community-composer-modal" role="dialog" aria-modal="true" aria-labelledby="communityComposerTitle">
            <div class="community-composer-head">
              <div>
                <p class="user-panel-kicker">Post resep</p>
                <h2 id="communityComposerTitle">Buat posting resep baru</h2>
              </div>
              <button type="button" class="community-composer-close" id="closeCommunityComposer" aria-label="Tutup">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>

            <form class="community-form" action="/community" method="post" enctype="multipart/form-data">
              <div class="community-form-grid">
                <label class="community-form-field">
                  <span>Judul resep</span>
                  <input type="text" name="title" required placeholder="Contoh: Ayam Goreng Bumbu Kuning" />
                </label>
                <label class="community-form-field community-form-field-wide community-upload-field">
                  <span>Foto resep</span>
                  <div class="community-upload-card">
                    <div class="community-upload-preview" id="communityRecipeImagePreview">
                      <img class="community-upload-preview-image" id="communityRecipeImagePreviewImg" alt="Preview foto resep" hidden />
                      <div class="community-upload-preview-empty" id="communityRecipeImagePreviewEmpty">
                        <i class="fa-regular fa-image"></i>
                        <strong>[Opsional] Foto Resep</strong>
                        <span>Tambahkan foto akhir masakan</span>
                      </div>
                    </div>
                    <div class="community-upload-controls">
                      <input type="file" name="image_file" accept="image/*" id="communityRecipeImageInput" />
                      <p>Setelah dipilih, foto akan tampil di preview.</p>
                    </div>
                  </div>
                </label>
                <label class="community-form-field">
                  <span>Cuisine</span>
                  <input type="text" name="cuisine" placeholder="Indonesia / Japanese / dll" />
                </label>
                <label class="community-form-field">
                  <span>Kategori</span>
                  <select name="category">
                    <option value="main course">Main course</option>
                    <option value="dessert">Dessert</option>
                    <option value="snack">Snack</option>
                    <option value="drink">Drink</option>
                    <option value="breakfast">Breakfast</option>
                    <option value="lunch">Lunch</option>
                    <option value="dinner">Dinner</option>
                    <option value="side dish">Side dish</option>
                    <option value="soup">Soup</option>
                  </select>
                </label>
                <label class="community-form-field">
                  <span>Waktu masak (menit)</span>
                  <input type="number" name="cooking_time" min="0" placeholder="30" />
                </label>
                <label class="community-form-field">
                  <span>Porsi</span>
                  <input type="number" name="servings" min="1" placeholder="2" />
                </label>
                <label class="community-form-field">
                  <span>Difficulty</span>
                  <select name="difficulty">
                    <option value="easy">Easy</option>
                    <option value="medium">Medium</option>
                    <option value="hard">Hard</option>
                  </select>
                </label>
                <label class="community-form-field">
                  <span>Perkiraan harga</span>
                  <input type="text" name="estimated_price" placeholder="25000" />
                </label>
                <label class="community-form-field community-form-field-wide">
                  <span>Video URL</span>
                  <input type="url" name="video_url" placeholder="https://..." />
                </label>
                <label class="community-form-field community-form-field-wide">
                  <span>Deskripsi</span>
                  <textarea name="description" rows="3" placeholder="Cerita singkat resep ini"></textarea>
                </label>
                <label class="community-form-field community-form-field-wide">
                  <span>Bahan</span>
                  <textarea name="ingredients" rows="5" required placeholder="Tulis per baris, misalnya:&#10;2 dada ayam&#10;1 sdt garam"></textarea>
                </label>
                <label class="community-form-field community-form-field-wide">
                  <span>Langkah</span>
                  <textarea name="steps" rows="5" required placeholder="Tulis per baris, misalnya:&#10;Panaskan wajan&#10;Tumis bumbu"></textarea>
                </label>
                <label class="community-form-field community-form-field-wide community-upload-field">
                  <span>Foto langkah (opsional)</span>
                  <div class="community-upload-card community-upload-card--compact">
                    <div class="community-upload-preview community-upload-preview--compact" id="communityStepsImagePreview">
                      <img class="community-upload-preview-image" id="communityStepsImagePreviewImg" alt="Preview foto langkah" hidden />
                      <div class="community-upload-preview-empty" id="communityStepsImagePreviewEmpty">
                        <i class="fa-regular fa-image"></i>
                        <strong>Foto langkah</strong>
                        <span>Opsional, untuk menampilkan visual langkah masak</span>
                      </div>
                    </div>
                    <div class="community-upload-controls">
                      <input type="file" name="steps_image_file" accept="image/*" id="communityStepsImageInput" />
                      <p>Preview akan muncul setelah memilih foto.</p>
                    </div>
                  </div>
                </label>
                <label class="community-form-field community-form-field-wide">
                  <span>Tags</span>
                  <textarea name="tags" rows="2" placeholder="pedas&#10;ayam&#10;rumahan"></textarea>
                </label>
              </div>

              <div class="community-form-actions">
                <button type="submit" class="auth-button">Post ke community</button>
                <p>Resep akan langsung tersimpan dan tampil di community.</p>
              </div>
            </form>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script>
    (() => {
      const postsDataNode = document.getElementById('communityPostsData');
      const communityPosts = postsDataNode ? JSON.parse(postsDataNode.textContent || '[]') : [];
      const postMap = new Map(communityPosts.map((post) => [String(post.communityPostId || post.id || ''), post]));
      const overlay = document.getElementById('communityComposerOverlay');
      const openButtons = [
        document.getElementById('openCommunityComposer'),
        document.getElementById('openCommunityComposerInline'),
        document.getElementById('openCommunityComposerInlinePost'),
        document.getElementById('openCommunityComposerSecondary'),
        document.getElementById('openCommunityComposerTertiary')
      ].filter(Boolean);
      const closeButton = document.getElementById('closeCommunityComposer');
      const modal = overlay ? overlay.querySelector('.community-composer-modal') : null;
      const feed = document.querySelector('.community-feed-grid');
      const detailOverlay = document.getElementById('communityDetailOverlay');
      const detailClose = document.getElementById('closeCommunityDetail');
      const detailAvatar = document.getElementById('communityDetailAvatar');
      const detailAuthor = document.getElementById('communityDetailAuthor');
      const detailHandle = document.getElementById('communityDetailHandle');
      const detailTime = document.getElementById('communityDetailTime');
      const detailTitle = document.getElementById('communityDetailTitle');
      const detailText = document.getElementById('communityDetailText');
      const detailImage = document.getElementById('communityDetailImage');
      const detailMeta = document.getElementById('communityDetailMeta');
      const detailCommentsList = document.getElementById('communityDetailCommentsList');
      const detailCommentState = document.getElementById('communityDetailCommentState');
      const detailLikeButton = document.getElementById('communityDetailLikeButton');
      const detailCommentButton = document.getElementById('communityDetailCommentButton');
      const detailReplyForm = document.getElementById('communityDetailReplyForm');
      const detailReplyInput = document.getElementById('communityDetailReplyInput');
      const detailLikeCount = document.getElementById('communityDetailLikeCount');
      const detailCommentCount = document.getElementById('communityDetailCommentCount');
      const recipeImageInput = document.getElementById('communityRecipeImageInput');
      const recipePreviewImage = document.getElementById('communityRecipeImagePreviewImg');
      const recipePreviewEmpty = document.getElementById('communityRecipeImagePreviewEmpty');
      const stepsImageInput = document.getElementById('communityStepsImageInput');
      const stepsPreviewImage = document.getElementById('communityStepsImagePreviewImg');
      const stepsPreviewEmpty = document.getElementById('communityStepsImagePreviewEmpty');

      let activePostId = '';
      let activePost = null;
      let recipePreviewObjectUrl = '';
      let stepsPreviewObjectUrl = '';

      function escapeHtml(value) {
        return String(value || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function formatRelativeTime(value) {
        if (!value) return 'baru saja';
        const created = new Date(value);
        if (Number.isNaN(created.getTime())) return 'baru saja';
        const diff = Date.now() - created.getTime();
        const minutes = Math.max(0, Math.floor(diff / 60000));
        if (minutes < 1) return 'baru saja';
        if (minutes < 60) return `${minutes}m`;
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return `${hours}h`;
        const days = Math.floor(hours / 24);
        if (days < 7) return `${days}d`;
        return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
      }

      function renderCommentItem(comment) {
        const avatarUrl = comment.creatorAvatarUrl || `https://ui-avatars.com/api/?name=${encodeURIComponent(comment.creatorName || 'Community user')}&background=0f1419&color=ffffff&bold=true`;
        return `
          <article class="community-detail-comment">
            <div class="community-detail-comment-avatar">
              <img src="${avatarUrl}" alt="${escapeHtml(comment.creatorName || 'Community user')}" />
            </div>
            <div class="community-detail-comment-body">
              <div class="community-detail-comment-head">
                <strong>${escapeHtml(comment.creatorName || 'Community user')}</strong>
                <span>&bull; ${escapeHtml(formatRelativeTime(comment.createdAt))}</span>
              </div>
              <p>${escapeHtml(comment.content || '')}</p>
            </div>
          </article>
        `;
      }

      function setDetailVisible(visible) {
        if (!detailOverlay) return;
        detailOverlay.hidden = !visible;
        document.body.classList.toggle('community-detail-open', visible);
      }

      function setUploadPreview(input, previewImage, previewEmpty, previousObjectUrlRef) {
        const file = input && input.files && input.files[0] ? input.files[0] : null;
        if (previousObjectUrlRef.value) {
          URL.revokeObjectURL(previousObjectUrlRef.value);
          previousObjectUrlRef.value = '';
        }

        if (!file) {
          previewImage.hidden = true;
          previewImage.removeAttribute('src');
          previewEmpty.hidden = false;
          return;
        }

        const objectUrl = URL.createObjectURL(file);
        previousObjectUrlRef.value = objectUrl;
        previewImage.src = objectUrl;
        previewImage.hidden = false;
        previewEmpty.hidden = true;
      }

      function renderDetail(post) {
        if (!post) return;

        activePost = post;
        activePostId = String(post.communityPostId || post.id || '');
        const avatarUrl = post.creatorAvatarUrl || `https://ui-avatars.com/api/?name=${encodeURIComponent(post.creatorName || 'Community user')}&background=0f1419&color=ffffff&bold=true`;
        const postComments = Array.isArray(post.comments) ? post.comments : [];
        const mediaUrl = post.imageUrl || '/images/1.png';
        const cuisineText = post.originPlace || post.cuisine || 'Community';
        const categoryText = post.category || 'recipe';

        if (detailAvatar) detailAvatar.src = avatarUrl;
        if (detailAuthor) detailAuthor.textContent = post.creatorName || 'Community user';
        if (detailTime) detailTime.textContent = `• ${formatRelativeTime(post.createdAt)}`;
        if (detailTitle) detailTitle.textContent = post.title || 'Postingan community';
        if (detailText) detailText.textContent = post.description || post.title || '';
        if (detailImage) {
          detailImage.src = mediaUrl;
          detailImage.alt = post.title || 'Gambar resep';
        }
        if (detailMeta) {
          detailMeta.innerHTML = `
            <span><i class="fa-solid fa-layer-group"></i> ${escapeHtml(categoryText)} / ${escapeHtml(cuisineText)}</span>
            <span><i class="fa-regular fa-clock"></i> ${escapeHtml(String(post.cookingTime || 0))} min</span>
            <span><i class="fa-solid fa-wallet"></i> Rp ${escapeHtml(String(post.estimatedPrice || 0).replace(/\B(?=(\d{3})+(?!\d))/g, '.'))}</span>
          `;
        }
        if (detailLikeCount) detailLikeCount.textContent = String(post.likesCount || 0);
        if (detailCommentCount) detailCommentCount.textContent = String(post.commentsCount || postComments.length || 0);
        if (detailCommentState) detailCommentState.textContent = postComments.length ? `${postComments.length} balasan` : 'Belum ada komentar';
        if (detailLikeButton) {
          detailLikeButton.classList.toggle('is-liked', Boolean(post.likedByMe));
          detailLikeButton.disabled = Boolean(post.likedByMe);
        }
        if (detailCommentsList) {
          detailCommentsList.innerHTML = postComments.length
            ? postComments.map(renderCommentItem).join('')
            : `
              <div class="community-detail-empty">
                <p>Belum ada komentar untuk postingan ini.</p>
              </div>
            `;
        }

        setDetailVisible(true);
      }

      async function fetchPostDetail(postId) {
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}`, {
          headers: { Accept: 'application/json' }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal memuat detail postingan');
        }
        return data.data;
      }

      async function sendLike(postId) {
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/like`, {
          method: 'POST',
          headers: { Accept: 'application/json' }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal menyukai postingan');
        }
        return data;
      }

      async function sendComment(postId, content) {
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/comments`, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          },
          body: new URLSearchParams({ content })
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal mengirim komentar');
        }
        return data.comment;
      }

      async function deletePost(postId) {
        const response = await fetch(`/community/posts/${encodeURIComponent(postId)}/delete`, {
          method: 'POST',
          headers: { Accept: 'application/json' }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Gagal menghapus postingan');
        }
        return data;
      }

      const openComposer = () => {
        window.location.href = '/community/new';
      };

      const closeComposer = () => {
        if (!overlay) return;
        overlay.hidden = true;
        document.body.classList.remove('community-composer-open');
      };

      openButtons.forEach((button) => button.addEventListener('click', openComposer));
      closeButton?.addEventListener('click', closeComposer);

      recipeImageInput?.addEventListener('change', () => {
        setUploadPreview(
          recipeImageInput,
          recipePreviewImage,
          recipePreviewEmpty,
          {
            get value() {
              return recipePreviewObjectUrl;
            },
            set value(nextValue) {
              recipePreviewObjectUrl = nextValue;
            }
          }
        );
      });

      stepsImageInput?.addEventListener('change', () => {
        setUploadPreview(
          stepsImageInput,
          stepsPreviewImage,
          stepsPreviewEmpty,
          {
            get value() {
              return stepsPreviewObjectUrl;
            },
            set value(nextValue) {
              stepsPreviewObjectUrl = nextValue;
            }
          }
        );
      });

      overlay?.addEventListener('click', (event) => {
        if (event.target === overlay) {
          closeComposer();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') {
          return;
        }

        if (!detailOverlay?.hidden) {
          setDetailVisible(false);
          return;
        }

        if (!overlay?.hidden) {
          closeComposer();
        }
      });

      modal?.addEventListener('click', (event) => {
        event.stopPropagation();
      });

      feed?.addEventListener('click', async (event) => {
        const likeButton = event.target.closest('[data-action="like"]');
        const deleteButton = event.target.closest('[data-action="delete-post"]');
        const card = event.target.closest('.community-recipe-card') || event.target.closest('.community-tweet-card');

        if (!card) {
          return;
        }

        const postId = card.getAttribute('data-post-id') || '';
        if (!postId) {
          return;
        }

        if (likeButton) {
          event.preventDefault();
          event.stopPropagation();

          try {
            const likesCount = await sendLike(postId);
            const likeCountNode = likeButton.querySelector('span') || likeButton;
            if (likeCountNode) {
              likeCountNode.textContent = String(likesCount.likesCount || 0);
            }
            likeButton.classList.add('is-liked');
            likeButton.disabled = true;
            const cached = postMap.get(postId);
            if (cached) {
              cached.likesCount = likesCount.likesCount || cached.likesCount || 0;
              cached.likedByMe = true;
              postMap.set(postId, cached);
            }
            if (activePostId === postId && detailLikeCount) {
              detailLikeCount.textContent = String(likesCount.likesCount || 0);
              if (detailLikeButton) {
                detailLikeButton.classList.add('is-liked');
                detailLikeButton.disabled = true;
              }
            }
            if (likesCount.likedAlready) {
              window.alert('Kamu sudah menyukai postingan ini.');
            }
          } catch (error) {
            window.alert(error.message || 'Gagal menyukai postingan');
          }
          return;
        }

        if (deleteButton) {
          event.preventDefault();
          event.stopPropagation();

          const targetPostId = deleteButton.getAttribute('data-post-id') || postId;
          if (!targetPostId) {
            return;
          }

          const confirmed = window.confirm('Hapus postingan ini? Aksi ini tidak bisa dibatalkan.');
          if (!confirmed) {
            return;
          }

          deleteButton.disabled = true;
          try {
            await deletePost(targetPostId);
            window.location.href = '/community?notice=Postingan+berhasil+dihapus';
          } catch (error) {
            deleteButton.disabled = false;
            window.alert(error.message || 'Gagal menghapus postingan');
          }
          return;
        }

        if (event.target.closest('a, button')) {
          return;
        }

        const url = card.getAttribute('data-post-url');
        if (url) {
          window.location.href = url;
        }
      });

      if (shouldOpenComposer) {
        openComposer();
      }
    })();
  </script>
</body>
</html>
