<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/confirm-dialog.js"></script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const data = shoppingListData || { favoriteRecipes: [], ingredients: [], sections: { sayur: [], protein: [], bumbu: [], dairy: [], karbohidrat: [], saus: [], alat: [], lainnya: [] }, estimatedBudget: 0, totalRecipes: 0, totalIngredients: 0, budgetTarget: null, budgetDelta: null }; %>
  <% const budgetInput = data.budgetTarget !== null ? Number(data.budgetTarget).toLocaleString('id-ID') : ''; %>

  <main class="user-dashboard user-shopping-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'shopping-list', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar">
          <div class="user-feed-topline">
            <p class="user-panel-kicker">Shopping list</p>
            <h1>Rekap bahan dan budget</h1>
          </div>

          <div class="user-topbar-actions">
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <section class="user-panel user-panel-hero">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">Ringkasan</p>
              <h2>Belanja dari resep favorit lebih rapi</h2>
            </div>
          </div>

          <form class="shopping-budget-bar" action="/shopping-list" method="get">
              <label class="shopping-budget-field">
                <span>Budget belanja</span>
                <input
                  type="text"
                  name="budget"
                  inputmode="numeric"
                  value="<%= budgetInput %>"
                  placeholder="Contoh: 50000"
                />
              <small>Isi nominal budget untuk membandingkan estimasi belanja.</small>
              </label>
              <button type="submit" class="auth-button">Simpan budget</button>
            </form>

          <div class="user-dashboard-stats">
            <article class="user-stat-card">
              <i class="fa-solid fa-heart" aria-hidden="true"></i>
              <strong><%= data.totalRecipes %> resep dipilih</strong>
              <span>Sumber bahan yang dipakai untuk shopping list ini</span>
            </article>
            <article class="user-stat-card">
              <i class="fa-solid fa-basket-shopping" aria-hidden="true"></i>
              <strong><%= data.totalIngredients %> item unik</strong>
              <span>Daftar bahan, bumbu, alat, dan item lain yang perlu dicek</span>
            </article>
            <article class="user-stat-card">
              <i class="fa-solid fa-coins" aria-hidden="true"></i>
              <strong>Rp <%= formatPrice(data.estimatedBudget) %></strong>
              <span>Perkiraan belanja dari resep yang masuk ke shopping list</span>
            </article>
          </div>

          <% if (data.budgetTarget !== null) { %>
            <div class="shopping-budget-result <%= data.budgetDelta >= 0 ? 'is-safe' : 'is-over' %>">
              <strong>
                <% if (data.budgetDelta >= 0) { %>
                  Sisa budget Rp <%= formatPrice(data.budgetDelta) %>
                <% } else { %>
                  Over budget Rp <%= formatPrice(Math.abs(data.budgetDelta)) %>
                <% } %>
              </strong>
              <span>
                Budget kamu: Rp <%= formatPrice(data.budgetTarget) %> &middot; Perkiraan belanja: Rp <%= formatPrice(data.estimatedBudget) %>
              </span>
            </div>
          <% } %>
        </section>

        <div class="user-feed-layout user-shopping-layout">
          <section class="user-feed-column">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Shopping list</p>
                  <h2>Daftar bahan gabungan</h2>
                </div>
              </div>

              <% const shoppingSections = data.sections || { sayur: [], protein: [], bumbu: [], dairy: [], karbohidrat: [], saus: [], alat: [], lainnya: [] }; %>

              <% if (data.totalIngredients) { %>
                <div class="shopping-sections">
                  <% [
                    { key: 'sayur', title: 'Sayur', icon: 'fa-seedling', empty: 'Belum ada sayur.' },
                    { key: 'protein', title: 'Protein', icon: 'fa-drumstick-bite', empty: 'Belum ada protein.' },
                    { key: 'bumbu', title: 'Bumbu', icon: 'fa-pepper-hot', empty: 'Belum ada bumbu.' },
                    { key: 'dairy', title: 'Dairy', icon: 'fa-cheese', empty: 'Belum ada dairy.' },
                    { key: 'karbohidrat', title: 'Karbohidrat', icon: 'fa-bowl-rice', empty: 'Belum ada karbohidrat.' },
                    { key: 'saus', title: 'Saus & pelengkap', icon: 'fa-bottle-droplet', empty: 'Belum ada saus atau pelengkap.' },
                    { key: 'alat', title: 'Alat', icon: 'fa-kitchen-set', empty: 'Belum ada alat.' },
                    { key: 'lainnya', title: 'Lainnya', icon: 'fa-circle-dot', empty: 'Belum ada item lain.' }
                  ].forEach((group) => { %>
                    <section class="shopping-section">
                      <div class="user-panel-head shopping-section-head">
                        <div>
                          <p class="user-panel-kicker"><i class="fa-solid <%= group.icon %>"></i> <%= group.title %></p>
                          <h3><%= (shoppingSections[group.key] || []).length %> item</h3>
                        </div>
                      </div>

                      <% if ((shoppingSections[group.key] || []).length) { %>
                        <div class="shopping-list-grid">
                          <% (shoppingSections[group.key] || []).forEach((item) => { %>
                            <label class="shopping-item shopping-item-<%= group.key %> <%= item.checked ? 'is-checked' : '' %>">
                              <input
                                type="checkbox"
                                data-item-key="<%= item.key %>"
                                data-item-name="<%= item.name %>"
                                data-item-unit="<%= item.unit || '' %>"
                                data-item-category="<%= item.category || group.key %>"
                                <%= item.checked ? 'checked' : '' %>
                              />
                              <span class="shopping-item-copy">
                                <strong><%= item.displayQuantity ? `${item.displayQuantity}${item.unit ? ` ${item.unit}` : ''}` : 'Secukupnya' %></strong>
                                <span><%= item.name %></span>
                                <small><%= item.recipes.length %> resep • <%= item.recipes.join(', ') %></small>
                              </span>
                            </label>
                          <% }) %>
                        </div>
                      <% } else { %>
                        <div class="shopping-empty-inline"><%= group.empty %></div>
                      <% } %>
                    </section>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="user-empty-state">
                  <i class="fa-regular fa-list-check"></i>
                  <p>Belum ada resep di shopping list. Tambahkan dulu dari halaman detail resep.</p>
                </div>
              <% } %>
            </article>
          </section>

          <aside class="user-feed-sidebar">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Selected recipes</p>
                  <h2>Resep sumber belanja</h2>
                </div>
              </div>

              <div class="user-card-grid user-shopping-card-grid">
                <% data.favoriteRecipes.forEach((recipe) => { %>
                  <article class="user-mini-recipe-card shopping-recipe-card">
                    <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                    <div class="user-mini-recipe-copy">
                      <h3><%= recipe.title %></h3>
                      <p><%= recipe.category %></p>
                      <small>Perkiraan Rp <%= formatPrice(recipe.estimatedPrice) %> - <%= recipe.desiredServings %> porsi</small>
                      <div class="shopping-recipe-actions">
                        <a class="shopping-recipe-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.source === 'community' ? recipe.sourceId : (recipe.recipeKey || recipe.id)) %>">Buka resep</a>
                        <button type="button" class="shopping-recipe-remove" data-recipe-key="<%= recipe.recipeKey || recipe.id %>">Hapus</button>
                      </div>
                    </div>
                  </article>
                <% }) %>

                <% if (!data.favoriteRecipes.length) { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-heart"></i>
                    <p>Resep yang ditambahkan lewat tombol Add to Shopping List akan muncul di sini.</p>
                  </div>
                <% } %>
              </div>
            </article>

            <article class="user-panel user-ai-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Catatan</p>
                  <h2>Perkiraan belanja, bukan harga pasti</h2>
                </div>
              </div>

              <p class="user-ai-copy">
                Total budget di atas masih estimasi. Quantity otomatis digabung jika bahan yang sama muncul dari beberapa resep.
              </p>

              <div class="user-ai-actions">
                <a class="auth-button auth-button-secondary" href="/chat-ai">Tanya AI soal budget</a>
              </div>
            </article>
          </aside>
        </div>
      </section>
    </div>
  </main>
  <script>
    (() => {
      const syncCheckedStyle = (checkbox) => {
        const wrapper = checkbox.closest('.shopping-item');
        if (wrapper) {
          wrapper.classList.toggle('is-checked', checkbox.checked);
        }
      };

      document.querySelectorAll('.shopping-item input[type="checkbox"]').forEach((checkbox) => {
        syncCheckedStyle(checkbox);
        checkbox.addEventListener('change', async () => {
          try {
            const response = await fetch(`/api/recipes/shopping-list/items/${encodeURIComponent(checkbox.dataset.itemKey || '')}`, {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                checked: checkbox.checked,
                itemName: checkbox.dataset.itemName,
                unit: checkbox.dataset.itemUnit,
                category: checkbox.dataset.itemCategory
              })
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal memperbarui checklist.');
            }

            syncCheckedStyle(checkbox);
          } catch (error) {
            console.error(error);
            checkbox.checked = !checkbox.checked;
            syncCheckedStyle(checkbox);
            alert(error.message || 'Gagal memperbarui checklist.');
          }
        });
      });

      document.querySelectorAll('.shopping-recipe-remove').forEach((button) => {
        button.addEventListener('click', async () => {
          const recipeKey = button.dataset.recipeKey;
          if (!recipeKey) {
            return;
          }

          const confirmed = await window.confirmDanger(
            `Apakah yakin anda menghapus "${button.closest('.shopping-recipe-card')?.querySelector('h3')?.textContent || 'resep ini'}" dari shopping list?`,
            {
              title: 'Hapus dari shopping list',
              confirmButtonText: 'Ya, hapus'
            }
          );
          if (!confirmed) {
            return;
          }

          try {
            button.disabled = true;
            const response = await fetch(`/api/recipes/shopping-list/recipes/${encodeURIComponent(recipeKey)}`, {
              method: 'DELETE'
            });
            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal menghapus resep dari shopping list.');
            }

            window.location.reload();
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal menghapus resep dari shopping list.');
            button.disabled = false;
          }
        });
      });
    })();
  </script>
</body>
</html>
