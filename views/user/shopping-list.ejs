<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/confirm-dialog.js"></script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const data = shoppingListData || { favoriteRecipes: [], ingredients: [], sections: { sayur: [], protein: [], bumbu: [], dairy: [], karbohidrat: [], saus: [], alat: [], lainnya: [] }, totalRecipes: 0, totalIngredients: 0, manualBudget: 0 }; %>

  <main class="user-dashboard user-shopping-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'shopping-list', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar">
          <div class="user-feed-topline">
            <p class="user-panel-kicker">Daftar belanja</p>
            <h1>Rekap bahan belanja</h1>
          </div>

        </header>

        <section class="user-panel user-panel-hero">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">Ringkasan</p>
              <h2>Belanja dari resep favorit lebih rapi</h2>
            </div>
          </div>

          <div class="shopping-budget-display">
            <p class="shopping-budget-label">Anggaran minimal</p>
            <strong class="shopping-budget-value">Rp <%= formatPrice(data.manualBudget) %></strong>
            <span class="shopping-budget-copy">
              Anggaran ini hanya dihitung dari item yang kamu isi harganya sendiri. Item yang dikosongkan tidak ikut dihitung.
            </span>
          </div>

          <div class="user-dashboard-stats">
            <article class="user-stat-card">
              <i class="fa-solid fa-heart" aria-hidden="true"></i>
              <strong><%= data.totalRecipes %> resep dipilih</strong>
              <span>Sumber bahan yang dipakai untuk daftar belanja ini</span>
            </article>
            <article class="user-stat-card">
              <i class="fa-solid fa-basket-shopping" aria-hidden="true"></i>
              <strong><%= data.totalIngredients %> item unik</strong>
              <span>Daftar bahan, bumbu, alat, dan item lain yang perlu dicek</span>
            </article>
          </div>

        </section>

        <div class="user-feed-layout user-shopping-layout">
          <section class="user-feed-column">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Daftar belanja</p>
                  <h2>Daftar bahan gabungan</h2>
                </div>
              </div>

              <% const shoppingSections = data.sections || { sayur: [], protein: [], bumbu: [], dairy: [], karbohidrat: [], saus: [], alat: [], lainnya: [] }; %>

              <% if (data.totalIngredients) { %>
                <div class="shopping-sections">
                  <% [
                    { key: 'sayur', title: 'Sayur', icon: 'fa-seedling', empty: 'Belum ada sayur.' },
                    { key: 'protein', title: 'Protein', icon: 'fa-drumstick-bite', empty: 'Belum ada protein.' },
                    { key: 'bumbu', title: 'Bumbu', icon: 'fa-pepper-hot', empty: 'Belum ada bumbu.' },
                    { key: 'dairy', title: 'Produk susu', icon: 'fa-cheese', empty: 'Belum ada produk susu.' },
                    { key: 'karbohidrat', title: 'Karbohidrat', icon: 'fa-bowl-rice', empty: 'Belum ada karbohidrat.' },
                    { key: 'saus', title: 'Saus & pelengkap', icon: 'fa-bottle-droplet', empty: 'Belum ada saus atau pelengkap.' },
                    { key: 'alat', title: 'Alat', icon: 'fa-kitchen-set', empty: 'Belum ada alat.' },
                    { key: 'lainnya', title: 'Lainnya', icon: 'fa-circle-dot', empty: 'Belum ada item lain.' }
                  ].forEach((group) => { %>
                    <section class="shopping-section-shell">
                      <details class="shopping-section">
                        <summary class="user-panel-head shopping-section-head shopping-section-toggle">
                          <div>
                            <p class="user-panel-kicker"><i class="fa-solid <%= group.icon %>"></i> <%= group.title %></p>
                            <h3><%= (shoppingSections[group.key] || []).length %> item</h3>
                          </div>
                          <span class="shopping-section-toggle-icon" aria-hidden="true">
                            <i class="fa-solid fa-chevron-down"></i>
                          </span>
                        </summary>

                        <div class="shopping-section-drawer">
                          <div class="shopping-section-drawer-inner">
                            <form class="shopping-section-form" data-shopping-section-form="<%= group.key %>">
                            <input type="hidden" name="category" value="<%= group.key %>" />
                            <label class="shopping-section-form-field shopping-section-form-field-wide">
                              <span>Nama item</span>
                              <input type="text" name="itemName" placeholder="Contoh: <%= group.title %>" required />
                            </label>
                            <label class="shopping-section-form-field">
                              <span>Kuantitas / satuan</span>
                              <input type="text" name="quantity" placeholder="Contoh: 1 kg / 2 pcs" />
                            </label>
                            <label class="shopping-section-form-field">
                              <span>Harga item</span>
                              <input type="text" name="estimatedPrice" inputmode="numeric" placeholder="Opsional" />
                            </label>
                            <div class="shopping-section-form-actions">
                              <button type="submit" class="auth-button shopping-manual-submit">Tambah item</button>
                              <button type="button" class="shopping-section-cancel" data-section-cancel="<%= group.key %>">Batal</button>
                            </div>
                            </form>
                          </div>
                        </div>
                      </details>

                      <div class="shopping-section-body">
                        <% if ((shoppingSections[group.key] || []).length) { %>
                          <div class="shopping-list-grid">
                            <% (shoppingSections[group.key] || []).forEach((item) => { %>
                              <% const itemQuantityText = item.displayQuantity || item.quantityText || 'Secukupnya'; %>

                              <% if (item.source === 'manual') { %>
                                <div class="shopping-item shopping-item-<%= group.key %> shopping-item-manual <%= item.checked ? 'is-checked' : '' %>">
                                  <input
                                    type="checkbox"
                                    data-item-key="<%= item.key %>"
                                    data-item-name="<%= item.name %>"
                                    data-item-unit="<%= item.unit || '' %>"
                                    data-item-category="<%= item.category || group.key %>"
                                    data-item-source="manual"
                                    data-item-quantity="<%= item.quantityText || '' %>"
                                    data-item-estimated-price="<%= item.estimatedPrice || 0 %>"
                                    <%= item.checked ? 'checked' : '' %>
                                  />
                                  <span class="shopping-item-copy">
                                    <strong><%= itemQuantityText %></strong>
                                    <span><%= item.name %></span>
                                    <small>Item manual</small>
                                  </span>
                                  <button
                                    type="button"
                                    class="shopping-item-remove shopping-item-remove-manual"
                                    data-manual-item-key="<%= item.key %>"
                                    aria-label="Hapus <%= item.name %>"
                                  >
                                    Hapus
                                  </button>
                                </div>
                              <% } else { %>
                                <label class="shopping-item shopping-item-<%= group.key %> <%= item.checked ? 'is-checked' : '' %>">
                                  <input
                                    type="checkbox"
                                    data-item-key="<%= item.key %>"
                                    data-item-name="<%= item.name %>"
                                    data-item-unit="<%= item.unit || '' %>"
                                    data-item-category="<%= item.category || group.key %>"
                                    data-item-source="recipe"
                                    <%= item.checked ? 'checked' : '' %>
                                  />
                                  <span class="shopping-item-copy">
                                    <strong><%= itemQuantityText %></strong>
                                    <span><%= item.name %></span>
                                    <small><%= item.recipes.length %> resep ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢ <%= item.recipes.join(', ') %></small>
                                  </span>
                                </label>
                              <% } %>
                            <% }) %>
                          </div>
                        <% } else { %>
                          <div class="shopping-section-empty-wrap">
                            <div class="shopping-empty-inline"><%= group.empty %></div>
                          </div>
                        <% } %>
                      </div>
                    </section>
                  <% }) %>
                </div>
              <% } else { %>
                <div class="user-empty-state">
                  <i class="fa-regular fa-list-check"></i>
                  <p>Belum ada item di shopping list. Tambahkan dari detail resep atau isi form manual di atas.</p>
                </div>
              <% } %>
            </article>
          </section>

          <aside class="user-feed-sidebar">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Resep terpilih</p>
                  <h2>Resep sumber belanja</h2>
                </div>
              </div>

              <div class="user-card-grid user-shopping-card-grid">
                <% data.favoriteRecipes.forEach((recipe) => { %>
                  <article class="user-mini-recipe-card shopping-recipe-card">
                    <img src="<%= recipe.imageUrl %>" alt="<%= recipe.title %>" />
                    <div class="user-mini-recipe-copy">
                      <h3><%= recipe.title %></h3>
                      <p><%= recipe.category %></p>
                      <small><%= recipe.desiredServings %> porsi</small>
                      <div class="shopping-recipe-actions">
                        <a class="shopping-recipe-link" href="/recipe-detail?recipeId=<%= encodeURIComponent(recipe.source === 'community' ? recipe.sourceId : (recipe.recipeKey || recipe.id)) %>">Buka resep</a>
                        <button type="button" class="shopping-recipe-remove" data-recipe-key="<%= recipe.recipeKey || recipe.id %>">Hapus</button>
                      </div>
                    </div>
                  </article>
                <% }) %>

                <% if (!data.favoriteRecipes.length) { %>
                  <div class="user-empty-state">
                    <i class="fa-regular fa-heart"></i>
                    <p>Resep yang ditambahkan lewat tombol Tambah ke daftar belanja akan muncul di sini.</p>
                  </div>
                <% } %>
              </div>
            </article>

            <article class="user-panel user-ai-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Catatan</p>
                  <h2>Daftar belanja dengan budget minimal</h2>
                </div>
              </div>

              <p class="user-ai-copy">
                Daftar ini tetap fokus ke item, kuantitas, dan checklist. Nominal harga tidak muncul per item, tapi total budget minimal tetap bisa dihitung dari harga yang kamu isi sendiri.
              </p>
            </article>
          </aside>
        </div>
      </section>
    </div>
  </main>
  <script>
    (() => {
      const syncCheckedStyle = (checkbox) => {
        const wrapper = checkbox.closest('.shopping-item');
        if (wrapper) {
          wrapper.classList.toggle('is-checked', checkbox.checked);
        }
      };

      const submitManualItem = async (form) => {
        const formData = new FormData(form);
        const payload = {
          itemName: String(formData.get('itemName') || '').trim(),
          category: String(formData.get('category') || 'lainnya').trim() || 'lainnya',
          quantity: String(formData.get('quantity') || '').trim(),
          estimatedPrice: String(formData.get('estimatedPrice') || '').replace(/[^\d]/g, '')
        };

        const response = await fetch('/api/recipes/shopping-list/manual-items', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Gagal menambahkan item manual.');
        }

        window.location.reload();
      };

      const bindManualForm = (form) => {
        if (!form) {
          return;
        }

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const submitButton = form.querySelector('button[type="submit"]');
          try {
            submitButton.disabled = true;
            await submitManualItem(form);
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal menambahkan item manual.');
          } finally {
            submitButton.disabled = false;
          }
        });
      };

      document.querySelectorAll('.shopping-section-form').forEach((form) => {
        bindManualForm(form);
      });

      document.querySelectorAll('.shopping-item input[type="checkbox"]').forEach((checkbox) => {
        syncCheckedStyle(checkbox);
        checkbox.addEventListener('change', async () => {
          try {
            const response = await fetch(`/api/recipes/shopping-list/items/${encodeURIComponent(checkbox.dataset.itemKey || '')}`, {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({
                checked: checkbox.checked,
                itemName: checkbox.dataset.itemName,
                unit: checkbox.dataset.itemUnit,
                category: checkbox.dataset.itemCategory,
                quantity: checkbox.dataset.itemQuantity,
                estimatedPrice: checkbox.dataset.itemEstimatedPrice || 0
              })
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal memperbarui checklist.');
            }

            syncCheckedStyle(checkbox);
          } catch (error) {
            console.error(error);
            checkbox.checked = !checkbox.checked;
            syncCheckedStyle(checkbox);
            alert(error.message || 'Gagal memperbarui checklist.');
          }
        });
      });

      document.querySelectorAll('[data-section-cancel]').forEach((button) => {
        button.addEventListener('click', () => {
          const sectionKey = button.dataset.sectionCancel;
          const form = document.querySelector(`[data-shopping-section-form="${CSS.escape(sectionKey)}"]`);
          const details = button.closest('details.shopping-section');
          if (!form || !details) {
            return;
          }

          form.reset();
          details.open = false;
        });
      });

      document.querySelectorAll('.shopping-item-remove-manual').forEach((button) => {
        button.addEventListener('click', async () => {
          const itemKey = button.dataset.manualItemKey;
          if (!itemKey) {
            return;
          }

          const itemName = button.closest('.shopping-item')?.querySelector('.shopping-item-copy span')?.textContent || 'item ini';
          const confirmed = await window.confirmDanger(
            `Apakah yakin anda menghapus "${itemName}" dari shopping list?`,
            {
              title: 'Hapus item manual',
              confirmButtonText: 'Ya, hapus'
            }
          );

          if (!confirmed) {
            return;
          }

          try {
            button.disabled = true;
            const response = await fetch(`/api/recipes/shopping-list/manual-items/${encodeURIComponent(itemKey)}`, {
              method: 'DELETE'
            });

            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal menghapus item manual.');
            }

            window.location.reload();
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal menghapus item manual.');
            button.disabled = false;
          }
        });
      });

      document.querySelectorAll('.shopping-recipe-remove').forEach((button) => {
        button.addEventListener('click', async () => {
          const recipeKey = button.dataset.recipeKey;
          if (!recipeKey) {
            return;
          }

          const confirmed = await window.confirmDanger(
            `Apakah yakin anda menghapus "${button.closest('.shopping-recipe-card')?.querySelector('h3')?.textContent || 'resep ini'}" dari shopping list?`,
            {
              title: 'Hapus dari shopping list',
              confirmButtonText: 'Ya, hapus'
            }
          );
          if (!confirmed) {
            return;
          }

          try {
            button.disabled = true;
            const response = await fetch(`/api/recipes/shopping-list/recipes/${encodeURIComponent(recipeKey)}`, {
              method: 'DELETE'
            });
            const result = await response.json();
            if (!response.ok || !result.success) {
              throw new Error(result.error || 'Gagal menghapus resep dari shopping list.');
            }

            window.location.reload();
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal menghapus resep dari shopping list.');
            button.disabled = false;
          }
        });
      });
    })();
  </script>
</body>
</html>
