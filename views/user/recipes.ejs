<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const formatPrice = (value) => new Intl.NumberFormat('id-ID').format(Number(value || 0)); %>
  <% const serializedRecipes = JSON.stringify(recipes || []).replace(/</g, '\\u003c'); %>
  <% const activeRecipeDetailUrl = activeRecipe ? `/recipe-detail?feed=${encodeURIComponent(feed || 'random')}&recipeId=${encodeURIComponent(activeRecipe.id)}` : '/recipe-detail'; %>

  <main class="user-dashboard user-feed-page user-fyp-page">
    <div class="user-dashboard-shell">
      <%- include('../partials/sidebar', { mode: 'user', activePage: 'fyp', user }) %>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar">
          <div class="user-feed-topline">
            <p class="user-panel-kicker">Untukmu</p>
            <h1><%= feedPreset.title %></h1>
          </div>

          <div class="user-topbar-actions">
            <a class="auth-button auth-button-secondary" href="/shopping-list">
              Daftar Belanja
            </a>
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <div class="user-fyp-layout">
          <section class="user-fyp-main">
            <% if (activeRecipe) { %>
              <article class="user-panel user-fyp-feature">
                <div class="user-panel-head user-fyp-feature-head">
                  <div>
                    <p class="user-panel-kicker"><%= activeRecipe.originPlace || activeRecipe.cuisine %> &bull; <%= activeRecipe.category %></p>
                    <h1><%= activeRecipe.title %></h1>
                  </div>
                  <div class="user-fyp-author">
                    <span>Dibuat oleh <strong><%= activeRecipe.creatorName %></strong></span>
                  </div>
                </div>

                <% if (activeRecipe.warning) { %>
                  <div class="recipe-warning-badge recipe-warning-panel">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span><%= activeRecipe.warning %></span>
                  </div>
                <% } %>

                <div class="user-recipe-detail-grid user-fyp-detail-grid">
                  <div class="user-recipe-visual">
                    <% if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'youtube') { %>
                      <iframe
                        src="<%= activeRecipe.videoSource.src %>?autoplay=1&mute=1"
                        title="<%= activeRecipe.title %>"
                        allow="autoplay; encrypted-media; picture-in-picture"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    <% } else if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'direct' && activeRecipe.videoSource.src) { %>
                      <video controls poster="<%= activeRecipe.imageUrl %>">
                        <source src="<%= activeRecipe.videoSource.src %>" />
                      </video>
                    <% } else if (activeRecipe.videoSource && activeRecipe.videoSource.kind === 'tiktok' && activeRecipe.videoSource.postUrl) { %>
                      <blockquote
                        class="tiktok-embed"
                        cite="<%= activeRecipe.videoSource.postUrl %>"
                        data-video-id="<%= activeRecipe.videoSource.videoId %>"
                        style="max-width: 100%; min-width: 100%;"
                      >
                        <section>
                          <a target="_blank" rel="noreferrer" href="<%= activeRecipe.videoSource.postUrl %>">
                            Lihat di TikTok
                          </a>
                        </section>
                      </blockquote>
                    <% } else { %>
                      <img src="<%= activeRecipe.imageUrl %>" alt="<%= activeRecipe.title %>" />
                    <% } %>
                  </div>

                  <div class="user-recipe-sidecards">
                    <article class="user-recipe-mini-panel">
                      <h3>Bahan-bahan</h3>
                      <div class="user-recipe-ingredient-list">
                        <% activeRecipe.ingredients.forEach((ingredient) => { %>
                          <label class="user-recipe-ingredient-item">
                            <span><%= ingredient.display || ingredient.name %></span>
                          </label>
                        <% }) %>
                      </div>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Ringkasan video resep</h3>
                      <p class="user-recipe-detail-description is-summary">
                        Video ini menunjukkan langkah utama resep ini. <%= activeRecipe.description %>
                      </p>
                    </article>

                    <article class="user-recipe-mini-panel">
                      <h3>Ringkasan resep</h3>
                      <div class="user-recipe-summary-list">
                        <span><strong>Perkiraan harga</strong> Rp <%= formatPrice(activeRecipe.estimatedPrice) %></span>
                        <span><strong>Waktu</strong> <%= activeRecipe.cookingTime %> menit</span>
                        <span><strong>Tingkat kesulitan</strong> <%= activeRecipe.difficulty %></span>
                        <span><strong>Porsi</strong> <%= activeRecipe.servings %> porsi</span>
                      </div>
                    </article>
                  </div>
                </div>

                <div class="user-recipe-action-row">
                  <button
                    type="button"
                    class="user-recipe-action-btn"
                    id="selectedRecipeFavorite"
                    data-action="favorite"
                    data-recipe-id="<%= activeRecipe.id %>"
                  >
                    <i class="fa-<%= activeRecipe.isFavorite ? 'solid' : 'regular' %> fa-heart"></i>
                    <span><%= activeRecipe.isFavorite ? 'Hapus dari favorit' : 'Simpan ke favorit' %></span>
                  </button>
                  <a class="user-recipe-action-btn" href="<%= activeRecipeDetailUrl %>">
                    <i class="fa-regular fa-eye"></i>
                    <span>Buka detail resep</span>
                  </a>
                  <a class="user-recipe-action-btn" href="/shopping-list">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Daftar belanja</span>
                  </a>
                  <button type="button" class="user-recipe-action-btn is-primary" id="selectedRecipeShare" data-action="share">
                    <i class="fa-solid fa-share-nodes"></i>
                    <span>Bagikan</span>
                  </button>
                </div>
              </article>

            <% } else { %>
              <article class="user-panel user-feed-empty">
                <h3>Belum ada resep yang bisa ditampilkan.</h3>
                <p>Coba ganti filter atau tambahkan resep approved dulu dari halaman admin.</p>
              </article>
            <% } %>
          </section>

        </div>
      </section>
    </div>
  </main>

  <% if (hasTikTokEmbed) { %>
    <script async src="https://www.tiktok.com/embed.js"></script>
  <% } %>

  <script>
    (() => {
      const recipes = <%- serializedRecipes %>;
      const recipeMap = new Map(recipes.map((recipe) => [String(recipe.id), recipe]));
      const selectedRecipeSnapshot = <%- JSON.stringify(activeRecipe || null).replace(/</g, '\\u003c') %>;
      const selectedRecipeId = String(<%- JSON.stringify(activeRecipe ? activeRecipe.id : '') %>);
      const selectedRecipeFavorite = document.getElementById('selectedRecipeFavorite');
      const selectedRecipeShare = document.getElementById('selectedRecipeShare');
      const escapeSelector = (value) => {
        if (window.CSS && typeof window.CSS.escape === 'function') {
          return window.CSS.escape(String(value || ''));
        }

        return String(value || '').replace(/"/g, '\\"');
      };

      const updateRecipeCardState = (recipe) => {
        const card = document.querySelector(`.user-fyp-menu-card[data-recipe-id="${escapeSelector(recipe.id)}"]`);
        if (!card) {
          return;
        }

        card.classList.toggle('is-favorite', Boolean(recipe.isFavorite));

        const heartButton = card.querySelector('.js-favorite-btn');
        if (heartButton) {
          heartButton.classList.toggle('is-active', Boolean(recipe.isFavorite));
          heartButton.setAttribute('aria-pressed', recipe.isFavorite ? 'true' : 'false');
          heartButton.setAttribute('aria-label', recipe.isFavorite ? 'Hapus dari favorit' : 'Simpan ke favorit');
          const icon = heartButton.querySelector('i');
          if (icon) {
            icon.className = recipe.isFavorite ? 'fa-solid fa-heart' : 'fa-regular fa-heart';
          }
        }

        const title = card.querySelector('.user-panel-head h2');
        if (title && recipe.title) {
          title.textContent = recipe.title;
        }

        const stats = card.querySelector('.user-fyp-menu-meta');
        if (stats) {
          const spans = stats.querySelectorAll('span');
          if (spans[0]) spans[0].innerHTML = `<i class="fa-solid fa-star"></i> ${recipe.likesCount || 0}`;
          if (spans[1]) spans[1].innerHTML = `<i class="fa-solid fa-bookmark"></i> ${recipe.savesCount || 0}`;
          if (spans[2]) spans[2].innerHTML = `<i class="fa-solid fa-list-check"></i> ${(recipe.ingredients || []).length}`;
        }
      };

      const updateSelectedRecipeState = (recipe) => {
        if (!recipe || String(recipe.id) !== selectedRecipeId) {
          return;
        }

        if (selectedRecipeFavorite) {
          selectedRecipeFavorite.dataset.recipeId = String(recipe.id);
          selectedRecipeFavorite.innerHTML = recipe.isFavorite
            ? '<i class="fa-solid fa-heart"></i><span>Hapus dari favorit</span>'
            : '<i class="fa-regular fa-heart"></i><span>Simpan ke favorit</span>';
        }
      };

      const toggleFavorite = async (recipeId) => {
        const recipe = recipeMap.get(String(recipeId));
        if (!recipe) {
          return;
        }

        const response = await fetch(`/api/recipes/${encodeURIComponent(recipeId)}/favorite`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        });

        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.error || 'Gagal mengubah favorit.');
        }

        recipe.isFavorite = Boolean(result.favorited);
        recipe.savesCount = Number(result.savesCount || 0);
        updateRecipeCardState(recipe);
        updateSelectedRecipeState(recipe);
      };

      document.querySelectorAll('.user-fyp-menu-card[data-recipe-id]').forEach((card) => {
        const recipeId = card.getAttribute('data-recipe-id');

        card.addEventListener('click', (event) => {
          const actionButton = event.target.closest('[data-action]');
          if (actionButton && actionButton.dataset.action === 'favorite') {
            return;
          }

          if (actionButton && actionButton.dataset.action === 'share') {
            navigator.clipboard?.writeText?.(`${window.location.origin}/recipes?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`);
            return;
          }

          if (actionButton && actionButton.dataset.action === 'detail') {
            window.location.href = `/recipe-detail?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
            return;
          }

          window.location.href = `/recipes?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
        });

        card.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            window.location.href = `/recipes?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=${encodeURIComponent(recipeId || '')}`;
          }
        });
      });

      document.querySelectorAll('.js-favorite-btn').forEach((button) => {
        button.addEventListener('click', async (event) => {
          event.stopPropagation();
          const recipeId = button.dataset.recipeId;
          if (!recipeId) {
            return;
          }

          try {
            button.disabled = true;
            await toggleFavorite(recipeId);
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal mengubah favorit.');
          } finally {
            button.disabled = false;
          }
        });
      });

      if (selectedRecipeFavorite) {
        selectedRecipeFavorite.addEventListener('click', async (event) => {
          event.stopPropagation();
          const recipeId = selectedRecipeFavorite.dataset.recipeId;
          if (!recipeId) {
            return;
          }

          try {
            selectedRecipeFavorite.disabled = true;
            await toggleFavorite(recipeId);
          } catch (error) {
            console.error(error);
            alert(error.message || 'Gagal mengubah favorit.');
          } finally {
            selectedRecipeFavorite.disabled = false;
          }
        });
      }

      if (selectedRecipeShare) {
        selectedRecipeShare.addEventListener('click', () => {
          navigator.clipboard?.writeText?.(`${window.location.origin}${window.location.pathname}?feed=<%= encodeURIComponent(feed || 'random') %>&recipeId=<%= encodeURIComponent(activeRecipe ? activeRecipe.id : '') %>`);
        });
      }

      if (selectedRecipeSnapshot && selectedRecipeSnapshot.id && !recipeMap.has(String(selectedRecipeSnapshot.id))) {
        recipeMap.set(String(selectedRecipeSnapshot.id), selectedRecipeSnapshot);
      }
    })();
  </script>
</body>
</html>
