<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    body.chat-page {
      background:
        radial-gradient(circle at top left, rgba(56, 156, 154, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(254, 219, 113, 0.2), transparent 24%),
        linear-gradient(180deg, #f5f7f4 0%, #eef3ee 100%);
    }

    .chat-dashboard .user-dashboard-main {
      display: grid;
      gap: 18px;
      padding: 20px;
      border-radius: 34px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 251, 248, 0.92)),
        linear-gradient(135deg, rgba(56, 156, 154, 0.04), transparent 48%);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 24px 70px rgba(29, 29, 29, 0.08);
      min-width: 0;
    }

    .chat-dashboard-topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      padding: 24px 26px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 18px 36px rgba(29, 29, 29, 0.08);
      backdrop-filter: blur(18px);
    }

    .chat-topbar-copy {
      display: grid;
      gap: 10px;
      max-width: 780px;
    }

    .chat-topbar-copy h1 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(1.8rem, 2.7vw, 2.8rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .chat-topbar-note {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      max-width: 78ch;
    }

    .chat-quick-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 6px;
    }

    .chat-quick-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0 14px;
      border-radius: 999px;
      border: 1px solid rgba(56, 156, 154, 0.18);
      background: rgba(56, 156, 154, 0.08);
      color: var(--accent-dark);
      font: inherit;
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 18px rgba(56, 156, 154, 0.08);
    }

    .chat-quick-chip:hover {
      background: rgba(56, 156, 154, 0.14);
      border-color: rgba(56, 156, 154, 0.28);
    }

    .chat-topbar-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-end;
      align-items: center;
    }

    .chat-dashboard .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 48px;
      padding: 0 18px;
      border-radius: 999px;
      text-decoration: none;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      border: 0;
      appearance: none;
      -webkit-appearance: none;
      background-clip: padding-box;
    }

    .chat-dashboard .button-secondary {
      background: rgba(255, 255, 255, 0.92);
      color: var(--text);
      border: 1px solid rgba(29, 29, 29, 0.08);
      box-shadow: 0 10px 26px rgba(29, 29, 29, 0.05);
    }

    .chat-window-shell {
      overflow: hidden;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr) auto;
      min-height: calc(100vh - 150px);
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.86);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 18px 36px rgba(29, 29, 29, 0.08);
      backdrop-filter: blur(18px);
    }

    .chat-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(29, 29, 29, 0.06);
      background: linear-gradient(180deg, rgba(245, 249, 246, 0.96), rgba(255, 255, 255, 0.9));
    }

    .chat-peer {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .chat-avatar {
      display: grid;
      place-items: center;
      width: 44px;
      height: 44px;
      border-radius: 16px;
      background: linear-gradient(180deg, #3bb49e 0%, #2c907f 100%);
      color: #fff;
      font-weight: 800;
      box-shadow: 0 12px 22px rgba(56, 156, 154, 0.2);
      flex-shrink: 0;
    }

    .chat-peer strong {
      display: block;
      margin-bottom: 3px;
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.03em;
    }

    .chat-peer span {
      color: #1f8f5d;
      font-size: 0.88rem;
      font-weight: 700;
    }

    .chat-feed {
      padding: 18px;
      display: grid;
      gap: 12px;
      align-content: start;
      overflow-y: auto;
      min-height: 50vh;
      background:
        linear-gradient(rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.18)),
        radial-gradient(circle at 20% 20%, rgba(56, 156, 154, 0.05), transparent 0 18%),
        radial-gradient(circle at 80% 78%, rgba(254, 219, 113, 0.08), transparent 0 16%);
    }

    .chat-message {
      display: flex;
    }

    .chat-message.is-user {
      justify-content: flex-end;
    }

    .chat-message.is-ai {
      justify-content: flex-start;
    }

    .chat-bubble {
      max-width: min(560px, 86%);
      padding: 12px 14px 10px;
      border-radius: 20px;
      display: grid;
      gap: 8px;
      position: relative;
      box-shadow: 0 10px 22px rgba(29, 29, 29, 0.08);
    }

    .chat-message.is-user .chat-bubble {
      background: linear-gradient(180deg, #dcf8e4 0%, #c7efd2 100%);
      border-top-right-radius: 8px;
    }

    .chat-message.is-ai .chat-bubble {
      background: rgba(255, 255, 255, 0.96);
      border-top-left-radius: 8px;
    }

    .chat-meta {
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--accent-dark);
    }

    .chat-status {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      width: fit-content;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(176, 120, 0, 0.14);
      background: rgba(255, 228, 158, 0.28);
      color: #8a5a00;
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .chat-status i {
      font-size: 0.9em;
    }

    .chat-status-note {
      color: rgba(138, 90, 0, 0.88);
      font-size: 0.8rem;
      line-height: 1.45;
      font-weight: 700;
      margin-top: -2px;
    }

    .chat-body {
      color: var(--text);
      line-height: 1.7;
      word-break: break-word;
    }

    .chat-body p {
      margin: 0 0 10px;
    }

    .chat-body p:last-child {
      margin-bottom: 0;
    }

    .chat-body a {
      color: #1f8f5d;
      font-weight: 700;
      text-decoration: underline;
    }

    .chat-followups {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .follow-up {
      border: 0;
      border-radius: 999px;
      padding: 9px 12px;
      background: rgba(56, 156, 154, 0.12);
      color: var(--accent-dark);
      font-weight: 700;
      cursor: pointer;
    }

    .message-attachment {
      margin: 0;
    }

    .message-attachment img {
      width: 100%;
      max-height: 260px;
      object-fit: cover;
      border-radius: 14px;
      border: 1px solid rgba(29, 29, 29, 0.08);
    }

    .chat-composer {
      display: grid;
      gap: 10px;
      padding: 16px 18px 18px;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.97), rgba(248, 251, 248, 0.97));
      border-top: 1px solid rgba(29, 29, 29, 0.06);
    }

    .composer-body {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 12px;
      align-items: end;
    }

    .attachment-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-height: 50px;
      padding: 0 14px;
      border-radius: 16px;
      background: rgba(56, 156, 154, 0.12);
      color: var(--accent-dark);
      cursor: pointer;
      font-weight: 800;
      box-shadow: 0 10px 18px rgba(56, 156, 154, 0.08);
      border: 0;
      appearance: none;
      -webkit-appearance: none;
      font: inherit;
    }

    .attachment-chip span:first-child {
      display: inline-grid;
      place-items: center;
      width: 28px;
      height: 28px;
      border-radius: 10px;
      background: rgba(56, 156, 154, 0.16);
    }

    .composer-input-wrap {
      display: grid;
      gap: 10px;
    }

    .composer-input {
      min-height: 54px;
      max-height: 180px;
      overflow-y: auto;
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid rgba(29, 29, 29, 0.1);
      background: #fff;
      line-height: 1.7;
      outline: none;
      width: 100%;
      resize: none;
      font: inherit;
      color: inherit;
      box-sizing: border-box;
      appearance: none;
      -webkit-appearance: none;
      box-shadow: 0 8px 20px rgba(29, 29, 29, 0.05);
    }

    .composer-input::placeholder {
      color: #8a9489;
    }

    .attachment-preview {
      display: grid;
      grid-template-columns: 56px minmax(0, 1fr) auto;
      gap: 12px;
      padding: 10px 12px;
      border-radius: 18px;
      background: rgba(56, 156, 154, 0.08);
      border: 1px solid rgba(56, 156, 154, 0.12);
      align-items: center;
    }

    .attachment-preview[hidden] {
      display: none !important;
    }

    .attachment-preview-thumb {
      width: 56px;
      height: 56px;
      border-radius: 14px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.72);
      box-shadow: inset 0 0 0 1px rgba(29, 29, 29, 0.06);
    }

    .attachment-preview img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .attachment-preview-copy strong {
      display: block;
      font-size: 0.92rem;
    }

    .attachment-preview-copy span {
      color: var(--muted);
      font-size: 0.84rem;
      word-break: break-word;
    }

    .attachment-remove {
      align-self: start;
      justify-self: start;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(29, 29, 29, 0.08);
      color: var(--text);
      cursor: pointer;
      border: 0;
      appearance: none;
      -webkit-appearance: none;
      font: inherit;
      font-weight: 700;
    }

    .composer-attachment-row {
      display: grid;
      gap: 10px;
    }

    .send-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 50px;
      min-width: 128px;
      border-radius: 16px;
      cursor: pointer;
      padding: 10px 12px;
      flex-direction: row;
      font-weight: 800;
      border: 0;
      appearance: none;
      -webkit-appearance: none;
    }

    .send-button span:last-child {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 28px;
      padding: 0 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      font-size: 0.76rem;
      letter-spacing: 0.04em;
    }

    .send-button:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      box-shadow: none;
    }

    @media (max-width: 1100px) {
      .chat-dashboard .user-dashboard-main {
        padding: 16px;
      }

      .chat-dashboard-topbar {
        flex-direction: column;
      }

      .chat-topbar-actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 900px) {
      .composer-body {
        grid-template-columns: 1fr;
      }

      .attachment-chip,
      .send-button {
        width: 100%;
      }
    }

    @media (max-width: 700px) {
      .chat-window-shell {
        min-height: calc(100vh - 120px);
      }

      .chat-feed,
      .chat-composer {
        padding: 14px;
      }

      .chat-topbar {
        padding: 14px;
        flex-direction: column;
        align-items: stretch;
      }

      .chat-bubble {
        max-width: 100%;
      }

      .attachment-preview {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 560px) {
      .chat-dashboard .user-dashboard-main {
        padding: 12px;
        gap: 14px;
      }

      .chat-dashboard-topbar {
        padding: 18px 16px;
        gap: 14px;
      }

      .chat-topbar-copy h1 {
        font-size: clamp(1.5rem, 8vw, 2rem);
      }

      .chat-topbar-note {
        line-height: 1.55;
      }

      .chat-quick-actions {
        flex-direction: column;
        gap: 8px;
      }

      .chat-quick-chip {
        width: 100%;
        justify-content: flex-start;
        padding-inline: 16px;
      }

      .chat-window-shell {
        border-radius: 22px;
      }

      .chat-topbar {
        padding: 12px 14px;
      }

      .chat-feed,
      .chat-composer {
        padding: 12px;
      }

      .chat-bubble {
        max-width: 100%;
        padding: 11px 12px 10px;
        border-radius: 18px;
      }

      .composer-input {
        min-height: 50px;
        padding: 12px 14px;
        border-radius: 16px;
      }

      .attachment-chip,
      .send-button {
        min-height: 46px;
      }

      .attachment-preview {
        padding: 10px;
        gap: 10px;
      }

      .attachment-preview-thumb {
        width: 48px;
        height: 48px;
      }

      .chat-dashboard .button {
        width: 100%;
      }
    }
  </style>
</head>
<body class="chat-page">
  <div class="page-bg"></div>

  <main class="user-dashboard chat-dashboard">
    <div class="user-dashboard-shell chat-dashboard-shell">
      <%- include('partials/sidebar', { mode: 'user', activePage: 'chat', user }) %>

      <section class="user-dashboard-main chat-main">
        <header class="user-dashboard-topbar chat-dashboard-topbar">
          <div class="chat-topbar-copy">
            <p class="user-panel-kicker">AI chat</p>
            <h1>Chat AI model WhatsApp</h1>
            <p class="chat-topbar-note">Tulis pesan biasa, paste gambar kalau perlu, upload foto opsional, lalu Enter untuk kirim. Shift+Enter untuk baris baru.</p>
            <div class="chat-quick-actions" aria-label="Aksi cepat">
              <button type="button" class="chat-quick-chip" data-preset="Bantu pilih resep dari bahan yang ada">Pilih resep</button>
              <button type="button" class="chat-quick-chip" data-preset="Cek bahan yang harus dibeli supaya bisa recook resep ini">Cek bahan</button>
              <button type="button" class="chat-quick-chip" data-preset="Buat recook dari foto masakan ini">Recook dari foto</button>
            </div>
          </div>
          <div class="user-topbar-actions chat-topbar-actions">
            <button type="button" class="button button-secondary" id="clearChat">Clear chat</button>
          </div>
        </header>

        <section class="chat-window-shell">
          <div class="chat-topbar">
            <div class="chat-peer">
              <div class="chat-avatar">AI</div>
              <div>
                <strong>Recipe Assistant</strong>
                <span>online</span>
              </div>
            </div>
          </div>

          <div class="chat-feed" id="chatWindow" aria-live="polite"></div>

          <form class="chat-composer" id="chatForm" enctype="multipart/form-data">
            <div class="composer-body">
              <label class="attachment-chip" for="chatPhoto">
                <span>+</span>
                <input type="file" id="chatPhoto" accept="image/*" hidden />
                <span>Foto</span>
              </label>

              <div class="composer-input-wrap">
                <div class="composer-attachment-row">
                  <div class="attachment-preview" id="attachmentPreview" hidden>
                    <div class="attachment-preview-thumb">
                      <img id="attachmentPreviewImg" alt="Preview foto" />
                    </div>
                    <div class="attachment-preview-copy">
                      <strong>Foto siap dikirim</strong>
                      <span id="attachmentPreviewName">Belum ada file</span>
                    </div>
                    <button type="button" class="attachment-remove" id="removeAttachment">Hapus</button>
                  </div>
                </div>
                <textarea
                  id="chatInput"
                  class="composer-input"
                  rows="2"
                  aria-label="Tulis pesan"
                  placeholder="Tulis pesan, Shift+Enter untuk baris baru, Enter untuk kirim."
                ></textarea>
              </div>

              <button type="submit" class="send-button" id="sendButton" aria-label="Kirim pesan">
                <span>Kirim</span>
                <span>Enter</span>
              </button>
            </div>
          </form>
        </section>
      </section>
    </div>
  </main>

  <script>
    window.__INITIAL_CHAT_MESSAGES__ = <%- JSON.stringify(messages || []) %>;
  </script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/confirm-dialog.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>
