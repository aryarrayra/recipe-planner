<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="dashboard-shell dashboard-shell-admin">
    <section class="dashboard-hero">
      <span class="eyebrow">Admin dashboard</span>
      <h1>Selamat datang, <%= user.username %>.</h1>
      <p>
        Halaman ini menampilkan ringkasan data aplikasi. Admin login memakai
        credential server-side, bukan akun register user.
      </p>
      <div class="dashboard-actions">
        <a class="auth-button" href="/chat-ai">Lihat Chat AI</a>
        <form action="/logout" method="post">
          <button class="auth-button auth-button-secondary" type="submit">Logout</button>
        </form>
      </div>
    </section>

    <section class="dashboard-grid dashboard-grid-metrics">
      <article class="dashboard-card">
        <span>Total user</span>
        <strong><%= metrics.users %></strong>
      </article>
      <article class="dashboard-card">
        <span>Total resep</span>
        <strong><%= metrics.recipes %></strong>
      </article>
      <article class="dashboard-card">
        <span>Total chat message</span>
        <strong><%= metrics.messages %></strong>
      </article>
    </section>
  </main>
</body>
</html>
