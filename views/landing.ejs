<script>
// ─── TheMealDB Carousel ───
const MEALDB = 'https://www.themealdb.com/api/json/v1/1';
let carouselMeals = [];
let currentSlide = 0;
let carouselTimer = null;

async function fetchRandomMeals(n = 7) {
  const promises = Array.from({length: n}, () =>
    fetch(`${MEALDB}/random.php`).then(r => r.json()).then(d => d.meals[0])
  );
  return Promise.all(promises);
}

function buildCarousel(meals) {
  carouselMeals = meals;
  const track = document.getElementById('carousel-track');
  const dots = document.getElementById('carousel-dots');

  track.innerHTML = '';
  dots.innerHTML = '';

  meals.forEach((meal, i) => {
    const slide = document.createElement('div');
    slide.className = 'carousel-slide' + (i === 0 ? ' active' : '');
    slide.innerHTML = `
      <img src="${meal.strMealThumb}" alt="${meal.strMeal}" loading="${i === 0 ? 'eager' : 'lazy'}" />
      <div class="carousel-overlay"></div>
      <div class="carousel-label">
        <div class="meal-area">${meal.strArea || meal.strCategory}</div>
        <div class="meal-name">${meal.strMeal}</div>
      </div>
    `;
    track.appendChild(slide);

    const dot = document.createElement('div');
    dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
    dot.addEventListener('click', () => goToSlide(i));
    dots.appendChild(dot);
  });

  startCarousel();
}

function goToSlide(idx) {
  const track = document.getElementById('carousel-track');
  const slides = track.querySelectorAll('.carousel-slide');
  const dots = document.getElementById('carousel-dots').querySelectorAll('.carousel-dot');

  slides[currentSlide].classList.remove('active');
  dots[currentSlide].classList.remove('active');
  currentSlide = idx;
  slides[currentSlide].classList.add('active');
  dots[currentSlide].classList.add('active');
  track.style.transform = `translateX(-${currentSlide * 100}%)`;
}

function startCarousel() {
  clearInterval(carouselTimer);
  carouselTimer = setInterval(() => {
    const next = (currentSlide + 1) % carouselMeals.length;
    goToSlide(next);
  }, 4000);
}

// ─── TheMealDB Meal Grid ───
async function fetchCategoryMeals() {
  const cats = ['Seafood', 'Beef', 'Chicken', 'Dessert'];
  const pick = cats[Math.floor(Math.random() * cats.length)];
  const r = await fetch(`${MEALDB}/filter.php?c=${pick}`);
  const d = await r.json();
  const sample = d.meals.sort(() => 0.5 - Math.random()).slice(0, 4);
  const details = await Promise.all(
    sample.map(m => fetch(`${MEALDB}/lookup.php?i=${m.idMeal}`).then(r => r.json()).then(d => d.meals[0]))
  );
  return details;
}

function buildMealGrid(meals) {
  const grid = document.getElementById('meal-grid');
  grid.innerHTML = '';
  meals.forEach(meal => {
    const card = document.createElement('div');
    card.className = 'meal-card';
    card.innerHTML = `
      <img src="${meal.strMealThumb}" alt="${meal.strMeal}" loading="lazy" />
      <div class="meal-card-overlay">
        <div class="meal-card-area">${meal.strArea || meal.strCategory}</div>
        <div class="meal-card-name">${meal.strMeal}</div>
      </div>
      <div class="meal-card-tag">${meal.strCategory}</div>
    `;
    grid.appendChild(card);
  });
}

// ─── Ticker ───
function buildTicker(meals) {
  const ticker = document.getElementById('ticker');
  const items = meals.map(m => `
    <span class="ticker-item"><i class="fa-solid fa-circle-dot"></i>${m.strMeal} — ${m.strArea || m.strCategory}</span>
  `).join('');
  ticker.innerHTML = items + items; // duplicate for seamless loop
}

// ─── Init ───
(async () => {
  try {
    const [carouselMealsData, gridMeals] = await Promise.all([
      fetchRandomMeals(7),
      fetchCategoryMeals()
    ]);
    buildCarousel(carouselMealsData);
    buildMealGrid(gridMeals);
    buildTicker(carouselMealsData);
  } catch (e) {
    console.warn('MealDB fetch failed:', e);
  }
})();

// ─── Navbar scroll ───
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => {
  navbar.classList.toggle('scrolled', window.scrollY > 20);
});

// ─── Scroll reveal ───
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('in-view');
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
