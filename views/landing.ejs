<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="page-transition">
    <main class="food-landing">
      <section class="food-shell">
        <header class="food-header">
          <a href="/" class="food-logo">ResepKu</a>
          <nav class="food-nav">
            <a href="#about">About us</a>
            <a href="#service">Service</a>
            <a href="#menu">Menu</a>
            <a href="/login">Contact us</a>
          </nav>
          <a href="/login" class="food-header-btn">W</a>
        </header>

        <section class="food-hero">
          <div class="food-hero-copy">
            <p class="food-kicker">ResepKu</p>
            <h1>
              <span>YUMMY</span>
              BREAKFAST!
            </h1>
            <p class="food-subtitle">
              Discover breakfast ideas, plan your food schedule, and cook with a
              cleaner workflow every day.
            </p>
            <div class="food-hero-actions">
              <a href="/login" class="food-btn food-btn-primary">Go to login</a>
              <a href="/register" class="food-btn food-btn-secondary">Create account</a>
            </div>
          </div>

          <div class="food-hero-visual">
            <div class="visual-strip"></div>
            <figure class="hero-plate hero-plate-main">
              <img src="/images/6.png" alt="ResepKu hero bowl" />
            </figure>
          </div>
        </section>

        <section class="food-mini-strip" id="service">
          <div class="food-mini-head">
            <p>Hot selections</p>
          </div>
          <div class="food-mini-grid">
            <article class="food-mini-card">
              <img src="/images/1.png" alt="Budget meal" />
              <div>
                <h3>Budget meal</h3>
                <p>Smart and easy</p>
              </div>
            </article>
            <article class="food-mini-card">
              <img src="/images/2.png" alt="Quick dishes" />
              <div>
                <h3>Quick dishes</h3>
                <p>Ready fast</p>
              </div>
            </article>
            <article class="food-mini-card">
              <img src="/images/3.png" alt="Mood food" />
              <div>
                <h3>Mood food</h3>
                <p>Feel-good picks</p>
              </div>
            </article>
          </div>
        </section>

        <section class="food-feature" id="about">
          <div class="food-feature-plate">
            <div class="food-ring"></div>
            <img src="/images/2.png" alt="Featured recipe" />
          </div>
          <div class="food-feature-copy">
            <p class="food-kicker">Best workflow</p>
            <h2>THE BEST YUMMY FOOD IN TOWN</h2>
            <p>
              Organize recipes, filter by ingredients, and keep your next meal plan
              simple. ResepKu is built for practical cooking, not clutter.
            </p>
            <a href="/register" class="food-btn food-btn-primary">Try our app</a>
          </div>
        </section>

        <section class="food-menu" id="menu">
          <div class="food-section-title food-section-title-center">
            <p class="food-kicker">Explore</p>
            <h2>EXPLORE OUR MENU</h2>
          </div>
          <div class="food-menu-grid">
            <article class="food-menu-card">
              <img src="/images/1.png" alt="Ingredient search" />
              <div class="food-menu-copy">
                <h3>Ingredient search</h3>
                <p>Cook from what you have</p>
              </div>
            </article>
            <article class="food-menu-card">
              <img src="/images/3.png" alt="Meal ideas" />
              <div class="food-menu-copy">
                <h3>Meal ideas</h3>
                <p>Breakfast to dinner picks</p>
              </div>
            </article>
            <article class="food-menu-card">
              <img src="/images/2.png" alt="Recipe details" />
              <div class="food-menu-copy">
                <h3>Recipe details</h3>
                <p>Time, price, and tags</p>
              </div>
            </article>
          </div>
        </section>

        <section class="food-popular">
          <div class="food-popular-head">
            <div class="food-section-title">
              <p class="food-kicker">Most popular</p>
              <h2>OUR MOST POPULAR RECIPES</h2>
            </div>
            <div class="food-popular-actions">
              <button
                type="button"
                class="food-slider-btn"
                id="popularPrev"
                aria-label="Previous recipe"
              >
                &lt;
              </button>
              <button
                type="button"
                class="food-slider-btn"
                id="popularNext"
                aria-label="Next recipe"
              >
                &gt;
              </button>
              <a href="/login" class="food-pill-link">See more</a>
            </div>
          </div>

          <div class="food-popular-carousel" id="popularSlider">
            <div class="food-carousel-stage">
              <div class="food-carousel-track" id="popularTrack">
                <article class="food-carousel-card" data-popular-item="0">
                  <img src="/images/1.png" alt="Vegetable soup" />
                </article>
                <article class="food-carousel-card is-active" data-popular-item="1">
                  <img src="/images/3.png" alt="Noodle bowl" />
                </article>
                <article class="food-carousel-card" data-popular-item="2">
                  <img src="/images/2.png" alt="Spicy dish" />
                </article>
                <article class="food-carousel-card" data-popular-item="3">
                  <img src="/images/6.png" alt="Fresh breakfast" />
                </article>
              </div>
            </div>

            <div class="food-carousel-copy">
              <p class="food-carousel-tag" id="popularTag">Most wanted</p>
              <h3 id="popularTitle">Noodle bowl</h3>
              <div class="food-meta">
                <span id="popularTime">20 min</span>
                <span id="popularPrice">$11</span>
              </div>
            </div>
          </div>
        </section>

        <section class="food-quote">
          <blockquote>
            “The food we had inspired us to build a planner that turns meal ideas
            into something structured and easier to use.”
          </blockquote>
          <div class="food-quote-plate">
            <div class="food-ring food-ring-small"></div>
            <img src="/images/3.png" alt="Closing recipe" />
          </div>
        </section>

        <footer class="food-footer">
          <div>
            <a href="/" class="food-logo">ResepKu</a>
            <p>ResepKu for better everyday cooking.</p>
          </div>
          <div class="food-footer-links">
            <div>
              <h3>Navigate</h3>
              <a href="/">Home</a>
              <a href="/login">Login</a>
              <a href="/register">Register</a>
            </div>
            <div>
              <h3>Features</h3>
              <a href="#service">Ingredient search</a>
              <a href="#menu">Recipes</a>
              <a href="#about">Meal planning</a>
            </div>
          </div>
        </footer>
      </section>
    </main>
    <script>
      (() => {
        window.requestAnimationFrame(() => {
          window.setTimeout(() => {
            document.body.classList.add("is-ready");
          }, 40);
        });

        document.querySelectorAll('a[href="/login"], a[href="/register"]').forEach((link) => {
          link.addEventListener("click", (event) => {
            const href = link.getAttribute("href");
            if (!href) {
              return;
            }

            event.preventDefault();
            document.body.classList.remove("is-ready");
            document.body.classList.add("is-leaving");
            window.setTimeout(() => {
              window.location.href = href;
            }, 320);
          });
        });
      })();

    </script>
    <script>
      (() => {
        const recipes = [
          { title: "Vegetable soup", tag: "Fresh pick", time: "15 min", price: "$8", image: "/images/1.png" },
          { title: "Noodle bowl", tag: "Most wanted", time: "20 min", price: "$11", image: "/images/3.png" },
          { title: "Spicy dish", tag: "Chef favorite", time: "18 min", price: "$10", image: "/images/2.png" },
          { title: "Fresh breakfast", tag: "Morning special", time: "12 min", price: "$9", image: "/images/6.png" }
        ];

        const track = document.getElementById("popularTrack");
        const cards = Array.from(document.querySelectorAll("[data-popular-item]"));
        const prevButton = document.getElementById("popularPrev");
        const nextButton = document.getElementById("popularNext");
        const tag = document.getElementById("popularTag");
        const title = document.getElementById("popularTitle");
        const time = document.getElementById("popularTime");
        const price = document.getElementById("popularPrice");

        if (!track || !cards.length || !prevButton || !nextButton || !tag || !title || !time || !price) {
          return;
        }

        let slotPositions = [3, 0, 1, 2];

        const render = () => {
          const stage = track.parentElement;
          const stageWidth = stage.clientWidth;
          const cardWidth = cards[0].offsetWidth;
          const centerX = (stageWidth - cardWidth) / 2;
          const leftX = -cardWidth * 0.18;
          const rightX = stageWidth - cardWidth * 0.82;
          const bottomX = centerX;
          const arcSlots = {
            0: { x: centerX, y: 0, scale: 1, opacity: 1, z: 3 },
            1: { x: rightX, y: 128, scale: 0.82, opacity: 0.8, z: 2 },
            2: { x: bottomX, y: 268, scale: 0.6, opacity: 0, z: 1 },
            3: { x: leftX, y: 128, scale: 0.82, opacity: 0.8, z: 2 }
          };

          cards.forEach((card, index) => {
            const image = card.querySelector("img");
            const slotKey = slotPositions[index];
            const slot = arcSlots[slotKey] || arcSlots[2];
            card.classList.toggle("is-active", slotKey === 0);
            card.style.setProperty("--tx", `${slot.x}px`);
            card.style.setProperty("--ty", `${slot.y}px`);
            card.style.setProperty("--scale", slot.scale);
            card.style.opacity = slot.opacity;
            card.style.zIndex = slot.z;
            image.src = recipes[index].image;
            image.alt = recipes[index].title;
          });

          const activeIndex = slotPositions.findIndex((slot) => slot === 0);
          const activeRecipe = recipes[activeIndex];
          tag.textContent = activeRecipe.tag;
          title.textContent = activeRecipe.title;
          time.textContent = activeRecipe.time;
          price.textContent = activeRecipe.price;
        };

        nextButton.addEventListener("click", () => {
          slotPositions = slotPositions.map((slot) => (slot + 3) % 4);
          render();
        });

        prevButton.addEventListener("click", () => {
          slotPositions = slotPositions.map((slot) => (slot + 1) % 4);
          render();
        });

        window.addEventListener("resize", render);
        render();
      })();
    </script>
  </body>
</html>
