<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="user-dashboard">
    <div class="user-dashboard-shell">
      <aside class="user-sidebar">
        <a href="/dashboard" class="user-sidebar-brand">
          <i class="fa-solid fa-utensils" aria-hidden="true"></i>
        </a>

        <nav class="user-sidebar-nav">
          <a class="user-sidebar-link is-active" href="/dashboard">
            <span class="user-sidebar-icon"><i class="fa-solid fa-house"></i></span>
            <span>Dashboard</span>
          </a>
          <a class="user-sidebar-link" href="/api/recipes">
            <span class="user-sidebar-icon"><i class="fa-solid fa-book-open"></i></span>
            <span>Resep</span>
          </a>
          <a class="user-sidebar-link" href="/chat-ai">
            <span class="user-sidebar-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
            <span>AI Chat</span>
          </a>
          <a class="user-sidebar-link" href="/chat-history">
            <span class="user-sidebar-icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
            <span>History</span>
          </a>
        </nav>

        <form action="/logout" method="post" class="user-sidebar-logout">
          <button type="submit" class="user-icon-button user-icon-button-soft">Logout</button>
        </form>
      </aside>

      <section class="user-dashboard-main">
        <header class="user-dashboard-topbar">
          <div class="user-search">
            <i class="fa-solid fa-magnifying-glass user-search-icon" aria-hidden="true"></i>
            <input type="text" placeholder="Search recipe, ingredient, or AI idea" />
            <span>Search</span>
          </div>

          <div class="user-topbar-actions">
            <a class="user-icon-button" href="/chat-ai">
              <i class="fa-solid fa-wand-magic-sparkles" aria-hidden="true"></i>
            </a>
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <div class="user-dashboard-content">
          <section class="user-dashboard-left">
            <article class="user-panel user-panel-hero">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Top recipe categories</p>
                  <h2>Kategori resep favorit</h2>
                </div>
              </div>

              <div class="user-category-row">
                <div class="user-category-chip">
                  <img src="/images/1.png" alt="Soup" />
                  <span>Soup</span>
                </div>
                <div class="user-category-chip">
                  <img src="/images/3.png" alt="Pasta" />
                  <span>Pasta</span>
                </div>
                <div class="user-category-chip">
                  <img src="/images/2.png" alt="Spicy" />
                  <span>Spicy</span>
                </div>
                <div class="user-category-chip">
                  <img src="/images/6.png" alt="Breakfast" />
                  <span>Breakfast</span>
                </div>
                <div class="user-category-chip">
                  <img src="/images/1.png" alt="Healthy" />
                  <span>Grilled</span>
                </div>
                <div class="user-category-chip user-category-chip-arrow">
                  <span><i class="fa-solid fa-chevron-right" aria-hidden="true"></i></span>
                </div>
              </div>
            </article>

            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Popular recipe</p>
                  <h2>Menu yang cocok untuk kamu</h2>
                </div>
              </div>

              <div class="user-recipe-list">
                <article class="user-recipe-card">
                  <img src="/images/3.png" alt="Pasta with salmon and peas" />
                  <div class="user-recipe-copy">
                    <h3>Pasta with salmon &amp; peas</h3>
                    <div class="user-recipe-tags">
                      <span><i class="fa-solid fa-star"></i> 4.7</span>
                      <span><i class="fa-solid fa-fish"></i> Seafood</span>
                      <span><i class="fa-solid fa-bowl-food"></i> Pasta</span>
                    </div>
                    <p>20 mins</p>
                    <small>Suggested by ResepKu</small>
                  </div>
                </article>

                <article class="user-recipe-card">
                  <img src="/images/1.png" alt="Pumpkin soup" />
                  <div class="user-recipe-copy">
                    <h3>Pumpkin soup</h3>
                    <div class="user-recipe-tags">
                      <span><i class="fa-solid fa-star"></i> 4.4</span>
                      <span><i class="fa-solid fa-leaf"></i> Veg</span>
                      <span><i class="fa-solid fa-mug-hot"></i> Soup</span>
                    </div>
                    <p>19 mins</p>
                    <small>Upload by Tami</small>
                  </div>
                </article>

                <article class="user-recipe-card">
                  <img src="/images/2.png" alt="Pesto pasta" />
                  <div class="user-recipe-copy">
                    <h3>Pesto pasta</h3>
                    <div class="user-recipe-tags">
                      <span><i class="fa-solid fa-star"></i> 4.6</span>
                      <span><i class="fa-solid fa-pepper-hot"></i> Bold</span>
                      <span><i class="fa-solid fa-bowl-food"></i> Pasta</span>
                    </div>
                    <p>24 mins</p>
                    <small>Upload by Naya</small>
                  </div>
                </article>
              </div>
            </article>
          </section>

          <aside class="user-dashboard-right">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Events you may be interested</p>
                  <h2>Ide pilihan hari ini</h2>
                </div>
              </div>

              <div class="user-event-list">
                <article class="user-event-card">
                  <img src="/images/6.png" alt="Breakfast combo" />
                  <div class="user-event-copy">
                    <h3>Breakfast combo</h3>
                    <p><i class="fa-regular fa-clock"></i> Today | 7:00 AM</p>
                    <small><i class="fa-regular fa-user"></i> Cook with Dara</small>
                  </div>
                </article>

                <article class="user-event-card">
                  <img src="/images/2.png" alt="Gym meal" />
                  <div class="user-event-copy">
                    <h3>Gym meal</h3>
                    <p><i class="fa-regular fa-clock"></i> Today | 12:30 PM</p>
                    <small><i class="fa-regular fa-user"></i> Cook with Adit</small>
                  </div>
                </article>

                <article class="user-event-card">
                  <img src="/images/1.png" alt="Thai flavour" />
                  <div class="user-event-copy">
                    <h3>Thai flavour</h3>
                    <p><i class="fa-regular fa-clock"></i> Today | 5:30 PM</p>
                    <small><i class="fa-regular fa-user"></i> Cook with Sela</small>
                  </div>
                </article>
              </div>
            </article>

            <article class="user-panel user-ai-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">AI meal assistant</p>
                  <h2>Tempat AI ResepKu</h2>
                </div>
              </div>

              <p class="user-ai-copy">
                Tanya AI untuk ide masak dari bahan yang tersedia, meal plan mingguan,
                atau resep hemat yang tetap enak.
              </p>

              <div class="user-ai-actions">
                <a class="auth-button" href="/chat-ai">Mulai AI</a>
                <a class="auth-button auth-button-secondary" href="/chat-history">History</a>
              </div>

              <div class="user-ai-prompts">
                <a href="/chat-ai" class="user-prompt-card">
                  <strong>Prompt cepat</strong>
                  <span>"Aku punya telur, ayam, dan mie. Bikin menu 3 hari."</span>
                </a>
                <a href="/chat-ai" class="user-prompt-card">
                  <strong>Meal plan</strong>
                  <span>"Buat sarapan sehat seminggu yang simple dan murah."</span>
                </a>
              </div>
            </article>

            <article class="user-panel user-event-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Quick stats</p>
                  <h2>Status akun</h2>
                </div>
              </div>

              <div class="user-stat-list">
                <div class="user-stat-card">
                  <i class="fa-regular fa-id-badge" aria-hidden="true"></i>
                  <strong><%= user.username %></strong>
                  <span>Nama akun aktif</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-regular fa-envelope" aria-hidden="true"></i>
                  <strong><%= user.email %></strong>
                  <span>Email terdaftar</span>
                </div>
                <div class="user-stat-card">
                  <i class="fa-solid fa-user-shield" aria-hidden="true"></i>
                  <strong><%= user.role %></strong>
                  <span>Tipe akses saat ini</span>
                </div>
              </div>
            </article>
          </aside>
        </div>
      </section>
    </div>
  </main>
</body>
</html>
