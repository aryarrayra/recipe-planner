<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="page-transition auth-page">
    <main class="login-page auth-page auth-page-login">
      <section class="visual-panel">
        <div class="visual-outline"></div>
        <div class="visual-strip"></div>
        <div class="plate-stack">
          <figure class="plate plate-primary">
            <img src="/images/3.png" alt="Noodle bowl" />
          </figure>
          <figure class="plate plate-secondary">
            <img src="/images/2.png" alt="Spicy dish" />
          </figure>
          <figure class="plate plate-tertiary">
            <img src="/images/1.png" alt="Vegetable soup" />
          </figure>
        </div>
        <div class="brand-badge">
          <span class="brand-dot"></span>
          <div>
            <strong>ResepKu</strong>
            <small>Smart meal ideas for every day</small>
          </div>
        </div>
      </section>

      <section class="form-panel">
        <div class="form-top-accent"></div>
        <div class="corner-leaf corner-leaf-top"></div>
        <div class="corner-leaf corner-leaf-bottom"></div>

        <div class="form-shell">
          <div class="form-card">
            <p class="eyebrow">Forgot password</p>
            <h1>Reset your password</h1>

            <% if (error) { %>
              <div class="auth-alert landing-alert"><%= error %></div>
            <% } %>

            <% if (typeof notice !== "undefined" && notice) { %>
              <div class="auth-alert landing-alert landing-alert-success"><%= notice %></div>
            <% } %>

            <p class="auth-help-text">
              Masukkan email akunmu. Kalau email terdaftar, kami kirim kode OTP reset password.
            </p>

            <div class="login-panel">
              <form class="login-form" action="/forgot-password" method="post">
                <label class="sr-only" for="email">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="E-mail"
                  value="<%= (values && values.email) || '' %>"
                />
                <button type="submit">Send OTP</button>
              </form>
            </div>

            <p class="signup-copy">
              <a href="/login">Back to login</a>
            </p>
          </div>
        </div>
      </section>
    </main>
    <script>
      (() => {
        window.requestAnimationFrame(() => {
          window.setTimeout(() => {
            document.body.classList.add("is-ready");
          }, 70);
        });
      })();
    </script>
  </body>
</html>
