<%
  const mobileNavId = `mobile-nav-${mode}`;
  const isAdmin = mode === 'admin';
  const mobilePrimaryLinks = isAdmin
    ? [
        { href: '/admin/dashboard', iconClass: 'fa-solid fa-house', label: 'Dashboard', active: 'dashboard' },
        { href: '/admin/users', iconClass: 'fa-solid fa-users', label: 'User', active: 'users' },
        { href: '/admin/trending', iconClass: 'fa-solid fa-people-group', label: 'Community', active: 'community' },
        { href: '/admin/reports', iconClass: 'fa-solid fa-flag', label: 'Reports', active: 'reports' }
      ]
    : [
        { href: '/dashboard', iconClass: 'fa-solid fa-house', label: 'Dashboard', active: 'dashboard' },
        { href: '/recipes', iconClass: 'fa-solid fa-compass', label: 'FYP', active: 'fyp' },
        { href: '/chat-ai', iconClass: 'fa-solid fa-wand-magic-sparkles', label: 'AI Chat', active: 'chat' },
        { href: '/community', iconClass: 'fa-solid fa-users', label: 'Community', active: 'community' }
      ];

  const mobileDrawerLinks = isAdmin
    ? []
    : [
        { href: '/recipe-menu', iconClass: 'fa-solid fa-bowl-food', label: 'Resep', active: 'recipes' },
        { href: '/shopping-list', iconClass: 'fa-solid fa-cart-shopping', label: 'Shopping List', active: 'shopping-list' },
        { href: '/profile', iconClass: 'fa-solid fa-user', label: 'Profile', active: 'profile' }
      ];
%>

<div class="user-sidebar-shell">
  <aside class="user-sidebar <%= mode === 'admin' ? 'admin-sidebar' : 'user-sidebar-user' %>">
    <div class="user-sidebar-brand" aria-hidden="true">
      <img src="/images/7.png" alt="" />
    </div>

    <nav class="user-sidebar-nav">
      <% if (mode === 'admin') { %>
        <a class="user-sidebar-link <%= activePage === 'dashboard' ? 'is-active' : '' %>" href="/admin/dashboard">
          <span class="user-sidebar-icon"><i class="fa-solid fa-house"></i></span>
          <span>Dashboard</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'users' ? 'is-active' : '' %>" href="/admin/users">
          <span class="user-sidebar-icon"><i class="fa-solid fa-users"></i></span>
          <span>User</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'community' ? 'is-active' : '' %>" href="/admin/trending">
          <span class="user-sidebar-icon"><i class="fa-solid fa-people-group"></i></span>
          <span>Community</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'reports' ? 'is-active' : '' %>" href="/admin/reports">
          <span class="user-sidebar-icon"><i class="fa-solid fa-flag"></i></span>
          <span>Reports</span>
        </a>
      <% } else { %>
        <a class="user-sidebar-link <%= activePage === 'dashboard' ? 'is-active' : '' %>" href="/dashboard">
          <span class="user-sidebar-icon"><i class="fa-solid fa-house"></i></span>
          <span>Dashboard</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'fyp' ? 'is-active' : '' %>" href="/recipes">
          <span class="user-sidebar-icon"><i class="fa-solid fa-compass"></i></span>
          <span>FYP</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'recipes' ? 'is-active' : '' %>" href="/recipe-menu">
          <span class="user-sidebar-icon"><i class="fa-solid fa-bowl-food"></i></span>
          <span>Resep</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'shopping-list' ? 'is-active' : '' %>" href="/shopping-list">
          <span class="user-sidebar-icon"><i class="fa-solid fa-cart-shopping"></i></span>
          <span>Shopping List</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'chat' ? 'is-active' : '' %>" href="/chat-ai">
          <span class="user-sidebar-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
          <span>AI Chat</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'community' ? 'is-active' : '' %>" href="/community">
          <span class="user-sidebar-icon"><i class="fa-solid fa-users"></i></span>
          <span>Community</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'profile' ? 'is-active' : '' %>" href="/profile">
          <span class="user-sidebar-icon"><i class="fa-solid fa-user"></i></span>
          <span>Profile</span>
        </a>
      <% } %>
    </nav>

    <form action="/logout" method="post" class="user-sidebar-logout">
      <button type="submit" class="user-icon-button user-icon-button-soft" aria-label="Logout" title="Logout">
        <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
        <span class="sr-only">Logout</span>
      </button>
    </form>
  </aside>
</div>

  <div class="mobile-bottom-nav-shell" aria-label="Navigasi mobile">
  <input type="checkbox" class="mobile-bottom-nav-toggle" id="<%= mobileNavId %>" />

  <nav class="mobile-bottom-nav" aria-label="Navigasi cepat">
    <% mobilePrimaryLinks.forEach((item) => { %>
      <a class="mobile-bottom-nav-link <%= activePage === item.active ? 'is-active' : '' %>" href="<%= item.href %>">
        <span class="mobile-bottom-nav-icon"><i class="<%= item.iconClass %>"></i></span>
        <span><%= item.label %></span>
      </a>
    <% }) %>

    <label class="mobile-bottom-nav-link mobile-bottom-nav-menu" for="<%= mobileNavId %>" aria-label="Buka menu halaman">
      <span class="mobile-bottom-nav-icon"><i class="fa-solid fa-bars"></i></span>
      <span>Menu</span>
    </label>
  </nav>

  <aside class="mobile-bottom-nav-drawer" aria-label="Menu halaman">
    <div class="mobile-bottom-nav-drawer-head">
      <div>
        <p>Menu tambahan</p>
        <strong><%= mobileDrawerLinks.length ? 'Pilih halaman' : 'Tidak ada menu tambahan' %></strong>
      </div>
      <label class="mobile-bottom-nav-close" for="<%= mobileNavId %>" aria-label="Tutup menu">
        <i class="fa-solid fa-xmark"></i>
      </label>
    </div>

    <% if (mobileDrawerLinks.length) { %>
      <div class="mobile-bottom-nav-grid">
        <% mobileDrawerLinks.forEach((item) => { %>
          <a class="mobile-bottom-nav-card <%= activePage === item.active ? 'is-active' : '' %>" href="<%= item.href %>">
            <span class="mobile-bottom-nav-icon"><i class="<%= item.iconClass %>"></i></span>
            <div>
              <strong><%= item.label %></strong>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="mobile-bottom-nav-empty">
        Menu utama sudah ada di bottom navbar.
      </div>
    <% } %>

    <form action="/logout" method="post" class="mobile-bottom-nav-logout">
      <button type="submit" class="button button-secondary">
        <i class="fa-solid fa-right-from-bracket"></i>
        <span>Logout</span>
      </button>
    </form>
  </aside>
  <label class="mobile-bottom-nav-backdrop" for="<%= mobileNavId %>" aria-hidden="true"></label>
</div>

<% if (mode !== 'admin') { %>
  <div class="page-load-overlay" aria-hidden="true">
    <div class="page-load-card">
      <div class="page-load-spinner" aria-hidden="true"></div>
      <strong>Memuat halaman</strong>
      <span>Mengambil konten terbaru...</span>
    </div>
  </div>
  <script>
    (() => {
      const root = document.documentElement;
      let revealTimer = window.setTimeout(() => {
        root.classList.add('page-is-loading');
      }, 220);

      const finish = () => {
        if (revealTimer) {
          window.clearTimeout(revealTimer);
          revealTimer = null;
        }
        root.classList.remove('page-is-loading');
      };

      if (document.readyState === 'complete') {
        finish();
      } else {
        window.addEventListener('load', finish, { once: true });
        window.addEventListener('pageshow', finish, { once: true });
      }
    })();
  </script>
<% } %>
