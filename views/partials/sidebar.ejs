<div class="user-sidebar-shell">
  <aside class="user-sidebar <%= mode === 'admin' ? 'admin-sidebar' : 'user-sidebar-user' %>">
    <div class="user-sidebar-brand" aria-hidden="true">
      <img src="/images/7.png" alt="" />
    </div>

    <nav class="user-sidebar-nav">
      <% if (mode === 'admin') { %>
        <a class="user-sidebar-link <%= activePage === 'dashboard' ? 'is-active' : '' %>" href="/admin/dashboard">
          <span class="user-sidebar-icon"><i class="fa-solid fa-house"></i></span>
          <span>Dashboard</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'users' ? 'is-active' : '' %>" href="/admin/users">
          <span class="user-sidebar-icon"><i class="fa-solid fa-users"></i></span>
          <span>User</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'trending' ? 'is-active' : '' %>" href="/admin/trending">
          <span class="user-sidebar-icon"><i class="fa-solid fa-arrow-trend-up"></i></span>
          <span>Trending</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'reports' ? 'is-active' : '' %>" href="/admin/reports">
          <span class="user-sidebar-icon"><i class="fa-solid fa-flag"></i></span>
          <span>Reports</span>
        </a>
      <% } else { %>
        <a class="user-sidebar-link <%= activePage === 'dashboard' ? 'is-active' : '' %>" href="/dashboard">
          <span class="user-sidebar-icon"><i class="fa-solid fa-house"></i></span>
          <span>Dashboard</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'fyp' ? 'is-active' : '' %>" href="/recipes">
          <span class="user-sidebar-icon"><i class="fa-solid fa-compass"></i></span>
          <span>FYP</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'recipes' ? 'is-active' : '' %>" href="/recipe-menu">
          <span class="user-sidebar-icon"><i class="fa-solid fa-bowl-food"></i></span>
          <span>Resep</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'shopping-list' ? 'is-active' : '' %>" href="/shopping-list">
          <span class="user-sidebar-icon"><i class="fa-solid fa-cart-shopping"></i></span>
          <span>Shopping List</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'chat' ? 'is-active' : '' %>" href="/chat-ai">
          <span class="user-sidebar-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
          <span>AI Chat</span>
        </a>
        <a class="user-sidebar-link <%= activePage === 'history' ? 'is-active' : '' %>" href="/chat-history">
          <span class="user-sidebar-icon"><i class="fa-solid fa-clock-rotate-left"></i></span>
          <span>History</span>
        </a>
      <% } %>
    </nav>

    <form action="/logout" method="post" class="user-sidebar-logout">
      <button type="submit" class="user-icon-button user-icon-button-soft">Logout</button>
    </form>
  </aside>
</div>
