<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <%- include('partials/favicon') %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    html,
    body.history-page {
      height: 100%;
      overflow: hidden;
    }

    body.history-page {
      background:
        radial-gradient(circle at top left, rgba(56, 156, 154, 0.16), transparent 28%),
        radial-gradient(circle at bottom right, rgba(254, 219, 113, 0.2), transparent 24%),
        linear-gradient(180deg, #f5f7f4 0%, #eef3ee 100%);
    }

    .chat-history-main {
      display: grid;
      grid-template-rows: auto auto minmax(0, 1fr);
      gap: 18px;
      padding: 20px;
      border-radius: 34px;
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(248, 251, 248, 0.92)),
        linear-gradient(135deg, rgba(56, 156, 154, 0.04), transparent 48%);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 24px 70px rgba(29, 29, 29, 0.08);
      min-width: 0;
      min-height: 0;
      height: calc(100dvh - 28px);
      overflow: hidden;
    }

    .chat-history-topbar {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      padding: 20px 22px;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 18px 36px rgba(29, 29, 29, 0.08);
    }

    .chat-history-topbar h1 {
      margin: 6px 0 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(1.7rem, 2.4vw, 2.5rem);
      letter-spacing: -0.04em;
      line-height: 1.02;
    }

    .chat-history-topbar p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      max-width: 72ch;
    }

    .chat-history-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: flex-end;
    }

    .chat-history-summary {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }

    .chat-history-summary-card,
    .chat-history-panel,
    .chat-history-sessions,
    .chat-history-empty {
      padding: 22px;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.92);
      border: 1px solid rgba(29, 29, 29, 0.06);
      box-shadow: 0 14px 34px rgba(29, 29, 29, 0.06);
    }

    .chat-history-summary-card {
      display: grid;
      gap: 6px;
      padding: 18px 20px;
      background:
        radial-gradient(circle at top left, rgba(56, 156, 154, 0.12), transparent 30%),
        linear-gradient(135deg, rgba(254, 219, 113, 0.16), rgba(255, 255, 255, 0.96));
    }

    .chat-history-summary-card h2 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(1.2rem, 1.7vw, 1.8rem);
      line-height: 1.05;
      letter-spacing: -0.04em;
    }

    .chat-history-summary-card span {
      color: var(--muted);
      line-height: 1.45;
      font-size: 0.94rem;
    }

    .chat-history-layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 18px;
      align-items: stretch;
      min-height: 0;
      overflow: hidden;
    }

    .chat-history-list {
      display: grid;
      gap: 14px;
      align-content: start;
    }

    .chat-history-session-list {
      display: grid;
      gap: 10px;
    }

    .chat-history-sessions,
    .chat-history-panel {
      display: flex;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;
    }

    .chat-history-sessions {
      gap: 12px;
    }

    .chat-history-sessions > .chat-history-session-list,
    .chat-history-panel > .chat-history-list {
      flex: 1 1 auto;
      min-height: 0;
      overflow-y: auto;
      padding-right: 4px;
    }

    .chat-history-session-link {
      display: grid;
      gap: 6px;
      padding: 14px 16px;
      border-radius: 18px;
      background: #faf9f6;
      border: 1px solid rgba(29, 29, 29, 0.06);
      color: inherit;
      text-decoration: none;
      box-shadow: 0 8px 18px rgba(29, 29, 29, 0.04);
    }

    .chat-history-session-link.is-active {
      background: rgba(56, 156, 154, 0.1);
      border-color: rgba(56, 156, 154, 0.22);
    }

    .chat-history-session-link strong {
      font-family: "Space Grotesk", sans-serif;
      font-size: 1rem;
      line-height: 1.2;
    }

    .chat-history-session-link span {
      color: var(--muted);
      line-height: 1.45;
      font-size: 0.88rem;
    }

    .chat-history-item {
      display: grid;
      gap: 12px;
      max-width: min(860px, 100%);
      padding: 18px;
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: 0 10px 22px rgba(29, 29, 29, 0.06);
    }

    .chat-history-item.user {
      justify-self: end;
      background: linear-gradient(180deg, #dcf8e4 0%, #c7efd2 100%);
    }

    .chat-history-item.ai {
      justify-self: start;
    }

    .chat-history-item-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .chat-history-item-head strong {
      color: var(--accent-dark);
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .chat-history-item-head span {
      color: var(--muted);
      font-size: 0.82rem;
    }

    .chat-history-body {
      line-height: 1.75;
      word-break: break-word;
    }

    .chat-history-body p,
    .chat-history-body ul,
    .chat-history-body ol {
      margin: 0 0 10px;
    }

    .chat-history-body p:last-child,
    .chat-history-body ul:last-child,
    .chat-history-body ol:last-child {
      margin-bottom: 0;
    }

    .chat-history-body ul,
    .chat-history-body ol {
      padding-left: 20px;
    }

    .chat-history-attachment img {
      width: 100%;
      max-width: 320px;
      border-radius: 18px;
      display: block;
      border: 1px solid rgba(29, 29, 29, 0.08);
    }

    .chat-history-followups {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chat-history-followups span {
      display: inline-flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(56, 156, 154, 0.1);
      color: var(--accent-dark);
      font-size: 0.86rem;
      font-weight: 700;
    }

    .chat-history-empty {
      display: grid;
      gap: 12px;
      justify-items: start;
    }

    .chat-history-empty i {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 16px;
      background: rgba(56, 156, 154, 0.12);
      color: var(--accent-dark);
      font-size: 1.1rem;
    }

    .chat-history-empty h3 {
      margin: 0;
      font-family: "Space Grotesk", sans-serif;
      letter-spacing: -0.03em;
    }

    .chat-history-session-drawer-toggle {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .chat-history-session-drawer,
    .chat-history-session-drawer-button,
    .chat-history-session-drawer-backdrop {
      display: none;
    }

    @media (max-width: 860px) {
      html,
      body.history-page {
        overflow: auto;
      }

      .chat-history-summary {
        grid-template-columns: 1fr;
      }

      .chat-history-layout {
        grid-template-columns: 1fr;
        overflow: visible;
      }

      .chat-history-topbar {
        flex-direction: column;
      }

      .chat-history-actions {
        justify-content: flex-start;
      }

      .chat-history-main {
        grid-template-rows: auto auto auto;
        height: auto;
        overflow: visible;
      }

      .chat-history-sessions,
      .chat-history-panel,
      .chat-history-sessions > .chat-history-session-list,
      .chat-history-panel > .chat-history-list {
        overflow: visible;
      }
    }

    @media (max-width: 560px) {
      .chat-history-main {
        padding: 14px;
        gap: 14px;
        border-radius: 0;
        border: 0;
        box-shadow: none;
      }

      .chat-history-topbar,
      .chat-history-summary-card,
      .chat-history-panel,
      .chat-history-empty {
        padding: 16px;
        border-radius: 20px;
      }

      .chat-history-topbar h1 {
        font-size: clamp(1.45rem, 8vw, 1.9rem);
      }

      .chat-history-topbar p {
        font-size: 0.94rem;
        line-height: 1.5;
      }

      .chat-history-actions {
        width: 100%;
      }

      .chat-history-actions .button {
        width: 100%;
      }

      .chat-history-summary {
        gap: 12px;
      }

      .chat-history-layout {
        gap: 12px;
      }

      .chat-history-panel {
        padding-bottom: calc(108px + env(safe-area-inset-bottom));
      }

      .chat-history-session-drawer-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        min-height: 46px;
        padding: 0 16px;
        border-radius: 999px;
        background: rgba(56, 156, 154, 0.12);
        color: var(--accent-dark);
        font-weight: 800;
        box-shadow: 0 10px 22px rgba(56, 156, 154, 0.08);
        cursor: pointer;
      }

      .chat-history-layout > .chat-history-sessions:not(.chat-history-session-drawer) {
        display: none;
      }

      .chat-history-session-drawer-backdrop {
        position: fixed;
        inset: 0;
        display: block;
        background: rgba(15, 23, 20, 0.34);
        opacity: 0;
        pointer-events: none;
        transition: opacity 180ms ease;
        z-index: 79;
      }

      .chat-history-session-drawer {
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 80;
        width: min(88vw, 360px);
        padding: 18px 14px calc(24px + env(safe-area-inset-bottom));
        border-radius: 0 26px 26px 0;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(29, 29, 29, 0.08);
        box-shadow: 18px 0 40px rgba(29, 29, 29, 0.16);
        transform: translateX(calc(-100% - 24px));
        transition: transform 220ms ease;
        overflow-y: auto;
      }

      .chat-history-session-drawer-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        position: sticky;
        top: -18px;
        z-index: 2;
        margin: -18px -14px 14px;
        padding: 18px 14px 14px;
        background: rgba(255, 255, 255, 0.98);
        border-bottom: 1px solid rgba(29, 29, 29, 0.06);
      }

      .chat-history-session-drawer-head strong {
        font-family: "Space Grotesk", sans-serif;
        font-size: 1.05rem;
        letter-spacing: -0.03em;
      }

      .chat-history-session-drawer-close {
        display: inline-grid;
        place-items: center;
        width: 38px;
        height: 38px;
        border-radius: 999px;
        background: rgba(29, 29, 29, 0.06);
        color: var(--text);
        cursor: pointer;
      }

      .chat-history-session-drawer-toggle:checked ~ .chat-history-layout .chat-history-session-drawer {
        transform: translateX(0);
      }

      .chat-history-session-drawer-toggle:checked ~ .chat-history-layout .chat-history-session-drawer-backdrop {
        opacity: 1;
        pointer-events: auto;
      }

      .chat-history-item {
        padding: 14px;
        border-radius: 18px;
      }

      .chat-history-item-head {
        align-items: flex-start;
        flex-direction: column;
        gap: 4px;
      }

      .chat-history-body {
        line-height: 1.65;
      }
    }
  </style>
</head>
<body class="history-page">
  <div class="page-bg"></div>

  <% const data = chatHistoryData || { sessionId: '', totalMessages: 0, messages: [], sessions: [] }; %>
  <% const selectedSession = (data.sessions || []).find((item) => item.session_id === data.sessionId) || null; %>

  <main class="user-dashboard history-dashboard">
    <div class="user-dashboard-shell history-dashboard-shell">
      <%- include('partials/sidebar', { mode: 'user', activePage: 'chat', user }) %>

      <section class="user-dashboard-main chat-history-main">
        <header class="user-dashboard-topbar chat-history-topbar">
          <div>
            <p class="user-panel-kicker">History chat</p>
            <h1>Riwayat percakapan AI</h1>
            <p>Semua pesan dari sesi chat aktif tersimpan di sini, termasuk lampiran foto dan balasan AI.</p>
          </div>

          <div class="chat-history-actions">
            <a href="/chat-ai" class="button button-secondary">Kembali ke chat</a>
          </div>
        </header>

        <section class="chat-history-summary" aria-label="Ringkasan history chat">
          <article class="chat-history-summary-card">
            <p class="user-panel-kicker">Sesi terpilih</p>
            <h2><%= selectedSession?.title || 'Sesi chat' %></h2>
            <span><%= data.sessionId || 'Belum ada sesi terpilih.' %></span>
          </article>

          <article class="chat-history-summary-card">
            <p class="user-panel-kicker">Total pesan</p>
            <h2><%= data.totalMessages || 0 %></h2>
            <span>Jumlah pesan user dan AI dalam sesi ini.</span>
          </article>

          <article class="chat-history-summary-card">
            <p class="user-panel-kicker">Total sesi</p>
            <h2><%= (data.sessions || []).length %></h2>
            <span>Jumlah sesi chat yang tersimpan untuk akun ini.</span>
          </article>
        </section>

        <input type="checkbox" class="chat-history-session-drawer-toggle" id="chatHistorySessionDrawer" />
        <div class="chat-history-layout">
          <label class="chat-history-session-drawer-button" for="chatHistorySessionDrawer">
            <i class="fa-regular fa-message" aria-hidden="true"></i>
            <span>Pilih sesi</span>
          </label>

          <aside class="chat-history-sessions">
            <div class="chat-history-session-list">
              <% if ((data.sessions || []).length) { %>
                <% data.sessions.forEach((session) => { %>
                  <a
                    href="/chat-history?session=<%= encodeURIComponent(session.session_id) %>"
                    class="chat-history-session-link <%= session.session_id === data.sessionId ? 'is-active' : '' %>"
                  >
                    <strong><%= session.title || 'Sesi chat tanpa judul' %></strong>
                    <span><%= session.message_count || 0 %> pesan</span>
                    <span><%= session.updated_at_label || '-' %></span>
                  </a>
                <% }) %>
              <% } else { %>
                <div class="chat-history-empty">
                  <i class="fa-regular fa-message"></i>
                  <h3>Belum ada sesi chat</h3>
                  <p>Mulai percakapan baru di AI Chat, lalu sesinya akan muncul di sini.</p>
                </div>
              <% } %>
            </div>
          </aside>

          <label class="chat-history-session-drawer-backdrop" for="chatHistorySessionDrawer" aria-hidden="true"></label>

          <aside class="chat-history-sessions chat-history-session-drawer">
            <div class="chat-history-session-drawer-head">
              <strong>Pilih sesi chat</strong>
              <label class="chat-history-session-drawer-close" for="chatHistorySessionDrawer" aria-label="Tutup daftar sesi">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
              </label>
            </div>
            <div class="chat-history-session-list">
              <% if ((data.sessions || []).length) { %>
                <% data.sessions.forEach((session) => { %>
                  <a
                    href="/chat-history?session=<%= encodeURIComponent(session.session_id) %>"
                    class="chat-history-session-link <%= session.session_id === data.sessionId ? 'is-active' : '' %>"
                  >
                    <strong><%= session.title || 'Sesi chat tanpa judul' %></strong>
                    <span><%= session.message_count || 0 %> pesan</span>
                    <span><%= session.updated_at_label || '-' %></span>
                  </a>
                <% }) %>
              <% } else { %>
                <div class="chat-history-empty">
                  <i class="fa-regular fa-message"></i>
                  <h3>Belum ada sesi chat</h3>
                  <p>Mulai percakapan baru di AI Chat, lalu sesinya akan muncul di sini.</p>
                </div>
              <% } %>
            </div>
          </aside>

          <section class="chat-history-panel">
            <div class="chat-history-list">
              <% if (data.messages.length) { %>
                <% data.messages.forEach((message) => { %>
                  <article class="chat-history-item <%= message.role === 'ai' ? 'ai' : 'user' %>">
                    <div class="chat-history-item-head">
                      <strong><%= message.label || (message.role === 'ai' ? 'AI' : 'You') %></strong>
                      <span><%= message.createdAtLabel || '-' %></span>
                    </div>

                    <% if (message.attachment && message.attachment.dataUrl) { %>
                      <figure class="chat-history-attachment">
                        <img src="<%= message.attachment.dataUrl %>" alt="<%= message.attachment.name || 'Lampiran chat' %>" />
                      </figure>
                    <% } %>

                    <div class="chat-history-body"><%- message.html %></div>

                    <% if (message.followUps && message.followUps.length) { %>
                      <div class="chat-history-followups">
                        <% message.followUps.forEach((item) => { %>
                          <span><%= item %></span>
                        <% }) %>
                      </div>
                    <% } %>
                  </article>
                <% }) %>
              <% } else { %>
                <div class="chat-history-empty">
                  <i class="fa-regular fa-message"></i>
                  <h3>Belum ada history chat</h3>
                  <p>Belum ada pesan di sesi ini. Coba pilih sesi lain atau mulai percakapan baru.</p>
                  <a href="/chat-ai" class="button button-secondary">Buka AI chat</a>
                </div>
              <% } %>
            </div>
          </section>
        </div>
      </section>
    </div>
  </main>
</body>
</html>
