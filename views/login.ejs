<!DOCTYPE html>
<html lang="en">
  <head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script>
    (() => {
      try {
        if (window.sessionStorage.getItem("auth-switch-target") === "/login") {
          document.documentElement.classList.add("auth-skip-intro");
        }
      } catch (error) {
        void error;
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body class="page-transition auth-page">
    <main class="login-page auth-page auth-page-login">
      <section class="visual-panel">
        <div class="visual-outline"></div>
        <div class="visual-strip"></div>

        <div class="plate-stack">
          <figure class="plate plate-primary">
            <img src="/images/3.png" alt="Noodle bowl" />
          </figure>
          <figure class="plate plate-secondary">
            <img src="/images/2.png" alt="Spicy dish" />
          </figure>
          <figure class="plate plate-tertiary">
            <img src="/images/1.png" alt="Vegetable soup" />
          </figure>
        </div>

        <div class="brand-badge">
          <img src="/images/7.png" alt="Logo ResepKu" />
          <div>
            <strong>ResepKu</strong>
            <small>Smart meal ideas for every day</small>
          </div>
        </div>
      </section>

      <section class="form-panel">
        <div class="form-top-accent"></div>
        <div class="corner-leaf corner-leaf-top"></div>
        <div class="corner-leaf corner-leaf-bottom"></div>

        <div class="form-shell">
          <div class="form-card">
            <p class="eyebrow">Welcome back</p>
            <h1>Sign in to ResepKu</h1>

            <% if (error) { %>
              <div class="auth-alert landing-alert"><%= error %></div>
            <% } %>

            <% if (typeof notice !== "undefined" && notice) { %>
              <div class="auth-alert landing-alert landing-alert-success"><%= notice %></div>
            <% } %>

            <div class="login-panel">
              <form class="login-form" action="/login" method="post">
                <label class="sr-only" for="email">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="E-mail"
                  value="<%= (values && values.email) || '' %>"
                />

                <label class="sr-only" for="password">Password</label>
                <div class="password-field">
                  <input
                    id="password"
                    name="password"
                    type="password"
                    placeholder="Password"
                  />
                  <button type="button" class="password-toggle" data-password-toggle data-target="password" aria-label="Tampilkan password">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z"></path>
                      <circle cx="12" cy="12" r="3"></circle>
                      <path class="eye-slash" d="M4 4l16 16"></path>
                    </svg>
                  </button>
                </div>

                <a class="helper-link" href="/forgot-password">Forgot password?</a>
                <button type="submit">Login</button>
              </form>
            </div>

            <div class="divider">
              <span></span>
              <p>Or continue with</p>
              <span></span>
            </div>

            <div class="social-grid">
              <a href="/auth/google?source=login" class="social-btn">
                <span class="social-icon google">G</span>
                Continue with Google
              </a>
            </div>

            <p class="signup-copy">
              Don't have an account?
              <a href="/register">Register</a>
            </p>
          </div>
        </div>
      </section>
    </main>
    <script>
      (() => {
        const shouldSkipIntro = document.documentElement.classList.contains("auth-skip-intro");

        if (shouldSkipIntro) {
          document.body.classList.add("is-ready");
          try {
            window.sessionStorage.removeItem("auth-switch-target");
          } catch (error) {
            void error;
          }
          document.documentElement.classList.remove("auth-skip-intro");
        } else {
          window.requestAnimationFrame(() => {
            window.setTimeout(() => {
              document.body.classList.add("is-ready");
            }, 70);
          });
        }

        const switchLink = document.querySelector('a[href="/register"]');
        const homeLink = document.querySelector('a[href="/"]');

        if (switchLink) {
          switchLink.addEventListener("click", (event) => {
            event.preventDefault();
            try {
              window.sessionStorage.setItem("auth-switch-target", "/register");
            } catch (error) {
              void error;
            }
            document.body.classList.remove("is-ready");
            document.body.classList.add("is-switching-auth", "is-switching-to-register");
            window.setTimeout(() => {
              window.location.href = "/register";
            }, 320);
          });
        }

        [homeLink].filter(Boolean).forEach((link) => {
          link.addEventListener("click", (event) => {
            const href = link.getAttribute("href");
            if (!href) {
              return;
            }

            event.preventDefault();
            document.body.classList.remove("is-ready");
            document.body.classList.add("is-leaving");
            window.setTimeout(() => {
              window.location.href = href;
            }, 320);
          });
        });

        document.querySelectorAll("[data-password-toggle]").forEach((button) => {
          const target = document.getElementById(button.dataset.target || "");
          if (!target) {
            return;
          }

          button.addEventListener("click", () => {
            const showPassword = target.type === "password";
            target.type = showPassword ? "text" : "password";
            button.classList.toggle("is-visible", showPassword);
            button.setAttribute("aria-label", showPassword ? "Sembunyikan password" : "Tampilkan password");
          });
        });
      })();
    </script>
  </body>
</html>
