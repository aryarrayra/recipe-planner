<% const defaultAvatar = (name) => `https://ui-avatars.com/api/?name=${encodeURIComponent(name || 'User')}`; %>
<% const formatDate = (value) => value ? new Date(value).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-'; %>

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/confirm-dialog.js"></script>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const pager = pagination || { page: 1, pageSize: 5, totalItems: users.length, totalPages: 1, hasPrev: false, hasNext: false }; %>
  <% const activeFilters = filters || { search: '', role: '' }; %>
  <% const currentSessionUserId = String(user?.id || ''); %>
  <% const shouldOpenAccordion = Boolean(selectedUser || notice || error); %>
  <% const usersPaginationAnchor = 'users-pagination'; %>
  <% const buildUsersPageUrl = (targetPage, targetUserId = '', anchor = '') => {
    const params = new URLSearchParams();
    params.set('page', String(targetPage));
    if (targetUserId) params.set('userId', targetUserId);
    if (activeFilters.search) params.set('search', activeFilters.search);
    if (activeFilters.role) params.set('role', activeFilters.role);
    return `/admin/users?${params.toString()}${anchor ? `#${anchor}` : ''}`;
  }; %>
  <% const buildPaginationItems = (currentPage, totalPages) => {
    if (totalPages <= 1) return [1];
    const rawItems = [1];
    for (let page = Math.max(2, currentPage - 1); page <= Math.min(totalPages - 1, currentPage + 1); page += 1) {
      rawItems.push(page);
    }
    if (totalPages > 1) rawItems.push(totalPages);

    const uniqueItems = [...new Set(rawItems)].sort((left, right) => left - right);
    const result = [];
    uniqueItems.forEach((page, index) => {
      if (index > 0 && page - uniqueItems[index - 1] > 1) {
        result.push({ type: 'ellipsis', key: `ellipsis-${uniqueItems[index - 1]}-${page}` });
      }
      result.push({ type: 'page', value: page });
    });
    return result;
  }; %>
  <% const pagerItems = buildPaginationItems(pager.page, pager.totalPages); %>
  <% const pageStart = pager.totalItems ? ((pager.page - 1) * pager.pageSize) + 1 : 0; %>
  <% const pageEnd = Math.min(pager.totalItems, pager.page * pager.pageSize); %>
  <main class="user-dashboard admin-dashboard">
    <div class="user-dashboard-shell admin-shell">
      <%- include('../partials/sidebar', { mode: 'admin', activePage, user }) %>

      <section class="user-dashboard-main admin-main">
        <header class="user-dashboard-topbar admin-topbar admin-topbar-slim">
          <div class="admin-topbar-copy">
            <p class="user-panel-kicker">User management</p>
            <h1>Kelola user</h1>
          </div>

          <div class="user-topbar-actions">
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <% if (notice || error) { %>
          <div class="admin-banner <%= error ? 'is-error' : 'is-success' %>">
            <i class="fa-solid <%= error ? 'fa-triangle-exclamation' : 'fa-circle-check' %>" aria-hidden="true"></i>
            <span><%= error || notice %></span>
          </div>
        <% } %>

        <section class="admin-hero-panel">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">User</p>
              <h1><%= selectedUser ? 'Edit user yang dipilih' : 'Tambah user baru' %></h1>
            </div>
          </div>
          <p class="admin-hero-copy">
            Halaman ini memusatkan pengelolaan user: tambah akun, ubah role dan profil, serta hapus
            akun yang sudah tidak dipakai. Data tetap tersimpan di tabel <code>users</code>.
          </p>
        </section>

        <details class="admin-user-accordion" <%= shouldOpenAccordion ? 'open' : '' %>>
          <summary class="admin-user-accordion-summary">
            <div>
              <p class="user-panel-kicker">Form user</p>
              <h2><%= selectedUser ? 'Edit user' : 'Tambah user' %></h2>
            </div>
            <span class="admin-user-accordion-hint">
              <i class="fa-solid fa-chevron-down"></i>
            </span>
          </summary>

          <div class="user-panel admin-panel admin-user-accordion-panel">
            <form
              class="admin-form"
              action="<%= selectedUser ? `/admin/users/${selectedUser.id}` : '/admin/users' %>"
              method="post"
              enctype="multipart/form-data"
            >
              <input type="hidden" name="page" value="<%= pager.page %>" />
              <input type="hidden" name="search" value="<%= activeFilters.search %>" />
              <input type="hidden" name="filter_role" value="<%= activeFilters.role %>" />
              <input type="hidden" name="avatar_url" value="<%= selectedUserForm.avatar_url || '' %>" />
              <div class="admin-form-grid">
                <label class="admin-field">
                  <span>Username</span>
                  <input name="username" value="<%= selectedUserForm.username %>" placeholder="Username" required />
                </label>
                <label class="admin-field">
                  <span>Email</span>
                  <input type="email" name="email" value="<%= selectedUserForm.email %>" placeholder="email@domain.com" required />
                </label>
                <label class="admin-field">
                  <span>Role</span>
                  <select name="role">
                    <option value="user" <%= selectedUserForm.role === 'user' ? 'selected' : '' %>>user</option>
                    <option value="admin" <%= selectedUserForm.role === 'admin' ? 'selected' : '' %>>admin</option>
                  </select>
                </label>
                <label class="admin-field admin-field-wide">
                  <span>Password <%= selectedUser ? '(opsional)' : '' %></span>
                  <input
                    type="password"
                    name="password"
                    placeholder="<%= selectedUser ? 'Kosongkan jika tidak diubah' : 'Password baru' %>"
                    <%= selectedUser ? '' : 'required' %>
                  />
                </label>
                <div class="admin-field admin-field-wide">
                  <span>Avatar</span>
                  <input class="admin-avatar-input" type="file" id="avatarImageInput" name="avatar_image" accept="image/*" />
                  <label class="admin-avatar-picker" for="avatarImageInput">
                    <img
                      id="avatarPreview"
                      src="<%= selectedUserForm.avatar_url || defaultAvatar(selectedUserForm.username || 'User') %>"
                      alt="Preview avatar"
                      referrerpolicy="no-referrer"
                    />
                    <span class="admin-avatar-plus" aria-hidden="true">
                      <i class="fa-solid fa-plus"></i>
                    </span>
                  </label>
                  <small class="admin-field-help">Klik kotaknya untuk upload foto profil. Kalau kosong, avatar default akan dipakai.</small>
                </div>
                <label class="admin-field admin-field-wide">
                  <span>Bio</span>
                  <textarea name="bio" rows="4" placeholder="Bio singkat user"><%= selectedUserForm.bio %></textarea>
                </label>
              </div>

              <div class="admin-form-actions">
                <button type="submit" class="auth-button">
                  <%= selectedUser ? 'Simpan perubahan' : 'Tambah user' %>
                </button>
                <% if (selectedUser) { %>
                  <a class="auth-button auth-button-secondary" href="<%= buildUsersPageUrl(pager.page) %>">Batal edit</a>
                <% } %>
              </div>
            </form>
          </div>
        </details>

        <article class="user-panel">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">User list</p>
              <h2>Data user terbaru</h2>
            </div>
            <span class="user-panel-meta"><%= pager.totalItems %> item</span>
          </div>

          <form class="admin-user-filter-form" method="get" action="/admin/users">
            <input type="hidden" name="userId" value="<%= selectedUser ? selectedUser.id : '' %>" />
            <label class="admin-user-filter-field admin-user-filter-search">
              <span>Cari user</span>
              <input
                type="text"
                name="search"
                value="<%= activeFilters.search %>"
                placeholder="Cari username atau email"
              />
            </label>
            <label class="admin-user-filter-field">
              <span>Filter role</span>
              <select name="role">
                <option value="" <%= !activeFilters.role ? 'selected' : '' %>>Semua role</option>
                <option value="user" <%= activeFilters.role === 'user' ? 'selected' : '' %>>user</option>
                <option value="admin" <%= activeFilters.role === 'admin' ? 'selected' : '' %>>admin</option>
              </select>
            </label>
            <div class="admin-user-filter-actions">
              <button type="submit" class="auth-button">Terapkan</button>
              <a class="auth-button auth-button-secondary" href="<%= selectedUser ? `/admin/users?userId=${encodeURIComponent(selectedUser.id)}` : '/admin/users' %>">Reset</a>
            </div>
          </form>

          <div class="admin-user-list">
            <% users.forEach((item) => { %>
              <% const isCurrentSessionUser = String(item.id || '') === currentSessionUserId; %>
              <% const displayAvatarUrl = isCurrentSessionUser ? (user.avatar_url || item.avatar_url) : item.avatar_url; %>
              <article class="admin-user-card admin-user-card-compact">
                <img
                  src="<%= displayAvatarUrl || defaultAvatar(item.username) %>"
                  alt="<%= item.username %>"
                  referrerpolicy="no-referrer"
                  onerror="this.onerror=null;this.src='<%= defaultAvatar(item.username) %>'"
                />
                <div class="admin-user-copy">
                  <div class="admin-list-topline">
                    <h3><%= item.username %></h3>
                    <span class="admin-status <%= item.role === 'admin' ? 'is-approved' : 'is-neutral' %>"><%= item.role %></span>
                  </div>
                  <p><%= item.email %></p>
                  <div class="admin-meta-row">
                    <span><i class="fa-solid fa-book-bookmark"></i> <%= item.total_saved_recipes || 0 %> favorites</span>
                    <span><i class="fa-solid fa-fire-burner"></i> <%= item.total_recipes_cooked || 0 %> cooked</span>
                  </div>
                  <small><i class="fa-regular fa-calendar"></i> <%= formatDate(item.created_at) %></small>
                  <div class="admin-list-actions">
                    <a class="admin-link" href="<%= buildUsersPageUrl(pager.page, item.id) %>">Edit</a>
                    <form action="/admin/users/<%= item.id %>/delete" method="post" data-confirm-delete="Apakah yakin anda menghapus user ini?" data-confirm-title="Hapus user">
                      <input type="hidden" name="page" value="<%= pager.page %>" />
                      <input type="hidden" name="search" value="<%= activeFilters.search %>" />
                      <input type="hidden" name="filter_role" value="<%= activeFilters.role %>" />
                      <button type="submit" class="admin-link is-danger">Delete</button>
                    </form>
                  </div>
                </div>
              </article>
            <% }) %>

            <% if (!users.length) { %>
              <div class="admin-empty-state">
                <h3>Tidak ada user yang cocok.</h3>
                <p>Coba ubah keyword pencarian atau filter role yang dipakai.</p>
              </div>
            <% } %>
          </div>

          <% if (pager.totalPages > 1) { %>
            <nav class="admin-pagination" id="<%= usersPaginationAnchor %>" aria-label="Pagination user list">
              <% if (pager.hasPrev) { %>
                <a class="admin-pagination-link" href="<%= buildUsersPageUrl(pager.page - 1, selectedUser ? selectedUser.id : '', usersPaginationAnchor) %>" rel="prev">
                  <i class="fa-solid fa-chevron-left"></i>
                  <span class="admin-pagination-link-label">
                    <strong>Sebelumnya</strong>
                    <span>Page <%= pager.page - 1 %></span>
                  </span>
                </a>
              <% } else { %>
                <span class="admin-pagination-link is-disabled" aria-disabled="true">
                  <i class="fa-solid fa-chevron-left"></i>
                  <span class="admin-pagination-link-label">
                    <strong>Sebelumnya</strong>
                    <span>Page pertama</span>
                  </span>
                </span>
              <% } %>

              <div class="admin-pagination-center">
                <div class="admin-pagination-summary">
                  <strong>Halaman <%= pager.page %> dari <%= pager.totalPages %></strong>
                  <span>Menampilkan <%= pageStart %>-<%= pageEnd %> dari <%= pager.totalItems %> user</span>
                  <span class="admin-pagination-summary-compact"><%= pager.page %>/<%= pager.totalPages %></span>
                </div>

                <div class="admin-pagination-pages" aria-label="Daftar halaman user">
                  <% pagerItems.forEach((item) => { %>
                    <% if (item.type === 'ellipsis') { %>
                      <span class="admin-pagination-page is-ellipsis" aria-hidden="true">...</span>
                    <% } else if (item.value === pager.page) { %>
                      <span class="admin-pagination-page is-active" aria-current="page"><%= item.value %></span>
                    <% } else { %>
                      <a class="admin-pagination-page" href="<%= buildUsersPageUrl(item.value, selectedUser ? selectedUser.id : '', usersPaginationAnchor) %>"><%= item.value %></a>
                    <% } %>
                  <% }) %>
                </div>
              </div>

              <% if (pager.hasNext) { %>
                <a class="admin-pagination-link" href="<%= buildUsersPageUrl(pager.page + 1, selectedUser ? selectedUser.id : '', usersPaginationAnchor) %>" rel="next">
                  <span class="admin-pagination-link-label">
                    <strong>Berikutnya</strong>
                    <span>Page <%= pager.page + 1 %></span>
                  </span>
                  <i class="fa-solid fa-chevron-right"></i>
                </a>
              <% } else { %>
                <span class="admin-pagination-link is-disabled" aria-disabled="true">
                  <span class="admin-pagination-link-label">
                    <strong>Berikutnya</strong>
                    <span>Page terakhir</span>
                  </span>
                  <i class="fa-solid fa-chevron-right"></i>
                </span>
              <% } %>
            </nav>
          <% } %>
        </article>

      </section>
    </div>
  </main>
  <script>
    (() => {
      const avatarInput = document.getElementById('avatarImageInput');
      const avatarPreview = document.getElementById('avatarPreview');

      avatarInput?.addEventListener('change', () => {
        const file = avatarInput.files && avatarInput.files[0];
        if (!file || !avatarPreview) {
          return;
        }

        const reader = new FileReader();
        reader.onload = (event) => {
          avatarPreview.src = event.target?.result || avatarPreview.src;
        };
        reader.readAsDataURL(file);
      });
    })();
  </script>
</body>
</html>
