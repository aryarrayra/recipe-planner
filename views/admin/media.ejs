<% const formatDate = (value) => value ? new Date(value).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) : '-'; %>

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <main class="user-dashboard admin-dashboard">
    <div class="user-dashboard-shell admin-shell">
      <%- include('../partials/sidebar', { mode: 'admin', activePage, user }) %>

      <section class="user-dashboard-main admin-main">
        <header class="user-dashboard-topbar admin-topbar admin-topbar-slim">
          <div class="admin-topbar-copy">
            <p class="user-panel-kicker">Video library</p>
            <h1>Media feed resep</h1>
          </div>

          <div class="user-topbar-actions">
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <% if (notice || error) { %>
          <div class="admin-banner <%= error ? 'is-error' : 'is-success' %>">
            <i class="fa-solid <%= error ? 'fa-triangle-exclamation' : 'fa-circle-check' %>" aria-hidden="true"></i>
            <span><%= error || notice %></span>
          </div>
        <% } %>

        <section class="admin-hero-panel">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">Library</p>
              <h1><%= selectedMedia ? 'Edit media yang dipilih' : 'Tambah media baru' %></h1>
            </div>
            <div class="admin-hero-actions">
              <a class="auth-button auth-button-secondary" href="/admin/recipes">Buka CRUD resep</a>
            </div>
          </div>
          <p class="admin-hero-copy">
            Media di halaman ini dipakai sebagai sumber video otomatis untuk feed user.
            Jadi resep bisa tetap disimpan tanpa <code>video_url</code> di form utama.
          </p>
        </section>

        <div class="admin-content-grid">
          <section class="admin-column">
            <article class="user-panel admin-panel" id="media-form">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Form media</p>
                  <h2><%= selectedMedia ? 'Edit media' : 'Tambah media' %></h2>
                </div>
                <% if (selectedMedia) { %>
                  <a class="user-panel-link" href="/admin/media">Batal edit</a>
                <% } %>
              </div>

              <form
                class="admin-form"
                action="<%= selectedMedia ? `/admin/media/${selectedMedia.id}` : '/admin/media' %>"
                method="post"
              >
                <div class="admin-form-grid">
                  <label class="admin-field admin-field-wide">
                    <span>Judul media</span>
                    <input name="title" value="<%= selectedMediaForm.title %>" placeholder="Contoh: Korean street food pick" required />
                  </label>
                  <label class="admin-field">
                    <span>Platform</span>
                    <select name="platform">
                      <option value="youtube" <%= selectedMediaForm.platform === 'youtube' ? 'selected' : '' %>>YouTube</option>
                      <option value="tiktok" <%= selectedMediaForm.platform === 'tiktok' ? 'selected' : '' %>>TikTok</option>
                      <option value="internal" <%= selectedMediaForm.platform === 'internal' ? 'selected' : '' %>>Internal</option>
                    </select>
                  </label>
                  <label class="admin-field">
                    <span>Sort order</span>
                    <input type="number" name="sort_order" value="<%= selectedMediaForm.sort_order %>" />
                  </label>
                  <label class="admin-field">
                    <span>Kategori</span>
                    <input name="category" value="<%= selectedMediaForm.category %>" placeholder="Asian / Local / Dessert" />
                  </label>
                  <label class="admin-field">
                    <span>Cuisine</span>
                    <input name="cuisine" value="<%= selectedMediaForm.cuisine %>" placeholder="Indonesian / Japanese / Western" />
                  </label>
                  <label class="admin-field admin-field-wide">
                    <span>Media URL</span>
                    <input name="media_url" value="<%= selectedMediaForm.media_url %>" placeholder="https://..." />
                    <small class="admin-field-help">Isi link publik TikTok / YouTube / video file. Kalau kosong, item tetap bisa dipakai sebagai metadata library.</small>
                  </label>
                  <label class="admin-field admin-field-wide">
                    <span>Link ke resep</span>
                    <select name="recipe_id">
                      <option value="">Tidak ditautkan</option>
                      <% recipeOptions.forEach((recipe) => { %>
                        <option value="<%= recipe.id %>" <%= selectedMediaForm.recipe_id === recipe.id ? 'selected' : '' %>><%= recipe.title %></option>
                      <% }) %>
                    </select>
                  </label>
                  <label class="admin-field admin-field-wide">
                    <span>Tags</span>
                    <textarea name="tags" rows="3" placeholder="Bisa JSON array atau satu tag per baris"><%= selectedMediaForm.tags %></textarea>
                  </label>
                  <label class="admin-toggle">
                    <input type="checkbox" name="is_active" <%= selectedMediaForm.is_active ? 'checked' : '' %> />
                    <span>Aktifkan media</span>
                  </label>
                </div>

                <div class="admin-form-actions">
                  <button type="submit" class="auth-button">
                    <%= selectedMedia ? 'Simpan perubahan' : 'Tambah media' %>
                  </button>
                </div>
              </form>
            </article>
          </section>

          <aside class="admin-column">
            <article class="user-panel">
              <div class="user-panel-head">
                <div>
                  <p class="user-panel-kicker">Media list</p>
                  <h2>Video library terbaru</h2>
                </div>
                <span class="user-panel-meta"><%= mediaSources.length %> item</span>
              </div>

              <div class="admin-list">
                <% mediaSources.forEach((media) => { %>
                  <article class="admin-list-card admin-media-card">
                    <div class="admin-media-preview">
                      <i class="fa-solid <%= media.platform === 'tiktok' ? 'fa-tiktok' : media.platform === 'youtube' ? 'fa-youtube' : 'fa-film' %>"></i>
                    </div>
                    <div class="admin-list-copy">
                      <div class="admin-list-topline">
                        <h3><%= media.title %></h3>
                        <span class="admin-status <%= media.is_active ? 'is-approved' : 'is-pending' %>">
                          <%= media.is_active ? 'Active' : 'Inactive' %>
                        </span>
                      </div>
                      <p>
                        <%= media.platform %> • <%= media.category || 'no category' %> • <%= media.cuisine || 'no cuisine' %>
                      </p>
                      <div class="admin-meta-row">
                        <span><i class="fa-regular fa-calendar"></i> <%= formatDate(media.created_at) %></span>
                        <span><i class="fa-solid fa-hashtag"></i> <%= media.sort_order || 0 %></span>
                        <span><i class="fa-solid fa-link"></i> <%= media.recipe_title %></span>
                      </div>
                      <div class="admin-media-url"><%= media.media_url || 'Media URL belum diisi' %></div>
                      <div class="admin-list-actions">
                        <a class="admin-link" href="/admin/media?mediaId=<%= media.id %>">Edit</a>
                        <form action="/admin/media/<%= media.id %>/delete" method="post">
                          <button type="submit" class="admin-link is-danger">Delete</button>
                        </form>
                      </div>
                    </div>
                  </article>
                <% }) %>

                <% if (!mediaSources.length) { %>
                  <div class="admin-empty-state">
                    <h3>Belum ada media feed.</h3>
                    <p>Tambahkan sumber video dulu supaya feed user bisa tampil otomatis meski resep tidak punya `video_url`.</p>
                  </div>
                <% } %>
              </div>
            </article>
          </aside>
        </div>
      </section>
    </div>
  </main>
</body>
</html>
