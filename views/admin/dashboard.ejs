<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const dashboardMetrics = metrics || {}; %>
  <% const moderationQueue = Array.isArray(approvalQueue) ? approvalQueue : []; %>
  <% const reportsQueue = Array.isArray(reportQueue) ? reportQueue : []; %>
  <% const insights = secondaryInsights || {}; %>
  <% const auditItems = Array.isArray(auditTrail) ? auditTrail : []; %>
  <% const auditPager = auditPagination || { page: 1, pageSize: 5, totalItems: auditItems.length, totalPages: 1, hasPrev: false, hasNext: false }; %>
  <% const categoryItems = Array.isArray(topCategories) ? topCategories : []; %>
  <% const buildAuditPageUrl = (targetPage) => `/admin/dashboard?auditPage=${targetPage}`; %>
  <% const formatDateTime = (value) => value ? new Date(value).toLocaleString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'; %>
  <% const formatRelativeTime = (value) => {
    if (!value) return 'baru saja';
    const created = new Date(value);
    if (Number.isNaN(created.getTime())) return 'baru saja';
    const diff = Date.now() - created.getTime();
    const minutes = Math.max(0, Math.floor(diff / 60000));
    if (minutes < 1) return 'baru saja';
    if (minutes < 60) return `${minutes}m`;
    const hours = Math.floor(minutes / 60);
    if (hours < 24) return `${hours}h`;
    const days = Math.floor(hours / 24);
    if (days < 7) return `${days}d`;
    return created.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
  }; %>

  <main class="user-dashboard admin-dashboard">
    <div class="user-dashboard-shell admin-shell">
      <%- include('../partials/sidebar', { mode: 'admin', activePage, user }) %>

      <section class="user-dashboard-main admin-main">
        <header class="user-dashboard-topbar admin-topbar admin-topbar-slim">
          <div class="admin-topbar-copy">
            <p class="user-panel-kicker">Admin panel</p>
            <h1>Dashboard operasional platform</h1>
          </div>

          <div class="user-topbar-actions">
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <section class="admin-hero-panel">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">Fokus admin</p>
              <h1>Moderasi resep community, tindak laporan, kelola user, dan pantau kesehatan operasional.</h1>
            </div>
            <div class="admin-hero-actions">
              <a class="auth-button auth-button-secondary" href="/admin/trending">Moderasi resep</a>
              <a class="auth-button auth-button-secondary" href="/admin/reports">Tindak laporan</a>
              <a class="auth-button" href="/admin/users">Kelola user</a>
            </div>
          </div>

          <p class="admin-hero-copy">
            Baris pertama menunjukkan KPI yang butuh perhatian cepat. Baris kedua adalah dua antrean utama yang harus dikerjakan admin. Insight dan audit diletakkan di bawah sebagai konteks pendukung.
          </p>
        </section>

        <section class="admin-stat-grid admin-ops-stat-grid">
          <article class="admin-stat-card">
            <span>Pending recipes</span>
            <strong><%= dashboardMetrics.pending_recipes_count || 0 %></strong>
            <small>Resep community menunggu approval</small>
          </article>
          <article class="admin-stat-card">
            <span>Open reports</span>
            <strong><%= dashboardMetrics.open_reports_count || 0 %></strong>
            <small>Laporan open dan reviewing</small>
          </article>
          <article class="admin-stat-card">
            <span>Total users</span>
            <strong><%= dashboardMetrics.users_count || 0 %></strong>
            <small><%= dashboardMetrics.admin_count || 0 %> admin, <%= dashboardMetrics.user_count || 0 %> user</small>
          </article>
          <article class="admin-stat-card">
            <span>New users</span>
            <strong><%= dashboardMetrics.new_users_today || 0 %> / <%= dashboardMetrics.new_users_week || 0 %></strong>
            <small>Hari ini / 7 hari terakhir</small>
          </article>
        </section>

        <section class="admin-content-grid admin-ops-grid">
          <article class="user-panel admin-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Approval queue</p>
                <h2>Resep community yang menunggu moderasi</h2>
              </div>
              <a class="user-panel-link" href="/admin/trending">Lihat semua</a>
            </div>

            <div class="admin-list">
              <% if (moderationQueue.length) { %>
                <% moderationQueue.forEach((recipe) => { %>
                  <article class="admin-list-card admin-media-card">
                    <img src="<%= recipe.image_url || '/images/1.png' %>" alt="<%= recipe.title %>" />
                    <div class="admin-list-copy">
                      <div class="admin-list-topline">
                        <h3><%= recipe.title %></h3>
                        <span class="admin-status is-pending">Pending</span>
                      </div>
                      <p><%= recipe.description || 'Belum ada deskripsi.' %></p>
                      <div class="admin-meta-row">
                        <span><i class="fa-solid fa-user"></i> <%= recipe.creator_name || 'Community user' %></span>
                        <span><i class="fa-solid fa-layer-group"></i> <%= recipe.category || 'Community' %></span>
                        <span><i class="fa-regular fa-clock"></i> <%= formatRelativeTime(recipe.created_at) %></span>
                      </div>
                      <div class="admin-list-actions">
                        <form action="/admin/trending/<%= encodeURIComponent(recipe.id) %>/approve" method="post">
                          <button type="submit" class="auth-button">Approve</button>
                        </form>
                        <form action="/admin/trending/<%= encodeURIComponent(recipe.id) %>/reject" method="post">
                          <button type="submit" class="auth-button auth-button-secondary">Reject</button>
                        </form>
                      </div>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <div class="admin-empty-state">
                  <h3>Approval queue kosong.</h3>
                  <p>Tidak ada resep community yang menunggu moderasi saat ini.</p>
                </div>
              <% } %>
            </div>
          </article>

          <article class="user-panel admin-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Report queue</p>
                <h2>Laporan yang harus ditindak</h2>
              </div>
              <a class="user-panel-link" href="/admin/reports">Lihat semua</a>
            </div>

            <div class="admin-list">
              <% if (reportsQueue.length) { %>
                <% reportsQueue.forEach((report) => { %>
                  <article class="admin-user-card admin-report-card">
                    <div class="admin-media-preview">
                      <i class="fa-solid fa-flag"></i>
                    </div>
                    <div class="admin-user-copy">
                      <div class="admin-list-topline">
                        <h3><%= report.reason || 'Report' %></h3>
                        <span class="admin-status <%= report.status === 'open' ? 'is-pending' : 'is-neutral' %>"><%= report.status %></span>
                      </div>
                      <p><%= report.details || report.target_title || 'Laporan belum memiliki detail tambahan.' %></p>
                      <div class="admin-meta-row">
                        <span><i class="fa-solid fa-user"></i> <%= report.reporter_name || 'Unknown user' %></span>
                        <span><i class="fa-solid fa-crosshairs"></i> <%= report.target_type || 'target' %></span>
                        <span><i class="fa-regular fa-clock"></i> <%= formatRelativeTime(report.created_at) %></span>
                      </div>
                      <% if (report.reported_name || report.target_title) { %>
                        <small>
                          <%= report.reported_name ? `Terlapor: ${report.reported_name}` : `Target: ${report.target_title}` %>
                        </small>
                      <% } %>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <div class="admin-empty-state">
                  <h3>Tidak ada laporan terbuka.</h3>
                  <p>Queue laporan sedang bersih.</p>
                </div>
              <% } %>
            </div>
          </article>
        </section>

        <section class="admin-dashboard-stack">
          <article class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Platform insight</p>
                <h2>Insight sekunder</h2>
              </div>
            </div>

            <div class="admin-analytics-periods">
              <article class="admin-analytics-card">
                <span>Top category</span>
                <strong><%= insights.topCategory ? insights.topCategory.category : '-' %></strong>
                <small><%= insights.topCategory ? `${insights.topCategory.recipe_count} recipe • ${insights.topCategory.likes_count} likes` : 'Belum ada data kategori' %></small>
              </article>
              <article class="admin-analytics-card">
                <span>Total engagement</span>
                <strong><%= insights.totalEngagement || 0 %></strong>
                <small>Gabungan likes dan wishlist</small>
              </article>
              <article class="admin-analytics-card">
                <span>Resolved reports</span>
                <strong><%= insights.resolvedReports || 0 %></strong>
                <small>Kasus yang sudah ditutup</small>
              </article>
            </div>

            <div class="admin-category-list">
              <% if (categoryItems.length) { %>
                <% categoryItems.slice(0, 4).forEach((item, index) => { %>
                  <article class="admin-category-card">
                    <div class="admin-category-rank">#<%= index + 1 %></div>
                    <div class="admin-category-copy">
                      <h3><%= item.category %></h3>
                      <p><%= item.recipe_count %> recipe <span>&middot;</span> <%= item.likes_count %> likes <span>&middot;</span> <%= item.views_count %> views</p>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <div class="admin-empty-state">
                  <h3>Belum ada insight kategori.</h3>
                  <p>Data kategori akan muncul setelah resep mulai aktif digunakan.</p>
                </div>
              <% } %>
            </div>
          </article>

          <article class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Audit activity</p>
                <h2>Aktivitas penting terbaru</h2>
              </div>
              <span class="user-panel-meta"><%= auditPager.totalItems %> item</span>
            </div>

            <div class="admin-list admin-audit-list">
              <% if (auditItems.length) { %>
                <% auditItems.forEach((item) => { %>
                  <article class="admin-audit-card">
                    <div class="admin-audit-icon">
                      <% if (item.event_type === 'new_user') { %>
                        <i class="fa-solid fa-user-plus"></i>
                      <% } else if (item.event_type === 'recipe_submission') { %>
                        <i class="fa-solid fa-bowl-food"></i>
                      <% } else { %>
                        <i class="fa-solid fa-flag"></i>
                      <% } %>
                    </div>
                    <div class="admin-audit-copy">
                      <div class="admin-list-topline">
                        <h3><%= item.event_title || 'Aktivitas' %></h3>
                        <span class="admin-status is-neutral"><%= item.event_label || '-' %></span>
                      </div>
                      <p><strong><%= item.actor_name || 'System' %></strong> • <%= item.event_meta || '-' %></p>
                      <small><i class="fa-regular fa-clock"></i> <%= formatDateTime(item.event_time) %></small>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <div class="admin-empty-state">
                  <h3>Belum ada audit activity.</h3>
                  <p>Aktivitas penting akan muncul di sini.</p>
                </div>
              <% } %>
            </div>

            <% if (auditPager.totalPages > 1) { %>
              <nav class="admin-pagination" aria-label="Pagination audit activity">
                <a class="admin-pagination-link <%= !auditPager.hasPrev ? 'is-disabled' : '' %>" href="<%= auditPager.hasPrev ? buildAuditPageUrl(auditPager.page - 1) : '#' %>">
                  <i class="fa-solid fa-chevron-left"></i>
                  <span>Prev</span>
                </a>

                <div class="admin-pagination-summary">
                  <strong>Halaman <%= auditPager.page %></strong>
                  <span>dari <%= auditPager.totalPages %> | <%= auditPager.pageSize %> per halaman</span>
                </div>

                <a class="admin-pagination-link <%= !auditPager.hasNext ? 'is-disabled' : '' %>" href="<%= auditPager.hasNext ? buildAuditPageUrl(auditPager.page + 1) : '#' %>">
                  <span>Next</span>
                  <i class="fa-solid fa-chevron-right"></i>
                </a>
              </nav>
            <% } %>
          </article>
        </section>
      </section>
    </div>
  </main>
</body>
</html>
