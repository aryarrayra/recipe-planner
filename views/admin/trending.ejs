<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <% const moderationStatsData = moderationStats || { pending: 0, approved: 0, total: 0 }; %>
  <% const approvedCommunityRecipesData = approvedCommunityRecipes || []; %>
  <% const formatChallengeDate = (value) => value ? new Date(value).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'; %>

  <main class="user-dashboard admin-dashboard admin-community-page">
    <div class="user-dashboard-shell admin-shell">
      <%- include('../partials/sidebar', { mode: 'admin', activePage, user }) %>

      <section class="user-dashboard-main admin-main">
        <header class="user-dashboard-topbar admin-topbar admin-topbar-slim">
          <div class="admin-topbar-copy">
            <p class="user-panel-kicker">Community overview</p>
            <h1>Resep community langsung tampil ke feed</h1>
          </div>

          <div class="user-topbar-actions">
            <div class="user-profile-pill">
              <strong><%= user.username %></strong>
              <span><%= user.role %></span>
            </div>
          </div>
        </header>

        <% if (notice || error) { %>
          <div class="admin-banner <%= error ? 'is-error' : 'is-success' %>">
            <i class="fa-solid <%= error ? 'fa-triangle-exclamation' : 'fa-circle-check' %>" aria-hidden="true"></i>
            <span><%= error || notice %></span>
          </div>
        <% } %>

        <section class="admin-hero-panel user-panel">
          <div class="user-panel-head">
            <div>
              <p class="user-panel-kicker">Ringkasan</p>
              <h2>Daily dan weekly challenge berjalan otomatis dari API. Admin cukup memantau community feed.</h2>
            </div>
          </div>

          <div class="admin-approval-summary">
            <article class="admin-stat-card">
              <span>Published community</span>
              <strong><%= moderationStatsData.approved || 0 %></strong>
              <small>Sudah tampil di feed</small>
            </article>
            <article class="admin-stat-card">
              <span>Total community</span>
              <strong><%= moderationStatsData.total || 0 %></strong>
              <small>Semua posting user</small>
            </article>
            <article class="admin-stat-card">
              <span>Auto challenge</span>
              <strong>ON</strong>
              <small>Daily dan weekly dari API</small>
            </article>
          </div>
        </section>

        <div class="admin-approval-grid">
          <article class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Auto challenge</p>
                <h2>Daily challenge</h2>
              </div>
            </div>

            <% if (dailyChallenge) { %>
              <article class="admin-approval-card">
                <img src="<%= dailyChallenge.image_url || '/images/1.png' %>" alt="<%= dailyChallenge.title %>" />
                <div class="admin-list-copy">
                  <h3><%= dailyChallenge.title %></h3>
                  <p><%= dailyChallenge.category || 'Uncategorized' %> &bull; <%= dailyChallenge.cuisine || 'International' %></p>
                  <div class="admin-approval-meta">
                    <span><i class="fa-regular fa-clock"></i> <%= dailyChallenge.cooking_time || 0 %> min</span>
                    <span><i class="fa-solid fa-heart"></i> <%= dailyChallenge.likes_count || 0 %> likes</span>
                    <span><i class="fa-solid fa-eye"></i> <%= dailyChallenge.views_count || 0 %> views</span>
                  </div>
                </div>
              </article>
            <% } else { %>
              <div class="community-empty-state">
                <h3>Daily challenge belum tersedia.</h3>
                <p>API akan mengisi challenge ini otomatis setiap hari.</p>
              </div>
            <% } %>
          </article>

          <article class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Auto challenge</p>
                <h2>Weekly challenge</h2>
              </div>
            </div>

            <% if (weeklyChallenge) { %>
              <article class="admin-approval-card">
                <img src="<%= weeklyChallenge.image_url || '/images/1.png' %>" alt="<%= weeklyChallenge.title %>" />
                <div class="admin-list-copy">
                  <h3><%= weeklyChallenge.title %></h3>
                  <p><%= weeklyChallenge.category || 'Uncategorized' %> &bull; <%= weeklyChallenge.cuisine || 'International' %></p>
                  <div class="admin-approval-meta">
                    <span><i class="fa-regular fa-clock"></i> <%= weeklyChallenge.cooking_time || 0 %> min</span>
                    <span><i class="fa-solid fa-heart"></i> <%= weeklyChallenge.likes_count || 0 %> likes</span>
                    <span><i class="fa-solid fa-eye"></i> <%= weeklyChallenge.views_count || 0 %> views</span>
                  </div>
                </div>
              </article>
            <% } else { %>
              <div class="community-empty-state">
                <h3>Weekly challenge belum tersedia.</h3>
                <p>API akan memilih variasi resep mingguan secara otomatis.</p>
              </div>
            <% } %>
          </article>
        </div>

        <section class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Community posts</p>
                <h2>Resep community terbaru</h2>
              </div>
              <span class="user-panel-meta"><%= approvedCommunityRecipesData.length %> item</span>
            </div>

            <div class="admin-approval-grid">
            <% if (approvedCommunityRecipesData.length) { %>
              <% approvedCommunityRecipesData.forEach((recipe) => { %>
                <% const isDeletedRecipe = Boolean(recipe.is_deleted || recipe.post_is_deleted); %>
                <article class="admin-approval-card <%= isDeletedRecipe ? 'is-deleted' : '' %>">
                  <img src="<%= recipe.image_url || '/images/1.png' %>" alt="<%= recipe.title %>" />
                  <div class="admin-list-copy">
                    <div class="admin-list-topline">
                      <h3><%= recipe.title %></h3>
                      <% if (isDeletedRecipe) { %>
                        <span class="community-status is-deleted">DELETED</span>
                      <% } %>
                    </div>
                    <p><%= recipe.category || 'Community' %> &bull; <%= recipe.cuisine || 'Community' %></p>
                    <div class="admin-approval-meta">
                      <span><i class="fa-solid fa-user"></i> <%= recipe.creator_name || 'Community user' %></span>
                      <span><i class="fa-regular fa-clock"></i> <%= recipe.cooking_time || 0 %> min</span>
                      <span><i class="fa-solid fa-wallet"></i> Rp <%= new Intl.NumberFormat('id-ID').format(Number(recipe.estimated_price || 0)) %></span>
                      <span><i class="fa-regular fa-calendar"></i> <%= formatChallengeDate(recipe.created_at) %></span>
                    </div>
                    <p class="admin-approval-note">
                      <%= recipe.description || 'Belum ada deskripsi.' %>
                    </p>
                  </div>
                </article>
              <% }) %>
            <% } else { %>
              <div class="community-empty-state">
                <h3>Belum ada resep community.</h3>
                <p>Posting yang dibuat user akan langsung muncul di sini.</p>
              </div>
            <% } %>
          </div>
        </section>

        <section class="user-panel">
            <div class="user-panel-head">
              <div>
                <p class="user-panel-kicker">Feed</p>
                <h2>Resep community terbaru yang tampil di publik</h2>
              </div>
          </div>

          <div class="admin-approval-grid">
            <% if (approvedCommunityRecipesData.length) { %>
              <% approvedCommunityRecipesData.forEach((recipe) => { %>
                <% const isDeletedRecipe = Boolean(recipe.is_deleted || recipe.post_is_deleted); %>
                <article class="community-post-card <%= isDeletedRecipe ? 'is-deleted' : '' %>">
                  <div class="community-post-head">
                    <h3><%= recipe.title %></h3>
                    <span class="community-status <%= isDeletedRecipe ? 'is-deleted' : 'is-approved' %>"><%= isDeletedRecipe ? 'DELETED' : 'Live' %></span>
                  </div>
                  <p><%= recipe.creator_name || 'Community user' %></p>
                  <div class="admin-approval-meta">
                    <span><i class="fa-regular fa-clock"></i> <%= recipe.cooking_time || 0 %> min</span>
                    <span><i class="fa-solid fa-wallet"></i> Rp <%= new Intl.NumberFormat('id-ID').format(Number(recipe.estimated_price || 0)) %></span>
                  </div>
                </article>
              <% }) %>
            <% } else { %>
              <div class="community-empty-state">
                <h3>Belum ada resep approved.</h3>
                <p>Setelah approve pertama dilakukan, ringkasan ini akan terisi otomatis.</p>
              </div>
            <% } %>
          </div>
        </section>
      </section>
    </div>
  </main>
</body>
</html>
